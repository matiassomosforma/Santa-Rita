{% liquid
  assign blog_articles = section.settings.blog.articles
  assign article_limit = section.settings.article_limit
%}

<santa-rita-blog-slider class="santa-rita-blog-slider">
  <div class="santa-rita-blog-slider__container">
    <header class="santa-rita-blog-slider__header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
    </header>

    <div class="santa-rita-blog-slider__viewport" data-blog-slider-viewport>
      <div class="santa-rita-blog-slider__track" data-blog-slider-track>
        {% if section.settings.blog != blank and blog_articles.size > 0 %}
          {% for article in blog_articles limit: article_limit %}
            {% liquid
              assign article_tag = article.tags | first
              assign article_excerpt = article.excerpt_or_content | strip_html | truncate: section.settings.excerpt_length
            %}

            <article class="santa-rita-blog-card">
              <a href="{{ article.url }}" class="santa-rita-blog-card__media" aria-label="{{ article.title | escape }}">
                {% if article.image != blank %}
                  {{
                    article.image
                    | image_url: width: 900
                    | image_tag:
                      widths: '360, 520, 720, 900',
                      sizes: '(min-width: 990px) 33vw, 86vw',
                      loading: 'lazy',
                      class: 'santa-rita-blog-card__image'
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'santa-rita-blog-card__image santa-rita-blog-card__image--placeholder' }}
                {% endif %}

                {% if article_tag != blank %}
                  <span class="santa-rita-blog-card__tag">{{ article_tag }}</span>
                {% endif %}
              </a>

              <div class="santa-rita-blog-card__content">
                <h3>
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h3>

                {% if article_excerpt != blank %}
                  <p>{{ article_excerpt }}</p>
                {% endif %}

                <a href="{{ article.url }}" class="santa-rita-blog-card__button">
                  {{ section.settings.button_label }}
                </a>
              </div>
            </article>
          {% endfor %}
        {% else %}
          {% for index in (1..3) %}
            <article class="santa-rita-blog-card">
              <div class="santa-rita-blog-card__media">
                {{ 'image' | placeholder_svg_tag: 'santa-rita-blog-card__image santa-rita-blog-card__image--placeholder' }}
                <span class="santa-rita-blog-card__tag">Recomendaciones</span>
              </div>

              <div class="santa-rita-blog-card__content">
                <h3>Selecciona un blog para mostrar artículos reales</h3>
                <p>Cuando el blog tenga entradas, aquí se cargará su imagen, título, resumen y primera etiqueta.</p>
                <span class="santa-rita__button">{{ section.settings.button_label }}</span>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="santa-rita-blog-slider__footer">
      <div class="santa-rita-blog-slider__dots" data-blog-slider-dots aria-label="Paginación de artículos"></div>
      <div class="santa-rita-blog-slider__arrows">
        <button type="button" data-blog-slider-prev aria-label="Artículos anteriores">
          <span aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="33" height="20" viewBox="0 0 33 20" fill="none">
              <path d="M11 0C11 1.06 9.99212 2.64286 8.97187 3.97143C7.66012 5.68571 6.09263 7.18143 4.2955 8.32286C2.948 9.17857 1.3145 10 0 10M0 10C1.3145 10 2.94938 10.8214 4.2955 11.6771C6.09263 12.82 7.66012 14.3157 8.97187 16.0271C9.99212 17.3571 11 18.9429 11 20M0 10H33" stroke="white"/>
            </svg>
          </span>
        </button>
        <button type="button" data-blog-slider-next aria-label="Artículos siguientes">
          <span aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="33" height="20" viewBox="0 0 33 20" fill="none">
              <path d="M22 0C22 1.06 23.0079 2.64286 24.0281 3.97143C25.3399 5.68571 26.9074 7.18143 28.7045 8.32286C30.052 9.17857 31.6855 10 33 10M33 10C31.6855 10 30.0506 10.8214 28.7045 11.6771C26.9074 12.82 25.3399 14.3157 24.0281 16.0271C23.0079 17.3571 22 18.9429 22 20M33 10H0" stroke="white"/>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </div>
</santa-rita-blog-slider>

<script>
  if (!customElements.get('santa-rita-blog-slider')) {
    customElements.define(
      'santa-rita-blog-slider',
      class SantaRitaBlogSlider extends HTMLElement {
        connectedCallback() {
          this.viewport = this.querySelector('[data-blog-slider-viewport]');
          this.track = this.querySelector('[data-blog-slider-track]');
          this.prevButton = this.querySelector('[data-blog-slider-prev]');
          this.nextButton = this.querySelector('[data-blog-slider-next]');
          this.dotsContainer = this.querySelector('[data-blog-slider-dots]');
          this.footer = this.querySelector('.santa-rita-blog-slider__footer');

          this.handleResize = () => this.setupDots();

          if (!this.viewport || !this.track) return;

          this.prevButton?.addEventListener('click', () => this.scrollByPage(-1));
          this.nextButton?.addEventListener('click', () => this.scrollByPage(1));
          this.viewport.addEventListener('scroll', () => this.updateState(), { passive: true });
          window.addEventListener('resize', this.handleResize);

          this.setupDots();
        }

        disconnectedCallback() {
          window.removeEventListener('resize', this.handleResize);
        }

        getColumns() {
          if (window.matchMedia('(max-width: 749px)').matches) return 1;
          if (window.matchMedia('(max-width: 989px)').matches) return 2;
          return 3;
        }

        getPageWidth() {
          return this.viewport.clientWidth;
        }

        getPageCount() {
          const total = this.track.querySelectorAll('.santa-rita-blog-card').length;
          return Math.max(1, Math.ceil(total / this.getColumns()));
        }

        hasOverflow() {
          const total = this.track.querySelectorAll('.santa-rita-blog-card').length;
          return total > this.getColumns();
        }

        setupDots() {
          const hasOverflow = this.hasOverflow();

          if (this.footer) this.footer.hidden = !hasOverflow;
          if (!this.dotsContainer) return;

          this.dotsContainer.innerHTML = '';
          if (!hasOverflow) return;

          for (let index = 0; index < this.getPageCount(); index += 1) {
            const button = document.createElement('button');
            button.type = 'button';
            button.setAttribute('aria-label', `Ir al grupo ${index + 1}`);
            button.addEventListener('click', () => {
              this.viewport.scrollTo({ left: index * this.getPageWidth(), behavior: 'smooth' });
            });
            this.dotsContainer.append(button);
          }

          this.updateState();
        }

        scrollByPage(direction) {
          this.viewport.scrollBy({ left: direction * this.getPageWidth(), behavior: 'smooth' });
        }

        updateState() {
          const pageWidth = this.getPageWidth();
          const activeIndex = Math.round(this.viewport.scrollLeft / pageWidth);
          const maxScroll = Math.max(0, this.viewport.scrollWidth - this.viewport.clientWidth);

          Array.from(this.dotsContainer?.children || []).forEach((dot, index) => {
            dot.classList.toggle('is-active', index === activeIndex);
            dot.setAttribute('aria-current', index === activeIndex ? 'true' : 'false');
          });

          if (this.prevButton) this.prevButton.disabled = this.viewport.scrollLeft <= 4;
          if (this.nextButton) this.nextButton.disabled = this.viewport.scrollLeft >= maxScroll - 4;
        }
      }
    );
  }
</script>

{% stylesheet %}
  .santa-rita-blog-slider {
    display: block;
    background: #1E0812;
    color: #ffffff;
  }

  .santa-rita-blog-slider__container {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding: 64px clamp(24px, 8.2vw, 122px) 58px;
  }

  .santa-rita-blog-slider__header {
    margin-bottom: 40px;
  }

  .santa-rita-blog-slider__header h2 {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading--family);
    font-size: clamp(34px, 4.2vw, 48px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
  }

  .santa-rita-blog-slider__header p {
    margin: 34px 0 0;
    color: inherit;
    font-size: 24px;
    line-height: 1.35;
  }

  .santa-rita-blog-slider__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
  }

  .santa-rita-blog-slider__viewport::-webkit-scrollbar {
    display: none;
  }

  .santa-rita-blog-slider__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 56px) / 3);
    gap: 28px;
  }

  .santa-rita-blog-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    scroll-snap-align: start;
    overflow: hidden;
    border-radius: 8px;
    background: #fbf3e9;
    color: #21000f;
  }

  .santa-rita-blog-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 1.48 / 1;
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-blog-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .santa-rita-blog-card__image--placeholder {
    background: #dbcabb;
    opacity: 0.72;
  }

  .santa-rita-blog-card__tag {
    position: absolute;
    top: 18px;
    right: 18px;
    max-width: calc(100% - 36px);
    padding: 8px 12px;
    border-radius: 999px;
    background: #160009;
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .santa-rita-blog-card__content {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto 1fr;
    gap: 18px 20px;
    flex: 1;
    padding: 20px 20px 20px;
  }

  .santa-rita-blog-card__content h3 {
    grid-column: 1 / -1;
    margin: 0;
    color: inherit;
    font-family: var(--font-heading--family);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .santa-rita-blog-card__content h3 a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-blog-card__content p {
    margin: 0;
    color: #2a1520;
    font-size: 16px;
    line-height: 1.18;
  }

  .santa-rita-blog-card__button {
    align-self: end;
    grid-column: 2;
    grid-row: 2;
    padding: 14px 24px;
    border-radius: 8px;
    background: #9b173f;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .santa-rita-blog-slider__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 34px;
    margin-top: 34px;
  }

  .santa-rita-blog-slider__footer[hidden] {
    display: none;
  }

  .santa-rita-blog-slider__dots {
    display: flex;
    gap: 7px;
  }

  .santa-rita-blog-slider__dots button {
    width: 9px;
    height: 9px;
    padding: 0;
    border: 1px solid rgb(255 255 255 / 90%);
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
  }

  .santa-rita-blog-slider__dots button.is-active {
    background: #ffffff;
  }

  .santa-rita-blog-slider__arrows {
    display: flex;
    gap: 14px;
  }

  .santa-rita-blog-slider__arrows button {
    display: grid;
    width: 60px;
    height: 60px;
    place-items: center;
    border: 1px solid white;
    border-radius: 999px;
    background: transparent;
    color: #ffffff;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease, opacity 0.25s ease;
  }

  .santa-rita-blog-slider__arrows button:hover {
    border-color: #ffffff;
    background: rgb(255 255 255 / 10%);
  }

  .santa-rita-blog-slider__arrows button:disabled {
    opacity: 0.34;
    cursor: default;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-blog-slider__track {
      grid-auto-columns: calc((100% - 20px) / 2);
      gap: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-blog-slider__container {
      padding: 44px 20px 48px;
    }

    .santa-rita-blog-slider__header {
      margin-bottom: 28px;
    }

    .santa-rita-blog-slider__header h2 {
      font-size: 34px;
    }

    .santa-rita-blog-slider__header p {
      margin-top: 18px;
      font-size: 16px;
    }

    .santa-rita-blog-slider__track {
      grid-auto-columns: 86%;
      gap: 16px;
    }

    .santa-rita-blog-card__content {
      grid-template-columns: 1fr;
    }

    .santa-rita-blog-card__button {
      justify-self: start;
    }

    .santa-rita-blog-slider__footer {
      justify-content: space-between;
      gap: 20px;
      margin-top: 28px;
    }

    .santa-rita-blog-slider__arrows button {
      width: 46px;
      height: 46px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Santa Rita blog slider",
  "tag": "section",
  "class": "section-santa-rita-blog-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Historias para descubrir"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto",
      "default": "Conoce el blog de Santa Rita Online."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "article_limit",
      "label": "Cantidad de artículos",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 9
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "label": "Largo del resumen",
      "min": 50,
      "max": 160,
      "step": 10,
      "default": 90
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto botón",
      "default": "Ver más"
    }
  ],
  "presets": [
    {
      "name": "Santa Rita blog slider"
    }
  ]
}
{% endschema %}
