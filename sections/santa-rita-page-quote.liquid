{% if section.settings.show_section %}
  <section class="santa-rita-page-quote santa-rita-page-quote--{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
    <div class="santa-rita-page-quote__inner">
      {% if section.settings.show_icon %}
        <span class="santa-rita-page-quote__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.99993 1.5C5.27201 1.5 2.25 4.27704 2.25 7.70288C2.25 9.43015 3.01938 10.9926 4.26065 12.1168L3.54806 15.1385L6.64833 13.5447C7.37492 13.7778 8.16692 13.9058 8.99993 13.9058C12.7278 13.9058 15.75 11.1287 15.75 7.70288C15.75 4.27704 12.7278 1.5 8.99993 1.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            <path d="M6.25 7.75H6.2575M9 7.75H9.0075M11.75 7.75H11.7575" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="santa-rita-page-quote__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.author != blank %}
        <p class="santa-rita-page-quote__author">{{ section.settings.author }}</p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <a href="{{ section.settings.button_url }}" class="santa-rita-page-quote__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </section>
{% endif %}

<style>
  .santa-rita-page-quote {
    display: block;
    background: #fffbf6;
    color: #21000f;
    text-align: center;
  }

  .santa-rita-page-quote--dark {
    background: #21000f;
    color: #ffffff;
  }

  .santa-rita-page-quote__inner {
    width: min(100% - 48px, 780px);
    margin-inline: auto;
    padding-block: 58px;
  }

  .santa-rita-page-quote__icon {
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    margin-bottom: 16px;
    border-radius: 50%;
    background: #f8e8dd;
    color: #8c1a3e;
  }

  .santa-rita-page-quote h2 {
    margin: 0 0 12px;
    font-family: var(--font-heading--family);
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .santa-rita-page-quote__text {
    font-size: 16px;
    line-height: 1.55;
  }

  .santa-rita-page-quote__text p {
    margin: 0;
  }

  .santa-rita-page-quote__author {
    margin: 12px 0 0;
    color: #8c1a3e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .santa-rita-page-quote--dark .santa-rita-page-quote__author {
    color: #f8e8dd;
  }

  .santa-rita-page-quote__button {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin-top: 18px;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 16px;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .santa-rita-page-quote__inner {
      width: calc(100% - 40px);
      padding-block: 38px;
    }

    .santa-rita-page-quote h2 {
      font-size: 24px;
    }

    .santa-rita-page-quote__text {
      font-size: 13px;
      line-height: 1.45;
    }
  }
</style>

{% schema %}
{
  "name": "SR cita o CTA",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Mostrar seccion",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Fondo",
      "default": "light",
      "options": [
        {
          "value": "light",
          "label": "Claro"
        },
        {
          "value": "dark",
          "label": "Burdeo"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Mostrar icono",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Agrega una cita, mensaje destacado o llamado a la accion.</p>"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Autor o bajada"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto boton"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link boton"
    }
  ],
  "presets": [
    {
      "name": "SR cita o CTA"
    }
  ]
}
{% endschema %}
