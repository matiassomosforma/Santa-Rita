{% if section.settings.show_section %}
  <section class="santa-rita-page-quote santa-rita-page-quote--{{ section.settings.color_scheme }} santa-rita-page-quote--text-{{ section.settings.text_version }}" {{ section.shopify_attributes }}>
    <div class="santa-rita-page-quote__inner">
      {% if section.settings.show_icon %}
        <span class="santa-rita-page-quote__icon" aria-hidden="true">
          {% if section.settings.icon_image != blank %}
            {{
              section.settings.icon_image
              | image_url: width: 120
              | image_tag:
                widths: '40, 60, 80, 120',
                sizes: '40px',
                loading: 'lazy',
                class: 'santa-rita-page-quote__icon-image'
            }}
          {% else %}
            <svg width="19" height="27" viewBox="0 0 19 27" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.4407 9.33633L15.8895 0.672656C15.8323 0.478552 15.7139 0.308152 15.5519 0.186913C15.3899 0.0656743 15.193 0.000104681 14.9907 0H3.76643C3.56409 0.000104681 3.3672 0.0656743 3.2052 0.186913C3.0432 0.308152 2.92477 0.478552 2.8676 0.672656L0.316431 9.33633C-0.0838343 10.6642 -0.104782 12.0776 0.255953 13.4168C0.616688 14.756 1.34473 15.9676 2.35784 16.9148C4.02441 18.4776 6.16566 19.4383 8.44104 19.6441V24.375H4.69104C4.4424 24.375 4.20394 24.4738 4.02813 24.6496C3.85231 24.8254 3.75354 25.0639 3.75354 25.3125C3.75354 25.5611 3.85231 25.7996 4.02813 25.9754C4.20394 26.1512 4.4424 26.25 4.69104 26.25H14.066C14.3147 26.25 14.5531 26.1512 14.729 25.9754C14.9048 25.7996 15.0035 25.5611 15.0035 25.3125C15.0035 25.0639 14.9048 24.8254 14.729 24.6496C14.5531 24.4738 14.3147 24.375 14.066 24.375H10.316V19.6441C12.5914 19.4383 14.7327 18.4776 16.3992 16.9148C17.4124 15.9676 18.1404 14.756 18.5011 13.4168C18.8619 12.0776 18.8409 10.6642 18.4407 9.33633ZM4.46721 1.875H14.2899L16.6442 9.86602C16.6547 9.90117 16.6641 9.93633 16.6735 9.97148C14.1633 10.8715 11.3367 9.78398 9.80276 9.00703C6.85081 7.51289 4.50706 7.32305 2.77854 7.60898L4.46721 1.875ZM15.1207 15.5449C13.564 17.0026 11.5112 17.8136 9.37854 17.8136C7.2459 17.8136 5.19308 17.0026 3.63635 15.5449C2.87824 14.8345 2.33385 13.9262 2.06466 12.9228C1.79546 11.9193 1.81217 10.8605 2.11292 9.86602L2.16565 9.68789C3.5719 9.21211 5.80667 9.08555 8.95432 10.6805C10.261 11.3426 12.3715 12.1863 14.6297 12.1863C15.3845 12.1901 16.136 12.0875 16.8621 11.8816C16.7665 13.2792 16.1441 14.5884 15.1207 15.5449Z" fill="#8C1A3E"/>
            </svg>
          {% endif %}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="santa-rita-page-quote__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.author != blank %}
        <p class="santa-rita-page-quote__author">{{ section.settings.author }}</p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <a href="{{ section.settings.button_url }}" class="santa-rita-page-quote__button">
          {{ section.settings.button_label }} <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M12.2496 2.1875C12.2496 2.07147 12.2035 1.96019 12.1214 1.87814C12.0394 1.79609 11.9281 1.75 11.8121 1.75H6.56208C6.44604 1.75 6.33476 1.79609 6.25272 1.87814C6.17067 1.96019 6.12458 2.07147 6.12458 2.1875C6.12458 2.30353 6.17067 2.41481 6.25272 2.49686C6.33476 2.57891 6.44604 2.625 6.56208 2.625H10.756L1.87733 11.5028C1.83665 11.5434 1.80438 11.5917 1.78237 11.6449C1.76035 11.698 1.74902 11.755 1.74902 11.8125C1.74902 11.87 1.76035 11.927 1.78237 11.9801C1.80438 12.0333 1.83665 12.0816 1.87733 12.1222C1.918 12.1629 1.96629 12.1952 2.01944 12.2172C2.07259 12.2392 2.12955 12.2506 2.18708 12.2506C2.2446 12.2506 2.30156 12.2392 2.35471 12.2172C2.40786 12.1952 2.45615 12.1629 2.49683 12.1222L11.3746 3.24363V7.4375C11.3746 7.55353 11.4207 7.66481 11.5027 7.74686C11.5848 7.82891 11.696 7.875 11.8121 7.875C11.9281 7.875 12.0394 7.82891 12.1214 7.74686C12.2035 7.66481 12.2496 7.55353 12.2496 7.4375V2.1875Z" fill="white"/>
</svg>

        </a>
      {% endif %}
    </div>
  </section>
{% endif %}

<style>
  .santa-rita-page-quote {
    display: block;
    background: #fffbf6;
    color: #21000f;
    text-align: center;
  }

  .santa-rita-page-quote--dark {
    background: #21000f;
    color: #ffffff;
  }

  .santa-rita-page-quote__inner {
    width: min(100% - 48px, 645px);
    margin-inline: auto;
    padding-block: 58px;
  }

  .santa-rita-page-quote__icon {
    display: inline-grid;
    width: 60px;
    height: 60px;
    place-items: center;
    margin-bottom: 16px;
    border-radius: 50%;
    background: #f8e8dd;
    color: #8c1a3e;
  }

  .santa-rita-page-quote__icon-image {
    display: block;
    width: 25px;
    height: 25px;
    object-fit: contain;
  }

  .santa-rita-page-quote h2 {
    margin: 0 0 12px;
    font-family: var(--font-heading--family);
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
    margin-bottom: 25px;
  }

  .santa-rita-page-quote__text {
    font-size: 20px;
    line-height: 1.55;
  }

  .santa-rita-page-quote--text-version-2 .santa-rita-page-quote__text {
    font-family: var(--font-heading--family);
    font-size: clamp(24px, 2.5vw, 24px);
    font-style: italic;
    line-height: 1.35;
  }

  .santa-rita-page-quote__text p {
    margin: 0;
  }

  .santa-rita-page-quote__author {
    margin: 12px 0 0;
    color: #8c1a3e;
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .santa-rita-page-quote--dark .santa-rita-page-quote__author {
    color: #f8e8dd;
  }

  .santa-rita-page-quote__button {
  display: inline-flex;
    min-height: 36px;
    align-items: center;
    justify-content: center;
    margin-top: 18px;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    padding-inline: 16px;
    text-decoration: none;
    gap: 8px;
  }

  @media screen and (max-width: 749px) {
    .santa-rita-page-quote__inner {
      width: calc(100% - 40px);
      padding-block: 38px;
    }

    .santa-rita-page-quote h2 {
      font-size: 24px;
    }

    .santa-rita-page-quote__text {
      font-size: 13px;
      line-height: 1.45;
    }

    .santa-rita-page-quote--text-version-2 .santa-rita-page-quote__text {
      font-size: 19px;
      line-height: 1.35;
    }
  }
</style>

{% schema %}
{
  "name": "SR cita o CTA",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Mostrar seccion",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Fondo",
      "default": "light",
      "options": [
        {
          "value": "light",
          "label": "Claro"
        },
        {
          "value": "dark",
          "label": "Burdeo"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Mostrar icono",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Icono imagen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo"
    },
    {
      "type": "select",
      "id": "text_version",
      "label": "Version de texto",
      "default": "version-1",
      "options": [
        {
          "value": "version-1",
          "label": "Version 1"
        },
        {
          "value": "version-2",
          "label": "Version 2"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Agrega una cita, mensaje destacado o llamado a la accion.</p>"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Autor o bajada"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto boton"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link boton"
    }
  ],
  "presets": [
    {
      "name": "SR cita o CTA"
    }
  ]
}
{% endschema %}
