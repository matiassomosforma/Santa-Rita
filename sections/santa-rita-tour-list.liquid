{% liquid
  assign tours_collection = section.settings.collection
  assign products_limit = section.settings.products_limit | default: 6
%}

<section
  class="santa-rita-tour-list"
  aria-labelledby="santa-rita-tour-list-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="santa-rita-tour-list__inner">
    <div class="santa-rita-tour-list__header">
      {% if section.settings.heading != blank %}
        <h2 id="santa-rita-tour-list-title-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="santa-rita-tour-list__grid">
      {% if tours_collection != blank and tours_collection.products_count > 0 %}
        {% for product in tours_collection.products limit: products_limit %}
          {% liquid
            assign variant = product.selected_or_first_available_variant
            assign card_image = product.featured_image
            assign badge = product.metafields.custom.tour_badge.value | default: product.metafields.custom.tour_badge
            assign duration = product.metafields.custom.tour_duration.value | default: product.metafields.custom.tour_duration
            assign capacity = product.metafields.custom.tour_capacity.value | default: product.metafields.custom.tour_capacity
            assign short_description = product.metafields.custom.tour_short_description.value | default: product.metafields.custom.tour_short_description
            assign short_description = short_description | default: product.description | strip_html
          %}

          <article class="santa-rita-tour-list__card">
            <a class="santa-rita-tour-list__media" href="{{ product.url }}" aria-label="Ver {{ product.title | escape }}">
              {% if card_image != blank %}
                {{
                  card_image
                  | image_url: width: 720
                  | image_tag:
                    widths: '320, 480, 640, 720',
                    sizes: '(min-width: 990px) 31vw, 100vw',
                    loading: 'lazy',
                    class: 'santa-rita-tour-list__image'
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-list__image santa-rita-tour-list__image--placeholder' }}
              {% endif %}

              {% if badge != blank %}
                <span class="santa-rita-tour-list__badge">{{ badge }}</span>
              {% endif %}
            </a>

            <div class="santa-rita-tour-list__body">
              <h3>
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              {% if short_description != blank %}
                <p>{{ short_description | strip_html | truncatewords: 23 }}</p>
              {% endif %}

              <div class="santa-rita-tour-list__meta">
                {% if duration != blank %}
                  <span>{{ duration }}</span>
                {% endif %}
                {% if capacity != blank %}
                  <span>{{ capacity }}</span>
                {% endif %}
              </div>

              <div class="santa-rita-tour-list__footer">
                <div>
                  <strong>{{ variant.price | money }}</strong>
                  {% if section.settings.price_note != blank %}
                    <small>{{ section.settings.price_note }}</small>
                  {% endif %}
                </div>

                <a class="santa-rita-tour-list__button" href="{{ product.url }}">
                  {{ section.settings.card_button_label }}
                </a>
              </div>
            </div>
          </article>
        {% endfor %}
      {% elsif request.design_mode %}
        {% for index in (1..3) %}
          <article class="santa-rita-tour-list__card">
            <div class="santa-rita-tour-list__media">
              {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-list__image santa-rita-tour-list__image--placeholder' }}
              {% if index == 1 %}
                <span class="santa-rita-tour-list__badge">Destacado</span>
              {% endif %}
            </div>

            <div class="santa-rita-tour-list__body">
              <h3>Tour Santa Rita</h3>
              <p>Selecciona una coleccion de productos para mostrar tours administrables desde Shopify.</p>
              <div class="santa-rita-tour-list__meta">
                <span>1 h 30 min</span>
                <span>Por persona</span>
              </div>
              <div class="santa-rita-tour-list__footer">
                <div>
                  <strong>$50.000</strong>
                  <small>{{ section.settings.price_note }}</small>
                </div>
                <span class="santa-rita-tour-list__button">{{ section.settings.card_button_label }}</span>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.notice != blank %}
      <p class="santa-rita-tour-list__notice">{{ section.settings.notice }}</p>
    {% endif %}
  </div>

  {% assign transport_blocks = section.blocks | where: 'type', 'transport' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}

  {% if transport_blocks.size > 0 or section.settings.map_image != blank or section.settings.map_heading != blank %}
    <div class="santa-rita-tour-list__arrival">
      <div class="santa-rita-tour-list__arrival-inner">
        <div class="santa-rita-tour-list__section-heading">
          {% if section.settings.arrival_heading != blank %}
            <h2>{{ section.settings.arrival_heading }}</h2>
          {% endif %}
          {% if section.settings.arrival_text != blank %}
            <p>{{ section.settings.arrival_text }}</p>
          {% endif %}
        </div>

        {% if transport_blocks.size > 0 %}
          <div class="santa-rita-tour-list__transport-grid">
            {% for block in transport_blocks %}
              <article class="santa-rita-tour-list__transport" {{ block.shopify_attributes }}>
                <span class="santa-rita-tour-list__transport-icon" aria-hidden="true">{{ block.settings.icon }}</span>
                <h3>{{ block.settings.title }}</h3>
                {% if block.settings.time != blank %}
                  <p>{{ block.settings.time }}</p>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.map_image != blank or section.settings.map_heading != blank %}
          <div class="santa-rita-tour-list__map">
            {% if section.settings.map_image != blank %}
              {{
                section.settings.map_image
                | image_url: width: 1200
                | image_tag:
                  widths: '360, 640, 960, 1200',
                  sizes: '(min-width: 990px) 56vw, 100vw',
                  loading: 'lazy',
                  class: 'santa-rita-tour-list__map-image'
              }}
            {% endif %}

            <div class="santa-rita-tour-list__map-info">
              {% if section.settings.map_heading != blank %}
                <h3>{{ section.settings.map_heading }}</h3>
              {% endif %}
              {% if section.settings.map_text != blank %}
                <p>{{ section.settings.map_text }}</p>
              {% endif %}
              {% if section.settings.map_link != blank %}
                <a href="{{ section.settings.map_link }}" target="_blank" rel="noopener">
                  {{ section.settings.map_link_label }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if faq_blocks.size > 0 %}
    <div class="santa-rita-tour-list__faq">
      <div class="santa-rita-tour-list__faq-inner">
        <div class="santa-rita-tour-list__section-heading">
          {% if section.settings.faq_heading != blank %}
            <h2>{{ section.settings.faq_heading }}</h2>
          {% endif %}
          {% if section.settings.faq_text != blank %}
            <p>{{ section.settings.faq_text }}</p>
          {% endif %}
        </div>

        <div class="santa-rita-tour-list__faq-items">
          {% for block in faq_blocks %}
            <details class="santa-rita-tour-list__faq-item" {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.question }}</span>
                <span aria-hidden="true">+</span>
              </summary>
              <div>{{ block.settings.answer }}</div>
            </details>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</section>

<style>
  .santa-rita-tour-list {
    display: block;
    background: #fffbf6;
    color: #21000f;
  }

  .santa-rita-tour-list__inner,
  .santa-rita-tour-list__arrival-inner,
  .santa-rita-tour-list__faq-inner {
    width: min(100% - 48px, 1140px);
    margin-inline: auto;
  }

  .santa-rita-tour-list__inner {
    padding-block: 48px 34px;
  }

  .santa-rita-tour-list__header,
  .santa-rita-tour-list__section-heading {
    max-width: 640px;
    margin-bottom: 28px;
  }

  .santa-rita-tour-list h2 {
    margin: 0 0 8px;
    font-family: var(--font-heading--family);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__header p,
  .santa-rita-tour-list__section-heading p {
    margin: 0;
    color: #4f3c43;
    font-size: 15px;
    line-height: 1.45;
  }

  .santa-rita-tour-list__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .santa-rita-tour-list__card {
    display: grid;
    overflow: hidden;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 8px 24px rgba(140, 26, 62, 0.08);
  }

  .santa-rita-tour-list__media {
    position: relative;
    display: block;
    aspect-ratio: 1.62 / 1;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-tour-list__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .santa-rita-tour-list__image--placeholder {
    background: #eadfd5;
    fill: rgba(140, 26, 62, 0.22);
  }

  .santa-rita-tour-list__card:hover .santa-rita-tour-list__image {
    transform: scale(1.035);
  }

  .santa-rita-tour-list__badge {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    min-height: 22px;
    align-items: center;
    border-radius: 999px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 10px;
  }

  .santa-rita-tour-list__body {
    display: grid;
    gap: 12px;
    padding: 22px;
  }

  .santa-rita-tour-list__body h3 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 19px;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__body h3 a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-tour-list__body p {
    min-height: 58px;
    margin: 0;
    color: #4f3c43;
    font-size: 13px;
    line-height: 1.38;
  }

  .santa-rita-tour-list__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .santa-rita-tour-list__meta span {
    display: inline-flex;
    min-height: 24px;
    align-items: center;
    border-radius: 999px;
    background: #fff3ec;
    color: #8c1a3e;
    font-size: 11px;
    line-height: 1;
    padding-inline: 10px;
  }

  .santa-rita-tour-list__footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-top: 4px;
  }

  .santa-rita-tour-list__footer strong,
  .santa-rita-tour-list__footer small {
    display: block;
  }

  .santa-rita-tour-list__footer strong {
    font-size: 17px;
    line-height: 1.1;
  }

  .santa-rita-tour-list__footer small {
    margin-top: 4px;
    color: #6e5a61;
    font-size: 11px;
  }

  .santa-rita-tour-list__button {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 14px;
    text-decoration: none;
    white-space: nowrap;
  }

  .santa-rita-tour-list__notice {
    margin: 28px 0 0;
    border-radius: 4px;
    background: #fff5e8;
    color: #4f3c43;
    font-size: 12px;
    line-height: 1.35;
    padding: 12px 16px;
  }

  .santa-rita-tour-list__arrival {
    background: #fff7f1;
  }

  .santa-rita-tour-list__arrival-inner {
    padding-block: 56px;
  }

  .santa-rita-tour-list__transport-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  .santa-rita-tour-list__transport {
    border-radius: 6px;
    background: #ffffff;
    padding: 18px;
    box-shadow: 0 4px 18px rgba(140, 26, 62, 0.06);
  }

  .santa-rita-tour-list__transport-icon {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border-radius: 50%;
    background: #fff0f3;
    color: #8c1a3e;
    font-size: 17px;
  }

  .santa-rita-tour-list__transport h3 {
    margin: 14px 0 6px;
    font-family: var(--font-heading--family);
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__transport p {
    margin: 0;
    color: #8c1a3e;
    font-size: 12px;
    font-weight: 700;
  }

  .santa-rita-tour-list__map {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(260px, 0.8fr);
    overflow: hidden;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 4px 18px rgba(140, 26, 62, 0.08);
  }

  .santa-rita-tour-list__map-image {
    width: 100%;
    height: 100%;
    min-height: 180px;
    object-fit: cover;
  }

  .santa-rita-tour-list__map-info {
    align-self: center;
    padding: 28px;
  }

  .santa-rita-tour-list__map-info h3 {
    margin: 0 0 8px;
    font-family: var(--font-heading--family);
    font-size: 20px;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__map-info p {
    margin: 0 0 16px;
    color: #4f3c43;
    font-size: 13px;
    line-height: 1.4;
  }

  .santa-rita-tour-list__map-info a {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    padding-inline: 14px;
    text-decoration: none;
  }

  .santa-rita-tour-list__faq {
    background: #250012;
    color: #ffffff;
  }

  .santa-rita-tour-list__faq-inner {
    padding-block: 52px 62px;
  }

  .santa-rita-tour-list__faq .santa-rita-tour-list__section-heading p {
    color: rgba(255, 255, 255, 0.76);
  }

  .santa-rita-tour-list__faq-items {
    display: grid;
  }

  .santa-rita-tour-list__faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .santa-rita-tour-list__faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .santa-rita-tour-list__faq-item summary {
    display: flex;
    min-height: 58px;
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    font-size: 14px;
    line-height: 1.25;
  }

  .santa-rita-tour-list__faq-item summary::-webkit-details-marker {
    display: none;
  }

  .santa-rita-tour-list__faq-item[open] summary span:last-child {
    transform: rotate(45deg);
  }

  .santa-rita-tour-list__faq-item div {
    max-width: 760px;
    padding-bottom: 22px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 13px;
    line-height: 1.45;
  }

  .santa-rita-tour-list__faq-item div p {
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-tour-list__grid,
    .santa-rita-tour-list__transport-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .santa-rita-tour-list__map {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-tour-list__inner,
    .santa-rita-tour-list__arrival-inner,
    .santa-rita-tour-list__faq-inner {
      width: calc(100% - 24px);
    }

    .santa-rita-tour-list__inner {
      padding-block: 34px 28px;
    }

    .santa-rita-tour-list__grid,
    .santa-rita-tour-list__transport-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .santa-rita-tour-list__body p {
      min-height: 0;
    }

    .santa-rita-tour-list__arrival-inner {
      padding-block: 42px;
    }

    .santa-rita-tour-list__map-info {
      padding: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "Tours",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleccion de tours"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Cantidad de tours",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Elige tu experiencia"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Bajada",
      "default": "Desde recorridos clasicos hasta vivencias unicas en el corazon de la vina."
    },
    {
      "type": "text",
      "id": "card_button_label",
      "label": "Texto boton tour",
      "default": "Ver mas"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Nota precio",
      "default": "por persona"
    },
    {
      "type": "textarea",
      "id": "notice",
      "label": "Nota bajo listado",
      "default": "Reserva con anticipacion. Todos los tours requieren reserva minima con 24 horas de anticipacion."
    },
    {
      "type": "header",
      "content": "Como llegar"
    },
    {
      "type": "text",
      "id": "arrival_heading",
      "label": "Titulo como llegar",
      "default": "Como llegar a Vina Santa Rita?"
    },
    {
      "type": "textarea",
      "id": "arrival_text",
      "label": "Texto como llegar",
      "default": "Elige tu medio de transporte preferido y te mostramos el camino hasta la vina."
    },
    {
      "type": "image_picker",
      "id": "map_image",
      "label": "Imagen mapa"
    },
    {
      "type": "text",
      "id": "map_heading",
      "label": "Titulo mapa",
      "default": "Vina Santa Rita"
    },
    {
      "type": "textarea",
      "id": "map_text",
      "label": "Texto mapa",
      "default": "Camino Padre Hurtado 0695, Alto Jahuel"
    },
    {
      "type": "url",
      "id": "map_link",
      "label": "Link Google Maps"
    },
    {
      "type": "text",
      "id": "map_link_label",
      "label": "Texto boton mapa",
      "default": "Ir a Google Maps"
    },
    {
      "type": "header",
      "content": "Preguntas frecuentes"
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "Titulo FAQ",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "textarea",
      "id": "faq_text",
      "label": "Bajada FAQ",
      "default": "Todo lo que necesitas saber sobre Tour Vina Santa Rita."
    }
  ],
  "blocks": [
    {
      "type": "transport",
      "name": "Transporte",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono",
          "default": "A"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Automovil particular"
        },
        {
          "type": "text",
          "id": "time",
          "label": "Tiempo",
          "default": "1 hora"
        }
      ]
    },
    {
      "type": "faq",
      "name": "Pregunta frecuente",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "En que idiomas estan disponibles los tours?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Los tours pueden configurarse segun la disponibilidad definida por el equipo de Santa Rita.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tours",
      "blocks": [
        {
          "type": "transport",
          "settings": {
            "icon": "A",
            "title": "Automovil particular",
            "time": "1 hora"
          }
        },
        {
          "type": "transport",
          "settings": {
            "icon": "M",
            "title": "Metro + Taxi colectivo",
            "time": "45 min"
          }
        },
        {
          "type": "transport",
          "settings": {
            "icon": "B",
            "title": "Bus MB81",
            "time": "1 hora"
          }
        },
        {
          "type": "transport",
          "settings": {
            "icon": "T",
            "title": "Transporte privado",
            "time": "40 min"
          }
        },
        {
          "type": "faq"
        },
        {
          "type": "faq",
          "settings": {
            "question": "Se permiten mascotas en la Vina Santa Rita?"
          }
        }
      ]
    }
  ]
}
{% endschema %}
