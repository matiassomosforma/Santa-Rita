{% liquid
  assign tours_collection = section.settings.collection
  assign tour_products = section.settings.products
  assign products_limit = section.settings.products_limit | default: 6

  if tour_products == blank and tours_collection != blank
    assign tour_products = tours_collection.products
  endif
%}

<section
  class="santa-rita-tour-list"
  aria-labelledby="santa-rita-tour-list-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="santa-rita-tour-list__inner">
    <div class="santa-rita-tour-list__header">
      {% if section.settings.heading != blank %}
        <h2 id="santa-rita-tour-list-title-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <santa-rita-tour-slider class="santa-rita-tour-list__slider">
      <div class="santa-rita-tour-list__viewport" data-slider-viewport>
        <div class="santa-rita-tour-list__grid" data-slider-track>
          {% if tour_products != blank %}
            {% for product in tour_products limit: products_limit %}
              {% liquid
                assign variant = product.selected_or_first_available_variant
                assign card_image = product.featured_image
                assign badge = product.metafields.custom.tour_badge.value | default: product.metafields.custom.tour_badge
                assign duration = product.metafields.custom.tour_duration.value | default: product.metafields.custom.tour_duration
                assign short_description_metafield = product.metafields.custom.tour_short_description

                capture short_description
                  if short_description_metafield != blank
                    echo short_description_metafield | metafield_tag
                  else
                    echo product.description
                  endif
                endcapture

                assign short_description = short_description | strip_html | strip
              %}

              <article class="santa-rita-tour-list__card">
                <a class="santa-rita-tour-list__media" href="{{ product.url }}" aria-label="Ver {{ product.title | escape }}">
                  {% if card_image != blank %}
                    {{
                      card_image
                      | image_url: width: 720
                      | image_tag:
                        widths: '320, 480, 640, 720',
                        sizes: '(min-width: 990px) 31vw, 100vw',
                        loading: 'lazy',
                        class: 'santa-rita-tour-list__image'
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-list__image santa-rita-tour-list__image--placeholder' }}
                  {% endif %}

                  {% if badge != blank %}
                    <span class="santa-rita-tour-list__badge">{{ badge }}</span>
                  {% endif %}
                </a>

                <div class="santa-rita-tour-list__body">
                  <h3>
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>

                  {% if short_description != blank %}
                    <p>{{ short_description | truncatewords: 23 }}</p>
                  {% endif %}

                  <div class="santa-rita-tour-list__footer">
                    <div>
                      <strong>{{ variant.price | money }}</strong>
                      {% if duration != blank %}
                        <small>{{ duration }}</small>
                      {% elsif section.settings.price_note != blank %}
                        <small>{{ section.settings.price_note }}</small>
                      {% endif %}
                    </div>

                    <a class="santa-rita-tour-list__button" href="{{ product.url }}">
                      {{ section.settings.card_button_label }}
                    </a>
                  </div>
                </div>
              </article>
            {% endfor %}
          {% elsif request.design_mode %}
            {% for index in (1..3) %}
              <article class="santa-rita-tour-list__card">
                <div class="santa-rita-tour-list__media">
                  {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-list__image santa-rita-tour-list__image--placeholder' }}
                  {% if index == 1 %}
                    <span class="santa-rita-tour-list__badge">Destacado</span>
                  {% endif %}
                </div>

                <div class="santa-rita-tour-list__body">
                  <h3>Tour Santa Rita</h3>
                  <p>Selecciona una coleccion de productos para mostrar tours administrables desde Shopify.</p>
                  <div class="santa-rita-tour-list__footer">
                    <div>
                      <strong>$50.000</strong>
                      <small>1 h 30 min</small>
                    </div>
                    <span class="santa-rita-tour-list__button">{{ section.settings.card_button_label }}</span>
                  </div>
                </div>
              </article>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <div class="santa-rita-tour-list__controls">
        <div class="santa-rita-tour-list__dots" data-slider-dots aria-label="Paginacion de tours"></div>
        <div class="santa-rita-tour-list__arrows">
          <button type="button" class="santa-rita-tour-list__arrow" data-slider-prev aria-label="Tours anteriores">
            <svg viewBox="0 0 32 20" fill="none" focusable="false" aria-hidden="true">
              <path d="M11 1C11 2.05 9.99 3.59 8.97 4.89C7.66 6.56 6.09 8.02 4.3 9.13C2.95 9.97 1.31 10.78 0 10.78M0 10.78C1.31 10.78 2.95 11.58 4.3 12.42C6.09 13.54 7.66 15 8.97 16.67C9.99 17.97 11 19.5 11 20.55M0 10.78H32" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          </button>
          <button type="button" class="santa-rita-tour-list__arrow" data-slider-next aria-label="Tours siguientes">
            <svg viewBox="0 0 32 20" fill="none" focusable="false" aria-hidden="true">
              <path d="M21 1C21 2.05 22.01 3.59 23.03 4.89C24.34 6.56 25.91 8.02 27.7 9.13C29.05 9.97 30.69 10.78 32 10.78M32 10.78C30.69 10.78 29.05 11.58 27.7 12.42C25.91 13.54 24.34 15 23.03 16.67C22.01 17.97 21 19.5 21 20.55M32 10.78H0" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          </button>
        </div>
      </div>
    </santa-rita-tour-slider>

    {% if section.settings.notice != blank %}
      <p class="santa-rita-tour-list__notice">{{ section.settings.notice }}</p>
    {% endif %}
  </div>

  {% assign transport_blocks = section.blocks | where: 'type', 'transport' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}

  {% if transport_blocks.size > 0 or section.settings.map_image != blank or section.settings.map_embed_code != blank or section.settings.map_heading != blank %}
    <div class="santa-rita-tour-list__arrival">
      <div class="santa-rita-tour-list__arrival-inner">
        <div class="santa-rita-tour-list__section-heading">
          {% if section.settings.arrival_heading != blank %}
            <h2>{{ section.settings.arrival_heading }}</h2>
          {% endif %}
          {% if section.settings.arrival_text != blank %}
            <p>{{ section.settings.arrival_text }}</p>
          {% endif %}
        </div>

        {% if transport_blocks.size > 0 %}
          <div class="santa-rita-tour-list__transport-grid">
            {% for block in transport_blocks %}
              <article class="santa-rita-tour-list__transport" {{ block.shopify_attributes }}>
                <span class="santa-rita-tour-list__transport-icon" aria-hidden="true">{{ block.settings.icon }}</span>
                <h3>{{ block.settings.title }}</h3>
                {% if block.settings.time != blank %}
                  <p>{{ block.settings.time }}</p>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.map_image != blank or section.settings.map_embed_code != blank or section.settings.map_heading != blank %}
          <div class="santa-rita-tour-list__map">
            <div class="santa-rita-tour-list__map-media">
              {% if section.settings.map_embed_code != blank %}
                {{ section.settings.map_embed_code }}
              {% elsif section.settings.map_image != blank %}
                {{
                  section.settings.map_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '360, 640, 960, 1200',
                    sizes: '(min-width: 990px) 56vw, 100vw',
                    loading: 'lazy',
                    class: 'santa-rita-tour-list__map-image'
                }}
              {% elsif request.design_mode %}
                {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-list__map-image santa-rita-tour-list__map-image--placeholder' }}
              {% endif %}
            </div>

            <div class="santa-rita-tour-list__map-info">
              {% if section.settings.map_heading != blank %}
                <h3>{{ section.settings.map_heading }}</h3>
              {% endif %}
              {% if section.settings.map_text != blank %}
                <p>{{ section.settings.map_text }}</p>
              {% endif %}
              {% if section.settings.map_link != blank %}
                <a href="{{ section.settings.map_link }}" target="_blank" rel="noopener">
                  {{ section.settings.map_link_label }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if faq_blocks.size > 0 %}
    <div class="santa-rita-tour-list__faq">
      <div class="santa-rita-tour-list__faq-inner">
        <div class="santa-rita-tour-list__section-heading">
          {% if section.settings.faq_heading != blank %}
            <h2>{{ section.settings.faq_heading }}</h2>
          {% endif %}
          {% if section.settings.faq_text != blank %}
            <p>{{ section.settings.faq_text }}</p>
          {% endif %}
        </div>

        <div class="santa-rita-tour-list__faq-items">
          {% for block in faq_blocks %}
            <details class="santa-rita-tour-list__faq-item" {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.question }}</span>
                <span aria-hidden="true">+</span>
              </summary>
              <div>{{ block.settings.answer }}</div>
            </details>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</section>

<script>
  if (!customElements.get('santa-rita-tour-slider')) {
    customElements.define(
      'santa-rita-tour-slider',
      class SantaRitaTourSlider extends HTMLElement {
        connectedCallback() {
          this.viewport = this.querySelector('[data-slider-viewport]');
          this.track = this.querySelector('[data-slider-track]');
          this.prevButton = this.querySelector('[data-slider-prev]');
          this.nextButton = this.querySelector('[data-slider-next]');
          this.dotsContainer = this.querySelector('[data-slider-dots]');
          this.controls = this.querySelector('.santa-rita-tour-list__controls');
          this.handleResize = () => this.setupDots();

          if (!this.viewport || !this.track) return;

          this.prevButton?.addEventListener('click', () => this.scrollByPage(-1));
          this.nextButton?.addEventListener('click', () => this.scrollByPage(1));
          this.viewport.addEventListener('scroll', () => this.updateState(), { passive: true });
          window.addEventListener('resize', this.handleResize);

          this.setupDots();
        }

        disconnectedCallback() {
          window.removeEventListener('resize', this.handleResize);
        }

        getStep() {
          const card = this.track.querySelector('.santa-rita-tour-list__card');

          if (!card) return this.viewport.clientWidth;

          const gap = parseFloat(window.getComputedStyle(this.track).columnGap || '0');
          return card.getBoundingClientRect().width + gap;
        }

        getPageCount() {
          const total = this.track.querySelectorAll('.santa-rita-tour-list__card').length;
          const visible = Math.max(1, Math.round(this.viewport.clientWidth / this.getStep()));

          return Math.max(1, total - visible + 1);
        }

        setupDots() {
          if (!this.dotsContainer) return;

          this.dotsContainer.innerHTML = '';
          const count = this.getPageCount();

          if (this.controls) {
            this.controls.hidden = count <= 1;
          }

          for (let index = 0; index < count; index += 1) {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = 'santa-rita-tour-list__dot';
            dot.setAttribute('aria-label', `Ir al grupo ${index + 1} de tours`);
            dot.addEventListener('click', () => {
              this.viewport.scrollTo({ left: index * this.getStep(), behavior: 'smooth' });
            });
            this.dotsContainer.append(dot);
          }

          this.updateState();
        }

        scrollByPage(direction) {
          this.viewport.scrollBy({ left: direction * this.getStep(), behavior: 'smooth' });
        }

        updateState() {
          const step = this.getStep();
          const activeIndex = Math.round(this.viewport.scrollLeft / step);
          const maxScroll = Math.max(0, this.viewport.scrollWidth - this.viewport.clientWidth);

          Array.from(this.dotsContainer?.children || []).forEach((dot, index) => {
            dot.classList.toggle('is-active', index === activeIndex);
            dot.setAttribute('aria-current', index === activeIndex ? 'true' : 'false');
          });

          if (this.prevButton) this.prevButton.disabled = this.viewport.scrollLeft <= 4;
          if (this.nextButton) this.nextButton.disabled = this.viewport.scrollLeft >= maxScroll - 4;
        }
      }
    );
  }
</script>

<style>
  .santa-rita-tour-list {
    display: block;
    background: #fffbf6;
    color: #21000f;
  }

  .santa-rita-tour-list__inner,
  .santa-rita-tour-list__arrival-inner,
  .santa-rita-tour-list__faq-inner {
    width: min(100% - 48px, 1140px);
    margin-inline: auto;
  }

  .santa-rita-tour-list__inner {
    padding-block: 48px 34px;
  }

  .santa-rita-tour-list__header,
  .santa-rita-tour-list__section-heading {
    max-width: 640px;
    margin-bottom: 28px;
  }

  .santa-rita-tour-list h2 {
    margin: 0 0 8px;
    font-family: var(--font-heading--family);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__header p,
  .santa-rita-tour-list__section-heading p {
    margin: 0;
    color: #4f3c43;
    font-size: 15px;
    line-height: 1.45;
  }

  .santa-rita-tour-list__slider {
    display: block;
  }

  .santa-rita-tour-list__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    padding-block: 8px 14px;
  }

  .santa-rita-tour-list__viewport::-webkit-scrollbar {
    display: none;
  }

  .santa-rita-tour-list__grid {
    display: grid;
    grid-auto-columns: calc((100% - 56px) / 3);
    grid-auto-flow: column;
    column-gap: 28px;
    align-items: stretch;
  }

  .santa-rita-tour-list__card {
    display: grid;
    overflow: hidden;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 8px 24px rgba(140, 26, 62, 0.08);
    scroll-snap-align: start;
  }

  .santa-rita-tour-list__media {
    position: relative;
    display: block;
    aspect-ratio: 1.5 / 1;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-tour-list__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .santa-rita-tour-list__image--placeholder {
    background: #eadfd5;
    fill: rgba(140, 26, 62, 0.22);
  }

  .santa-rita-tour-list__card:hover .santa-rita-tour-list__image {
    transform: scale(1.035);
  }

  .santa-rita-tour-list__badge {
    position: absolute;
    top: 11px;
    right: 11px;
    display: inline-flex;
    min-height: 24px;
    align-items: center;
    border-radius: 999px;
    background: #250012;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 12px;
  }

  .santa-rita-tour-list__body {
    display: grid;
    gap: 10px;
    padding: 20px 20px 18px;
  }

  .santa-rita-tour-list__body h3 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 18px;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__body h3 a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-tour-list__body p {
    min-height: 66px;
    margin: 0;
    color: #2f2026;
    font-size: 12px;
    line-height: 1.32;
  }

  .santa-rita-tour-list__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .santa-rita-tour-list__meta span {
    display: inline-flex;
    min-height: 20px;
    align-items: center;
    border-radius: 0;
    background: transparent;
    color: #6e5a61;
    font-size: 10px;
    line-height: 1;
    padding-inline: 0;
  }

  .santa-rita-tour-list__meta span::before {
    content: '';
    width: 14px;
    height: 14px;
    margin-right: 4px;
    border: 1px solid currentColor;
    border-radius: 50%;
  }

  .santa-rita-tour-list__footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-top: 4px;
  }

  .santa-rita-tour-list__footer strong,
  .santa-rita-tour-list__footer small {
    display: block;
  }

  .santa-rita-tour-list__footer strong {
    font-size: 16px;
    line-height: 1.1;
  }

  .santa-rita-tour-list__footer small {
    margin-top: 4px;
    color: #6e5a61;
    font-size: 11px;
  }

  .santa-rita-tour-list__footer small::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    margin-right: 4px;
    border: 1px solid currentColor;
    border-radius: 50%;
    vertical-align: -3px;
  }

  .santa-rita-tour-list__button {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 14px;
    text-decoration: none;
    white-space: nowrap;
  }

  .santa-rita-tour-list__notice {
    margin: 28px 0 0;
    border-radius: 4px;
    background: #fff5e8;
    color: #4f3c43;
    font-size: 12px;
    line-height: 1.35;
    padding: 12px 16px;
  }

  .santa-rita-tour-list__controls {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 28px;
    margin-top: 32px;
  }

  .santa-rita-tour-list__controls[hidden] {
    display: none;
  }

  .santa-rita-tour-list__dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .santa-rita-tour-list__dot {
    width: 9px;
    height: 9px;
    cursor: pointer;
    border: 1px solid #8c1a3e;
    border-radius: 50%;
    background: transparent;
    padding: 0;
  }

  .santa-rita-tour-list__dot.is-active {
    background: #8c1a3e;
  }

  .santa-rita-tour-list__arrows {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .santa-rita-tour-list__arrow {
    display: grid;
    width: 48px;
    height: 48px;
    cursor: pointer;
    place-items: center;
    border: 1px solid rgba(140, 26, 62, 0.45);
    border-radius: 50%;
    background: transparent;
    color: #8c1a3e;
    padding: 0;
  }

  .santa-rita-tour-list__arrow svg {
    width: 32px;
    height: 20px;
  }

  .santa-rita-tour-list__arrow:disabled {
    cursor: default;
    opacity: 0.45;
  }

  .santa-rita-tour-list__arrival {
    background: #fff7f1;
  }

  .santa-rita-tour-list__arrival-inner {
    padding-block: 56px;
  }

  .santa-rita-tour-list__transport-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  .santa-rita-tour-list__transport {
    border-radius: 6px;
    background: #ffffff;
    padding: 18px;
    box-shadow: 0 4px 18px rgba(140, 26, 62, 0.06);
  }

  .santa-rita-tour-list__transport-icon {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border-radius: 50%;
    background: #fff0f3;
    color: #8c1a3e;
    font-size: 17px;
  }

  .santa-rita-tour-list__transport h3 {
    margin: 14px 0 6px;
    font-family: var(--font-heading--family);
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__transport p {
    margin: 0;
    color: #8c1a3e;
    font-size: 12px;
    font-weight: 700;
  }

  .santa-rita-tour-list__map {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(260px, 0.8fr);
    overflow: hidden;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 4px 18px rgba(140, 26, 62, 0.08);
  }

  .santa-rita-tour-list__map-media {
    min-height: 180px;
    background: #eadfd5;
  }

  .santa-rita-tour-list__map-media iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 220px;
    border: 0;
  }

  .santa-rita-tour-list__map-image {
    width: 100%;
    height: 100%;
    min-height: 180px;
    object-fit: cover;
  }

  .santa-rita-tour-list__map-image--placeholder {
    display: block;
    background: #eadfd5;
    fill: rgba(140, 26, 62, 0.22);
  }

  .santa-rita-tour-list__map-info {
    align-self: center;
    padding: 28px;
  }

  .santa-rita-tour-list__map-info h3 {
    margin: 0 0 8px;
    font-family: var(--font-heading--family);
    font-size: 20px;
    letter-spacing: 0;
  }

  .santa-rita-tour-list__map-info p {
    margin: 0 0 16px;
    color: #4f3c43;
    font-size: 13px;
    line-height: 1.4;
  }

  .santa-rita-tour-list__map-info a {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    padding-inline: 14px;
    text-decoration: none;
  }

  .santa-rita-tour-list__faq {
    background: #250012;
    color: #ffffff;
  }

  .santa-rita-tour-list__faq-inner {
    padding-block: 52px 62px;
  }

  .santa-rita-tour-list__faq .santa-rita-tour-list__section-heading p {
    color: rgba(255, 255, 255, 0.76);
  }

  .santa-rita-tour-list__faq-items {
    display: grid;
  }

  .santa-rita-tour-list__faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .santa-rita-tour-list__faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .santa-rita-tour-list__faq-item summary {
    display: flex;
    min-height: 58px;
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    font-size: 14px;
    line-height: 1.25;
  }

  .santa-rita-tour-list__faq-item summary::-webkit-details-marker {
    display: none;
  }

  .santa-rita-tour-list__faq-item[open] summary span:last-child {
    transform: rotate(45deg);
  }

  .santa-rita-tour-list__faq-item div {
    max-width: 760px;
    padding-bottom: 22px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 13px;
    line-height: 1.45;
  }

  .santa-rita-tour-list__faq-item div p {
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-tour-list__grid {
      grid-auto-columns: calc((100% - 18px) / 2);
      column-gap: 18px;
    }

    .santa-rita-tour-list__transport-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .santa-rita-tour-list__map {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-tour-list__inner,
    .santa-rita-tour-list__arrival-inner,
    .santa-rita-tour-list__faq-inner {
      width: calc(100% - 24px);
    }

    .santa-rita-tour-list__inner {
      padding-block: 34px 28px;
    }

    .santa-rita-tour-list__grid {
      grid-auto-columns: 100%;
      column-gap: 14px;
    }

    .santa-rita-tour-list__transport-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .santa-rita-tour-list__card {
      max-width: none;
    }

    .santa-rita-tour-list__controls {
      justify-content: space-between;
      gap: 18px;
      margin-top: 24px;
    }

    .santa-rita-tour-list__arrow {
      width: 42px;
      height: 42px;
    }

    .santa-rita-tour-list__body p {
      min-height: 0;
    }

    .santa-rita-tour-list__arrival-inner {
      padding-block: 42px;
    }

    .santa-rita-tour-list__map-info {
      padding: 22px;
    }
  }
</style>

