{% liquid
  assign slider_id = 'SantaRitaAwardsSlider-' | append: section.id
%}

<santa-rita-awards-slider
  id="{{ slider_id }}"
  class="santa-rita-awards-slider"
  style="
    --awards-background: {{ section.settings.background }};
    --awards-text-color: {{ section.settings.text_color }};
    --awards-card-width: {{ section.settings.card_width }}px;
  "
>
  <div class="santa-rita-awards-slider__container">
    <div class="santa-rita-awards-slider__intro">
      {% if section.settings.show_stars %}
        <div class="santa-rita-awards-slider__stars" aria-label="5 estrellas">
          {% for index in (1..5) %}
            <span>
              <svg xmlns="http://www.w3.org/2000/svg" width="25" height="24" viewBox="0 0 25 24" fill="none">
                <path d="M5.64165 23.3492C5.03852 23.6586 4.35415 23.1164 4.47602 22.4242L5.7729 15.0336L0.268209 9.78984C-0.245854 9.29922 0.0213335 8.40234 0.710396 8.30547L8.36352 7.21797L11.776 0.457031C12.0838 -0.152344 12.9166 -0.152344 13.2245 0.457031L16.637 7.21797L24.2901 8.30547C24.9791 8.40234 25.2463 9.29922 24.7307 9.78984L19.2276 15.0336L20.5245 22.4242C20.6463 23.1164 19.962 23.6586 19.3588 23.3492L12.4979 19.8242L5.64165 23.3492Z" fill="#F6EDD9"/>
              </svg>
            </span>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="santa-rita-awards-slider__carousel">
      <div class="santa-rita-awards-slider__viewport" data-awards-viewport>
        <div class="santa-rita-awards-slider__track" data-awards-track>
          {% for block in section.blocks %}
            {% liquid
              assign block_settings = block.settings
              assign tag_name = 'div'
              if block_settings.link != blank
                assign tag_name = 'a'
              endif
            %}

            <{{ tag_name }}
              class="santa-rita-awards-slide santa-rita-awards-slide--{{ block_settings.media_type }}"
              {% if block_settings.link != blank %}
                href="{{ block_settings.link }}"
              {% endif %}
              data-awards-slide
              {{ block.shopify_attributes }}
            >
              <div class="santa-rita-awards-slide__media">
                {% if block_settings.media_type == 'video' %}
                  {% if block_settings.video != blank %}
                    {{
                      block_settings.video
                      | video_tag:
                        image_size: '1200x',
                        autoplay: true,
                        loop: true,
                        muted: true,
                        playsinline: true,
                        preload: 'metadata',
                        class: 'santa-rita-awards-slide__video'
                    }}
                  {% elsif block_settings.video_asset_name != blank %}
                    <video
                      class="santa-rita-awards-slide__video"
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      {% if block_settings.image != blank %}
                        poster="{{ block_settings.image | image_url: width: 900 }}"
                      {% endif %}
                    >
                      <source src="{{ block_settings.video_asset_name | asset_url }}" type="video/mp4">
                    </video>
                  {% else %}
                    <div class="santa-rita-awards-slide__placeholder"></div>
                  {% endif %}
                {% elsif block_settings.image != blank %}
                  {{
                    block_settings.image
                    | image_url: width: 900
                    | image_tag:
                      widths: '360, 520, 720, 900',
                      sizes: '(min-width: 990px) 260px, 72vw',
                      loading: 'lazy',
                      class: 'santa-rita-awards-slide__image'
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'santa-rita-awards-slide__image santa-rita-awards-slide__image--placeholder' }}
                {% endif %}
              </div>

              {% if block_settings.media_type == 'image' %}
                {% if block_settings.title != blank or block_settings.subtitle != blank %}
                  <div class="santa-rita-awards-slide__caption">
                    {% if block_settings.title != blank %}
                      <h3>{{ block_settings.title }}</h3>
                    {% endif %}
                    {% if block_settings.subtitle != blank %}
                      <p>{{ block_settings.subtitle }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}
            </{{ tag_name }}>
          {% endfor %}
        </div>
      </div>
    </div>

    
  </div>
  {% if section.blocks.size > 1 %}
    <div class="santa-rita-awards-slider__footer-container">
      <div class="santa-rita-awards-slider__footer">
        <div class="santa-rita-awards-slider__dots" data-awards-dots aria-label="Paginación"></div>
        <div class="santa-rita-awards-slider__arrows">
          <button type="button" data-awards-prev aria-label="Slide anterior">
            <span aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="33" height="20" viewBox="0 0 33 20" fill="none">
                <path d="M11 0C11 1.06 9.99212 2.64286 8.97187 3.97143C7.66012 5.68571 6.09263 7.18143 4.2955 8.32286C2.948 9.17857 1.3145 10 0 10M0 10C1.3145 10 2.94938 10.8214 4.2955 11.6771C6.09263 12.82 7.66012 14.3157 8.97187 16.0271C9.99212 17.3571 11 18.9429 11 20M0 10H33" stroke="white"/>
              </svg>
            </span>
          </button>
          <button type="button" data-awards-next aria-label="Slide siguiente">
            <span aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="33" height="20" viewBox="0 0 33 20" fill="none">
                <path d="M22 0C22 1.06 23.0079 2.64286 24.0281 3.97143C25.3399 5.68571 26.9074 7.18143 28.7045 8.32286C30.052 9.17857 31.6855 10 33 10M33 10C31.6855 10 30.0506 10.8214 28.7045 11.6771C26.9074 12.82 25.3399 14.3157 24.0281 16.0271C23.0079 17.3571 22 18.9429 22 20M33 10H0" stroke="white"/>
              </svg>
            </span>
          </button>
        </div>
      </div>
    </div>
    {% endif %}
</santa-rita-awards-slider>

<script>
  if (!customElements.get('santa-rita-awards-slider')) {
    customElements.define(
      'santa-rita-awards-slider',
      class SantaRitaAwardsSlider extends HTMLElement {
        connectedCallback() {
          this.viewport = this.querySelector('[data-awards-viewport]');
          this.track = this.querySelector('[data-awards-track]');
          this.slides = Array.from(this.querySelectorAll('[data-awards-slide]'));
          this.prevButton = this.querySelector('[data-awards-prev]');
          this.nextButton = this.querySelector('[data-awards-next]');
          this.dotsContainer = this.querySelector('[data-awards-dots]');
          this.index = 0;
          this.handleResize = () => {
            this.createDots();
            this.update();
          };

          if (!this.viewport || !this.track || !this.slides.length) return;

          this.prevButton?.addEventListener('click', () => this.goTo(this.index - 1));
          this.nextButton?.addEventListener('click', () => this.goTo(this.index + 1));
          window.addEventListener('resize', this.handleResize);
          this.setupVideos();

          requestAnimationFrame(() => {
            this.createDots();
            this.update();
          });
        }

        disconnectedCallback() {
          window.removeEventListener('resize', this.handleResize);
        }

        setupVideos() {
          this.querySelectorAll('.santa-rita-awards-slide__video').forEach((video) => {
            video.muted = true;
            video.loop = true;
            video.playsInline = true;
            video.removeAttribute('controls');
            video.play().catch(() => {});

            const slide = video.closest('.santa-rita-awards-slide');
            if (!slide) return;

            slide.addEventListener('mouseenter', () => video.setAttribute('controls', ''));
            slide.addEventListener('mouseleave', () => video.removeAttribute('controls'));
            slide.addEventListener('focusin', () => video.setAttribute('controls', ''));
            slide.addEventListener('focusout', () => video.removeAttribute('controls'));
          });
        }

        getStep() {
          const slide = this.slides[0];
          if (!slide) return this.viewport.clientWidth;
          return slide.getBoundingClientRect().width + this.getGap();
        }

        getGap() {
          const styles = window.getComputedStyle(this.track);
          return Number.parseFloat(styles.columnGap || styles.gap || '0');
        }

        getMaxIndex() {
          if (this.isMobile()) {
            return Math.max(0, this.slides.length - 2);
          }

          const maxTranslate = this.getMaxTranslate();
          if (maxTranslate <= 1) return 0;
          return Math.ceil(maxTranslate / this.getStep());
        }

        isMobile() {
          return window.matchMedia('(max-width: 749px)').matches;
        }

        getMaxTranslate() {
          const slide = this.slides[0];
          if (!slide) return 0;

          const step = this.getStep();

          if (this.isMobile()) {
            return Math.max(0, (this.slides.length - 2) * step);
          }

          const visibleSlides = (this.viewport.clientWidth + this.getGap()) / step;
          const endPadding = 24;

          return Math.max(0, (this.slides.length - visibleSlides) * step + endPadding);
        }

        createDots() {
          if (!this.dotsContainer) return;
          this.dotsContainer.innerHTML = '';

          for (let index = 0; index <= this.getMaxIndex(); index += 1) {
            const button = document.createElement('button');
            button.type = 'button';
            button.setAttribute('aria-label', `Ir al slide ${index + 1}`);
            button.addEventListener('click', () => this.goTo(index));
            this.dotsContainer.append(button);
          }
        }

        goTo(index) {
          const maxIndex = this.getMaxIndex();
          this.index = Math.min(Math.max(index, 0), maxIndex);
          this.update();
        }

        update() {
          const maxIndex = this.getMaxIndex();
          if (this.index > maxIndex) this.index = maxIndex;

          const translate = Math.min(this.index * this.getStep(), this.getMaxTranslate());
          this.track.style.transform = `translateX(${-translate}px)`;

          Array.from(this.dotsContainer?.children || []).forEach((dot, index) => {
            dot.classList.toggle('is-active', index === this.index);
            dot.setAttribute('aria-current', index === this.index ? 'true' : 'false');
          });

          if (this.prevButton) this.prevButton.disabled = this.index === 0;
          if (this.nextButton) this.nextButton.disabled = this.index === maxIndex;
        }
      }
    );
  }
</script>

{% stylesheet %}
  .santa-rita-awards-slider {
    display: block;
    overflow: hidden;
    --awards-container-gutter: clamp(24px, 8.5vw, 122px);
    --awards-slide-gap: 24px;
    background: var(--awards-background);
    color: var(--awards-text-color);
  }

  .santa-rita-awards-slider__container {
    display: grid;
    grid-template-columns: minmax(260px, 500px) minmax(0, 1fr);
    gap: clamp(48px, 5.6vw, 80px);
    width: 100%;
    padding: 60px 0 58px var(--awards-container-gutter);
  }

  .santa-rita-awards-slider__intro {
    align-self: start;
    padding-top: 4px;
  }

  .santa-rita-awards-slider__stars {
    display: flex;
    gap: 15px;
    margin-bottom: 30px;
    color: #fff7e8;
    font-size: 22px;
    line-height: 1;
  }

  .santa-rita-awards-slider__intro h2 {
    margin: 0;
    color: inherit;
    font-family: var(--font-heading--family);
    font-size: clamp(36px, 4vw, 48px);
    font-weight: 700;
    line-height: normal;
    letter-spacing: 0;
  }

  .santa-rita-awards-slider__intro p {
    margin: 34px 0 0;
    color: inherit;
    font-size: 24px;
    line-height: 1.35;
  }

  .santa-rita-awards-slider__carousel {
    min-width: 0;
  }

  .santa-rita-awards-slider__viewport {
    overflow: hidden;
  }

  .santa-rita-awards-slider__track {
    display: flex;
    gap: var(--awards-slide-gap);
    align-items: flex-start;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .santa-rita-awards-slide {
    flex: 0 0 calc((100% - (var(--awards-slide-gap) * 1.7)) / 2.7);
    color: inherit;
    text-align: center;
    text-decoration: none;
  }

  .santa-rita-awards-slide:hover {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-awards-slide__media {
    overflow: hidden;
    width: 100%;
    aspect-ratio: 3 / 4.08;
    border-radius: 8px;
    background: #080505;
  }

  .santa-rita-awards-slide--video .santa-rita-awards-slide__media {
    background: #000000;
  }

  .santa-rita-awards-slide__image,
  .santa-rita-awards-slide__video,
  .santa-rita-awards-slide__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .santa-rita-awards-slide__image--placeholder {
    opacity: 0.45;
  }

  .santa-rita-awards-slide__caption {
    margin-top: 18px;
  }

  .santa-rita-awards-slide__caption h3 {
    margin: 0;
    color: #F6EDD9;
    font-family: var(--font-body--family);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.2;
  }

  .santa-rita-awards-slide__caption p {
    margin: 6px 0 0;
    color: #F6EDD9;
    font-size: 16px;
    line-height: 1.25;
  }

  .santa-rita-awards-slider__footer-container{
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
  }

  .santa-rita-awards-slider__footer {
    display: flex;
    grid-column: 1 / -1;
    align-items: center;
    justify-content: flex-end;
    gap: 34px;
    margin-bottom: 38px;
    padding-right: var(--awards-container-gutter);
  }

  .santa-rita-awards-slider__dots {
    display: flex;
    gap: 7px;
  }

  .santa-rita-awards-slider__dots button {
    width: 9px;
    height: 9px;
    padding: 0;
    border: 1px solid rgb(255 255 255 / 90%);
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
  }

  .santa-rita-awards-slider__dots button.is-active {
    background: #ffffff;
  }

  .santa-rita-awards-slider__arrows {
    display: flex;
    gap: 14px;
  }

  .santa-rita-awards-slider__arrows button {
    display: grid;
    width: 58px;
    height: 58px;
    place-items: center;
    border: 1px solid rgb(255 255 255 / 38%);
    border-radius: 999px;
    background: transparent;
    color: #ffffff;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .santa-rita-awards-slider__arrows button:hover {
    border-color: #ffffff;
    background: rgb(255 255 255 / 10%);
  }

  .santa-rita-awards-slider__arrows button:disabled {
    opacity: 0.32;
    cursor: default;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-awards-slider__container {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .santa-rita-awards-slider__footer {
      grid-column: auto;
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-awards-slider__container {
      padding: 42px 20px 48px;
    }

    .santa-rita-awards-slider__stars {
      margin-bottom: 20px;
      font-size: 18px;
    }

    .santa-rita-awards-slider__intro h2 {
      font-size: 24px;
    }

    .santa-rita-awards-slider__intro p {
      margin-top: 18px;
      font-size: 16px;
    }

    .santa-rita-awards-slider__track {
      --awards-slide-gap: 16px;
    }

    .santa-rita-awards-slide {
      flex-basis: calc((100% - var(--awards-slide-gap)) / 2);
    }

    .santa-rita-awards-slider__footer {
        justify-content: space-between;
        gap: 20px;
        margin-top: 28px;
        flex-direction: row-reverse;
        padding-inline: 0;
    }

    .santa-rita-awards-slider__arrows button {
      width: 46px;
      height: 46px;
      font-size: 23px;
    }

    .santa-rita-awards-slider__arrows button svg{
      width: 20px;
    }

    .santa-rita-awards-slide__caption h3{
      font-size: 18px;
    }

    .santa-rita-awards-slide__caption p{
      font-size: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Santa Rita premios slider",
  "tag": "section",
  "class": "section-santa-rita-awards-slider",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Mostrar estrellas",
      "default": true
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Título",
      "default": "Vinos premiados\nmundialmente"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto",
      "default": "Descubre los vinos de selección."
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Ancho tarjetas",
      "min": 180,
      "max": 320,
      "step": 10,
      "default": 250,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Fondo",
      "default": "#1E0812"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texto",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Tipo",
          "options": [
            {
              "value": "image",
              "label": "Imagen"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "video_asset_name",
          "label": "Video local en assets",
          "info": "Sólo para pruebas locales. Ejemplo: premio.mp4"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Floresta"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo",
          "default": "Cabernet Franc"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Santa Rita premios slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide",
          "settings": {
            "media_type": "video",
            "title": "",
            "subtitle": ""
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Pewen de Apalta",
            "subtitle": "Carmenere"
          }
        }
      ]
    }
  ]
}
{% endschema %}
