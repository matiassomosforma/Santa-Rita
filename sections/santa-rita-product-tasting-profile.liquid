      padding: 15px;
    }

    .santa-rita-tasting-profile__mouthfeel {
      gap: 12px;
    }
  }
</style>

<script>
  (() => {
    const initTastingProfileSlider = (root = document) => {
      const sections = root.matches?.('[data-santa-rita-tasting-profile]')
        ? [root]
        : Array.from(root.querySelectorAll('[data-santa-rita-tasting-profile]'));

      sections.forEach((section) => {
        if (section.dataset.sliderInitialized === 'true') return;

        const slider = section.querySelector('[data-tasting-profile-slider]');
        const prevButton = section.querySelector('[data-tasting-profile-prev]');
        const nextButton = section.querySelector('[data-tasting-profile-next]');
        const dots = Array.from(section.querySelectorAll('[data-tasting-profile-dot]'));
        const slides = slider ? Array.from(slider.children) : [];

        if (!slider || slides.length < 2 || !prevButton || !nextButton || dots.length === 0) return;

        section.dataset.sliderInitialized = 'true';
        const mobileQuery = window.matchMedia('(max-width: 989px)');

        const updateDots = () => {
          const slideWidth = slider.clientWidth || 1;
          const activeIndex = Math.max(0, Math.min(slides.length - 1, Math.round(slider.scrollLeft / slideWidth)));
          const activeSlide = slides[activeIndex];

          if (mobileQuery.matches && activeSlide) {
            slider.style.height = `${activeSlide.offsetHeight}px`;
          } else {
            slider.style.removeProperty('height');
          }

          dots.forEach((dot, index) => {
            const isActive = index === activeIndex;
            dot.classList.toggle('is-active', isActive);
            if (isActive) {
              dot.setAttribute('aria-current', 'true');
            } else {
              dot.removeAttribute('aria-current');
            }
          });
        };

        const scrollToSlide = (index) => {
          const nextIndex = Math.max(0, Math.min(slides.length - 1, index));
          slider.scrollTo({
            left: slider.clientWidth * nextIndex,
            behavior: 'smooth',
          });
        };

        prevButton.addEventListener('click', () => {
          const activeIndex = Math.round(slider.scrollLeft / (slider.clientWidth || 1));
          scrollToSlide(activeIndex - 1);
        });

        nextButton.addEventListener('click', () => {
          const activeIndex = Math.round(slider.scrollLeft / (slider.clientWidth || 1));
          scrollToSlide(activeIndex + 1);
        });

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            scrollToSlide(Number(dot.dataset.tastingProfileDot || 0));
          });
        });

        slider.addEventListener('scroll', () => {
          window.requestAnimationFrame(updateDots);
        });

        slides.forEach((slide) => {
          slide.querySelectorAll('img').forEach((image) => {
            image.addEventListener('load', updateDots);
          });
        });

        window.addEventListener('resize', updateDots);
        updateDots();
      });
    };

    initTastingProfileSlider();

    document.addEventListener('shopify:section:load', (event) => {
      initTastingProfileSlider(event.target);
    });
  })();
</script>

