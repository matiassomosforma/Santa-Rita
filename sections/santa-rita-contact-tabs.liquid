      "label": "Tab FAQ",
      "default": "Preguntas Frecuentes"
    },
    {
      "type": "header",
      "content": "Formulario"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Título formulario",
      "default": "Formulario de Contacto"
    },
    {
