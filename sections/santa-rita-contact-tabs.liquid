{% liquid
  assign accent = section.settings.accent_color | default: '#8C1A3E'
  assign hero_image = section.settings.hero_image
  assign contact_options = section.settings.subject_options | newline_to_br | split: '<br />'
  assign location_options = section.settings.location_options | newline_to_br | split: '<br />'
  assign area_options = section.settings.area_options | newline_to_br | split: '<br />'
  assign form_id = 'SantaRitaContactTabs-' | append: section.id
  assign faq_blocks = section.blocks | where: 'type', 'faq'
%}

<section
  class="santa-rita-contact-tabs"
  style="--sr-contact-accent: {{ accent }};"
  data-section-id="{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="santa-rita-contact-tabs__hero">
    {% if hero_image != blank %}
      {{
        hero_image
        | image_url: width: 2200
        | image_tag:
          widths: '750, 990, 1440, 1800, 2200',
          sizes: '100vw',
          loading: 'eager',
          class: 'santa-rita-contact-tabs__hero-image'
      }}
    {% endif %}
    <div class="santa-rita-contact-tabs__hero-overlay"></div>
    <div class="santa-rita-contact-tabs__hero-inner">
      {% if section.settings.show_breadcrumbs %}
        <nav class="santa-rita-contact-tabs__breadcrumbs" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Inicio</a>
          <span aria-hidden="true">-</span>
          <span data-sr-contact-current-label>{{ section.settings.contact_tab_label }}</span>
        </nav>
      {% endif %}

      <div class="santa-rita-contact-tabs__hero-content">
        <h1>{{ section.settings.heading }}</h1>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <nav class="santa-rita-contact-tabs__tabbar" aria-label="{{ section.settings.heading | escape }}">
    <button
      type="button"
      class="santa-rita-contact-tabs__tab santa-rita-contact-tabs__tab--active"
      data-sr-contact-tab="contact"
      data-sr-contact-label="{{ section.settings.contact_tab_label | escape }}"
      aria-controls="sr-contact-panel-{{ section.id }}"
      aria-selected="true"
    >
      {{ section.settings.contact_tab_label }}
    </button>
    <button
      type="button"
      class="santa-rita-contact-tabs__tab"
      data-sr-contact-tab="faq"
      data-sr-contact-label="{{ section.settings.faq_tab_label | escape }}"
      aria-controls="sr-faq-panel-{{ section.id }}"
      aria-selected="false"
    >
      {{ section.settings.faq_tab_label }}
    </button>
  </nav>

  <div class="santa-rita-contact-tabs__body">
    <div
      id="sr-contact-panel-{{ section.id }}"
      class="santa-rita-contact-tabs__panel santa-rita-contact-tabs__panel--active"
      data-sr-contact-panel="contact"
    >
      <div class="santa-rita-contact-tabs__card santa-rita-contact-tabs__card--form">
        <h2>{{ section.settings.form_heading }}</h2>

        {% form 'contact', id: form_id, class: 'santa-rita-contact-tabs__form', enctype: 'multipart/form-data' %}
          <input type="hidden" name="contact[Formulario]" value="{{ section.settings.form_heading | escape }}">

          {% if form.posted_successfully? %}
            <div class="santa-rita-contact-tabs__notice santa-rita-contact-tabs__notice--success" tabindex="-1" autofocus>
              {{ section.settings.success_message }}
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="santa-rita-contact-tabs__notice santa-rita-contact-tabs__notice--error" tabindex="-1" autofocus>
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <fieldset>
            <legend>{{ section.settings.help_heading }}</legend>
            <label>
              <span class="visually-hidden">{{ section.settings.subject_label }}</span>
              <select name="contact[{{ section.settings.subject_label | escape }}]" required>
                <option value="">{{ section.settings.subject_label }}</option>
                {% for option in contact_options %}
                  {% assign option_value = option | strip %}
                  {% if option_value != blank %}
                    <option value="{{ option_value | escape }}">{{ option_value }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </label>
            <label>
              <span class="visually-hidden">{{ section.settings.location_label }}</span>
              <select name="contact[{{ section.settings.location_label | escape }}]">
                <option value="">{{ section.settings.location_label }}</option>
                {% for option in location_options %}
                  {% assign option_value = option | strip %}
                  {% if option_value != blank %}
                    <option value="{{ option_value | escape }}">{{ option_value }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </label>
            <label>
              <span class="visually-hidden">{{ section.settings.area_label }}</span>
              <select name="contact[{{ section.settings.area_label | escape }}]">
                <option value="">{{ section.settings.area_label }}</option>
                {% for option in area_options %}
                  {% assign option_value = option | strip %}
                  {% if option_value != blank %}
                    <option value="{{ option_value | escape }}">{{ option_value }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </label>
          </fieldset>

          <fieldset>
            <legend>{{ section.settings.data_heading }}</legend>
            <label>
              <span class="visually-hidden">{{ section.settings.name_label }}</span>
              <input
                type="text"
                name="contact[name]"
                autocomplete="name"
                placeholder="{{ section.settings.name_label }}"
                required
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              >
            </label>
            <label>
              <span class="visually-hidden">{{ section.settings.rut_label }}</span>
              <input type="text" name="contact[{{ section.settings.rut_label | escape }}]" placeholder="{{ section.settings.rut_label }}">
            </label>
            <label>
              <span class="visually-hidden">{{ section.settings.email_label }}</span>
              <input
                type="email"
                name="contact[email]"
                autocomplete="email"
                placeholder="{{ section.settings.email_label }}"
                required
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              >
            </label>
            <label>
              <span class="visually-hidden">{{ section.settings.phone_label }}</span>
              <input
                type="tel"
                name="contact[phone]"
                autocomplete="tel"
                placeholder="{{ section.settings.phone_label }}"
                value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              >
            </label>
          </fieldset>

          <fieldset>
            <legend>{{ section.settings.message_heading }}</legend>
            <label>
              <span class="visually-hidden">{{ section.settings.message_label }}</span>
              <textarea name="contact[body]" rows="7" placeholder="{{ section.settings.message_label }}" required>{{ form.body }}</textarea>
            </label>

            {% if section.settings.show_file_input %}
              <div class="santa-rita-contact-tabs__file">
                <p>{{ section.settings.file_help }}</p>
                <label>
                  <span data-sr-file-name>{{ section.settings.file_placeholder }}</span>
                  <input
                    type="file"
                    name="contact[Archivo]"
                    accept=".jpg,.jpeg,.png,.pdf"
                    data-sr-file-input
                  >
                  <strong>{{ section.settings.file_button_label }}</strong>
                </label>
              </div>
            {% endif %}
          </fieldset>

          <button type="submit">{{ section.settings.submit_label }}</button>
        {% endform %}
      </div>
    </div>

    <div
      id="sr-faq-panel-{{ section.id }}"
      class="santa-rita-contact-tabs__panel"
      data-sr-contact-panel="faq"
      hidden
    >
      <div class="santa-rita-contact-tabs__card santa-rita-contact-tabs__card--faq">
        <h2>{{ section.settings.faq_heading }}</h2>

        {% assign current_group = '' %}
        <div class="santa-rita-contact-tabs__faq-list">
          {% for block in faq_blocks %}
            {% assign block_group = block.settings.group | strip %}
            {% if block_group != blank and block_group != current_group %}
              {% assign current_group = block_group %}
              <h3>{{ current_group }}</h3>
            {% endif %}

            <details class="santa-rita-contact-tabs__faq-item" {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.question }}</span>
                <span aria-hidden="true">+</span>
              </summary>
              <div>{{ block.settings.answer }}</div>
            </details>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!root) return;

    const tabs = root.querySelectorAll('[data-sr-contact-tab]');
    const panels = root.querySelectorAll('[data-sr-contact-panel]');
    const breadcrumbLabel = root.querySelector('[data-sr-contact-current-label]');

    const normalize = (value) =>
      String(value || '')
        .trim()
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');

    const contactAliases = ['contact', 'contacto', normalize('{{ section.settings.contact_tab_label | escape }}')];
    const faqAliases = ['faq', 'preguntas-frecuentes', 'preguntas', normalize('{{ section.settings.faq_tab_label | escape }}')];

    const getRequestedTab = () => {
      const params = new URLSearchParams(window.location.search);
      const queryKeys = Array.from(params.keys()).map(normalize);
      const queryValues = Array.from(params.values()).map(normalize);
      const hash = normalize(window.location.hash.replace('#', ''));
      const allValues = [hash, ...queryKeys, ...queryValues];

      if (allValues.some((value) => faqAliases.includes(value))) return 'faq';
      if (allValues.some((value) => contactAliases.includes(value))) return 'contact';
      return 'contact';
    };

    const activate = (tabName, updateUrl = false) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.srContactTab === tabName;
        tab.classList.toggle('santa-rita-contact-tabs__tab--active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        if (isActive && breadcrumbLabel) breadcrumbLabel.textContent = tab.dataset.srContactLabel || tab.textContent.trim();
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.srContactPanel === tabName;
        panel.classList.toggle('santa-rita-contact-tabs__panel--active', isActive);
        panel.hidden = !isActive;
      });

      if (updateUrl) {
        const hash = tabName === 'faq' ? '#faq' : '#contacto';
        history.replaceState(null, '', `${window.location.pathname}${window.location.search}${hash}`);
      }
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activate(tab.dataset.srContactTab, true));
    });

    root.querySelectorAll('[data-sr-file-input]').forEach((input) => {
      input.addEventListener('change', () => {
        const label = input.closest('label')?.querySelector('[data-sr-file-name]');
        if (label) label.textContent = input.files?.[0]?.name || '{{ section.settings.file_placeholder | escape }}';
      });
    });

    activate(getRequestedTab(), false);
    window.addEventListener('hashchange', () => activate(getRequestedTab(), false));
  })();
</script>

<style>
  .santa-rita-contact-tabs {
    --sr-contact-bg: #fbf8f2;
    background: var(--sr-contact-bg);
    color: #1d1117;
  }

  .santa-rita-contact-tabs__hero {
    position: relative;
    min-height: clamp(230px, 28vw, 405px);
    overflow: hidden;
    background: #111;
    color: #fff;
  }

  .santa-rita-contact-tabs__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .santa-rita-contact-tabs__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgb(0 0 0 / 0.82), rgb(0 0 0 / 0.46) 45%, rgb(0 0 0 / 0.08));
  }

  .santa-rita-contact-tabs__hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    width: min(100% - 48px, 1220px);
    min-height: inherit;
    flex-direction: column;
    margin-inline: auto;
    padding-block: 28px 56px;
  }

  .santa-rita-contact-tabs__breadcrumbs {
    display: flex;
    gap: 8px;
    font-size: 0.75rem;
    opacity: 0.85;
  }

  .santa-rita-contact-tabs__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-contact-tabs__hero-content {
    max-width: 760px;
    margin-block: auto;
  }

  .santa-rita-contact-tabs__hero h1,
  .santa-rita-contact-tabs__card h2 {
    margin: 0;
    font-family: var(--font-primary--family);
    letter-spacing: 0;
  }

  .santa-rita-contact-tabs__hero h1 {
    font-size: clamp(2.2rem, 4vw, 4.1rem);
    line-height: 1.1;
  }

  .santa-rita-contact-tabs__hero p {
    margin: 16px 0 0;
    font-size: 1rem;
  }

  .santa-rita-contact-tabs__tabbar {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    background: #fff;
    border-bottom: 1px solid rgb(0 0 0 / 0.08);
  }

  .santa-rita-contact-tabs__tab {
    min-height: 52px;
    border: 0;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: #1d1117;
    cursor: pointer;
    font: inherit;
  }

  .santa-rita-contact-tabs__tab--active {
    border-bottom-color: var(--sr-contact-accent);
    color: var(--sr-contact-accent);
    font-weight: 700;
  }

  .santa-rita-contact-tabs__body {
    width: min(100% - 32px, 1220px);
    margin-inline: auto;
    padding-block: 56px 84px;
  }

  .santa-rita-contact-tabs__panel[hidden] {
    display: none;
  }

  .santa-rita-contact-tabs__card {
    width: min(100%, 620px);
    margin-inline: auto;
    padding: clamp(28px, 4vw, 56px);
    border: 1px solid rgb(0 0 0 / 0.12);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.04);
  }

  .santa-rita-contact-tabs__card h2 {
    font-size: clamp(2rem, 3.2vw, 3rem);
    line-height: 1.14;
  }

  .santa-rita-contact-tabs__form {
    display: grid;
    gap: 20px;
    margin-top: 24px;
  }

  .santa-rita-contact-tabs__form fieldset {
    display: grid;
    gap: 12px;
    min-width: 0;
    margin: 0;
    padding: 0 0 18px;
    border: 0;
    border-bottom: 1px dashed rgb(140 26 62 / 0.35);
  }

  .santa-rita-contact-tabs__form legend,
  .santa-rita-contact-tabs__faq-list h3 {
    margin: 0 0 8px;
    color: var(--sr-contact-accent);
    font-family: var(--font-primary--family);
    font-weight: 700;
  }

  .santa-rita-contact-tabs__form input,
  .santa-rita-contact-tabs__form select,
  .santa-rita-contact-tabs__form textarea {
    width: 100%;
    min-height: 44px;
    padding: 12px 14px;
    border: 1px solid rgb(0 0 0 / 0.16);
    border-radius: 3px;
    background: #fff;
    color: #1d1117;
    font: inherit;
    font-size: 0.95rem;
  }

  .santa-rita-contact-tabs__form textarea {
    min-height: 132px;
    resize: vertical;
  }

  .santa-rita-contact-tabs__file p {
    margin: 0 0 8px;
    font-size: 0.85rem;
    line-height: 1.35;
  }

  .santa-rita-contact-tabs__file label {
    display: flex;
    min-height: 56px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 12px;
    border: 1px solid rgb(0 0 0 / 0.16);
    border-radius: 3px;
  }

  .santa-rita-contact-tabs__file input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .santa-rita-contact-tabs__file strong {
    padding: 10px 18px;
    border: 1px solid var(--sr-contact-accent);
    border-radius: 999px;
    color: var(--sr-contact-accent);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .santa-rita-contact-tabs__form button[type='submit'] {
    min-height: 48px;
    border: 0;
    border-radius: 8px;
    background: var(--sr-contact-accent);
    color: #fff;
    cursor: pointer;
    font-weight: 700;
  }

  .santa-rita-contact-tabs__notice {
    padding: 12px 14px;
    border-radius: 4px;
    font-size: 0.95rem;
  }

  .santa-rita-contact-tabs__notice--success {
    background: rgb(0 100 0 / 0.08);
    color: #006400;
  }

  .santa-rita-contact-tabs__notice--error {
    background: rgb(139 0 0 / 0.08);
    color: #8b0000;
  }

  .santa-rita-contact-tabs__faq-list {
    margin-top: 32px;
  }

  .santa-rita-contact-tabs__faq-list h3 {
    margin-top: 32px;
    font-size: 1.2rem;
  }

  .santa-rita-contact-tabs__faq-list h3:first-child {
    margin-top: 0;
  }

  .santa-rita-contact-tabs__faq-item {
    border-bottom: 1px solid rgb(0 0 0 / 0.12);
  }

  .santa-rita-contact-tabs__faq-item summary {
    display: flex;
    min-height: 58px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    font-weight: 600;
    list-style: none;
  }

  .santa-rita-contact-tabs__faq-item summary::-webkit-details-marker {
    display: none;
  }

  .santa-rita-contact-tabs__faq-item[open] summary span:last-child {
    transform: rotate(45deg);
  }

  .santa-rita-contact-tabs__faq-item div {
    padding: 0 44px 20px 0;
    color: rgb(29 17 23 / 0.72);
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .santa-rita-contact-tabs__hero-inner {
      width: min(100% - 32px, 1220px);
      padding-block: 18px 36px;
    }

    .santa-rita-contact-tabs__tabbar {
      position: sticky;
      top: 0;
      z-index: 2;
    }

    .santa-rita-contact-tabs__body {
      padding-block: 32px 56px;
    }

    .santa-rita-contact-tabs__card {
      padding: 28px 22px;
    }
  }
</style>

