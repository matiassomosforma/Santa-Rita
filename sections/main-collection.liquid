      gap: 0;
      padding: 0 var(--page-margin);
      border-top-color: #e1cfb8;
      border-bottom-color: #e1cfb8;
    }

    .santa-rita-collection-nav__divider {
      display: block;
      width: 1px;
      height: 18px;
      align-self: center;
      background: #e1cfb8;
    }

    .santa-rita-collection-nav__links {
      display: none;
    }

    .santa-rita-collection-nav__sort {
      display: flex;
      min-width: 0;
      justify-content: center;
      z-index: 1001;
    }

    .santa-rita-collection-nav__filter {
      min-height: 31px;
      justify-content: center;
      gap: 6px;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      color: #21000f;
      font-size: 14px;
      font-weight: 400;
    }

    .santa-rita-collection-nav__filter .svg-wrapper {
      width: 16px;
      height: 16px;
    }

    .santa-rita-collection-nav__filter[aria-expanded='true'] {
      border: 0;
      background: transparent;
      color: #21000f;
    }

    .santa-rita-collection-nav__sort .sorting-filter,
    .santa-rita-collection-nav__sort accordion-custom,
    .santa-rita-collection-nav__sort .facets__panel {
      width: 100%;
      height: 100%;
    }

    .santa-rita-collection-nav__sort .facets__panel {
      position: relative;
    }

    .santa-rita-collection-nav__sort .facets__panel[open]::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(33, 0, 15, 0.2);
    }

    .santa-rita-collection-nav__sort .facets__summary {
      min-height: 31px;
      justify-content: center;
      gap: 6px;
      padding: 0;
      border: 0;
      background: transparent;
      color: #21000f;
      font-size: 14px;
      line-height: 1;
    }

    .santa-rita-collection-nav__sort .facets__label {
      margin: 0;
      color: inherit;
      font-family: var(--font-body--family);
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
    }

    .santa-rita-collection-nav__sort [data-sort-current],
    .santa-rita-collection-nav__sort .facets__status {
      display: none;
    }

    .santa-rita-collection-nav__sort .icon-caret {
      width: 10px;
      height: 10px;
    }

    .santa-rita-collection-nav__sort .santa-rita-sort-sheet {
      position: fixed !important;
      top: auto !important;
      right: 0 !important;
      bottom: 0 !important;
      left: 0 !important;
      display: block !important;
      grid-template-rows: none !important;
      width: 100vw;
      min-width: 100vw;
      max-width: 100vw;
      max-height: 72dvh;
      padding: 18px 20px 20px;
      border: 0;
      border-radius: 0;
      background: #fffaf4;
      box-shadow: 0 -10px 26px rgba(33, 0, 15, 0.12);
      opacity: 0;
      overflow-y: auto;
      pointer-events: none;
      transform: translate3d(0, 100%, 0);
      transition: none !important;
      will-change: transform;
      z-index: 1001;
    }

    .santa-rita-collection-nav__sort .facets__panel[open] .santa-rita-sort-sheet {
      animation: santa-rita-sort-sheet-in 0.22s ease-out forwards;
      opacity: 1;
      pointer-events: auto;
      transform: translate3d(0, 0, 0);
    }

    @keyframes santa-rita-sort-sheet-in {
      from {
        opacity: 1;
        transform: translate3d(0, 100%, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    .santa-rita-collection-nav__sort .santa-rita-sort-sheet__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 16px;
      border-bottom: 1px solid #e1cfb8;
    }

    .santa-rita-collection-nav__sort .santa-rita-sort-sheet__header h2 {
      margin: 0;
      color: #21000f;
      font-family: var(--font-heading--family);
      font-size: 20px;
      font-weight: 700;
      line-height: 1;
    }

    .santa-rita-collection-nav__sort .santa-rita-sort-sheet__close {
      width: 32px;
      height: 32px;
      border: 0;
      background: transparent;
      color: #6e5a61;
      font-size: 28px;
      font-weight: 300;
      line-height: 1;
      cursor: pointer;
    }

    .santa-rita-collection-nav__sort .sorting-filter__options-inner {
      gap: 0;
      padding: 12px 0 0;
    }

    .santa-rita-collection-nav__sort .sorting-filter__option {
      display: block;
      min-width: 0;
      max-width: none;
      padding: 8px 12px;
      border-radius: 3px;
      font-size: 14px;
      line-height: 1.2;
      width: 100%;
    }

    .santa-rita-collection-nav__sort .sorting-filter__option[aria-selected='true'] {
      background: #F6EDD9;
      font-weight: 400;
    }

    .santa-rita-collection-nav__sort .sorting-filter__option:hover,
    .santa-rita-collection-nav__sort .sorting-filter__option:focus {
      background: #f5ecd8;
      border-radius: 3px;
    }

    .santa-rita-collection-nav__sort .sorting-filter__checkmark {
      display: none;
    }

    .product-grid-container--santa-rita .facets-toggle {
      display: none;
    }

    .santa-rita-collection-banner {
      grid-column: var(--full-width);
      padding: 12px var(--page-margin) 26px;
    }

    .santa-rita-collection-banner__breadcrumbs {
      margin-bottom: 28px;
      font-size: 10px;
    }

    .santa-rita-collection-banner__layout {
      display: block;
    }

    .santa-rita-collection-banner__content h1 {
      margin-bottom: 12px;
      font-size: 34px;
      line-height: 1.02;
    }

    .santa-rita-collection-banner__content p {
      max-width: 320px;
      font-size: 16px;
      line-height: 1.12;
    }

    .santa-rita-collection-banner__picture,
    .santa-rita-collection-banner__placeholder {
      display: none;
    }

    .product-grid-container--santa-rita .santa-rita-product-card {
      min-height: 450px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "header",
      "content": "Banner de coleccion"
    },
    {
      "type": "checkbox",
      "id": "show_collection_banner",
      "label": "Mostrar banner de coleccion",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "collection_banner_image",
      "label": "Imagen /collections/all desktop"
    },
    {
      "type": "image_picker",
      "id": "collection_banner_mobile_image",
      "label": "Imagen /collections/all mobile"
    },
    {
      "type": "text",
      "id": "collection_banner_fallback_title",
      "label": "Titulo /collections/all",
      "info": "Las otras colecciones usan el titulo de la coleccion o el metafield custom.banner_title."
    },
    {
      "type": "textarea",
      "id": "collection_banner_fallback_subtitle",
      "label": "Subtitulo /collections/all",
      "info": "Las otras colecciones usan la descripcion de la coleccion o el metafield custom.banner_subtitle."
    },
    {
      "type": "checkbox",
      "id": "show_collection_breadcrumbs",
      "label": "Mostrar breadcrumb",
      "default": true
    },
    {
      "type": "text",
      "id": "collection_breadcrumb_label",
      "label": "Breadcrumb /collections/all",
      "default": "Productos"
    },
    {
      "type": "text",
      "id": "all_products_label",
      "label": "Texto boton todos los productos",
      "default": "Todos los productos"
    },
    {
      "type": "collection_list",
      "id": "collection_links",
      "label": "Colecciones para mostrar como filtros",
      "info": "Fallback global para /collections/all. Si una coleccion tiene el metafield custom.child_collections, se usara esa lista.",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Datos card producto"
    },
    {
      "type": "text",
      "id": "pack_label",
      "label": "Formato fallback",
      "default": "x12 un."
    },
    {
      "type": "text",
      "id": "unit_price_label",
      "label": "Precio por unidad fallback",
      "default": "$2.970"
    },
    {
      "type": "text",
      "id": "liter_price_label",
      "label": "Precio por litro fallback",
      "default": "$3.960"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Cantidad de resenas fallback",
      "default": "134"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
