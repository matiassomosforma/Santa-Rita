

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }

  if (!window.santaRitaCollectionFiltersReady) {
    window.santaRitaCollectionFiltersReady = true;

    const parsePrice = (value) => {
      const normalized = String(value || '').replace(/[^\d.,]/g, '');
      const hasDot = normalized.includes('.');
      const hasComma = normalized.includes(',');
      let wholeValue = normalized;

      if (hasDot && hasComma) {
        wholeValue = normalized.replace(/\./g, '').split(',')[0] || '';
      } else if (hasDot) {
        wholeValue = normalized.replace(/\./g, '');
      } else if (hasComma) {
        const [beforeComma = '', afterComma = ''] = normalized.split(',');
        wholeValue = afterComma.length === 3 ? `${beforeComma}${afterComma}` : beforeComma;
      }

      return Number(wholeValue || 0);
    };

    const formatPrice = (value) => String(Math.round(Number(value || 0))).replace(/\B(?=(\d{3})+(?!\d))/g, '.');

    const getPriceStateFromParams = (params) => {
      const minValue = parsePrice(params.get('filter.v.price.gte') || 0);
      const maxValue = parsePrice(params.get('filter.v.price.lte') || 0);

      return minValue || maxValue ? { minValue, maxValue } : null;
    };

    const getPriceStateFromURL = () => getPriceStateFromParams(new URLSearchParams(window.location.search));

    const isMobileViewport = () => window.matchMedia('(max-width: 749px)').matches;

    const getCurrentAbsoluteMax = () =>
      Number(
        document.querySelector('[data-sr-price-slider]')?.dataset.srPriceMax ||
          window.santaRitaPriceRangeState?.absoluteMax ||
          0
      );

    const setupSlider = (slider, force = false) => {
      if (!slider || (slider.dataset.srPriceReady === 'true' && !force)) return;
      const facet = slider.closest('price-facet-component');
      const rangeStatus = facet?.closest('details')?.querySelector('[data-range-max]');
      const minInput = facet?.querySelector('[ref="minInput"]');
      const maxInput = facet?.querySelector('[ref="maxInput"]');
      const minRange = slider.querySelector('[data-sr-price-range="min"]');
      const maxRange = slider.querySelector('[data-sr-price-range="max"]');

      if (!facet || !minInput || !maxInput || !minRange || !maxRange) return;

      const maxValue = Math.max(
        1,
        parsePrice(rangeStatus?.dataset.rangeMax || maxInput.dataset.max || maxInput.placeholder || maxInput.value || 100)
      );
      const urlState = getPriceStateFromURL();
      const savedState = window.santaRitaPriceRangeState;
      const hasSavedState = savedState && Number(savedState.absoluteMax) === maxValue;
      const minValue = hasSavedState ? Number(savedState.minValue) : parsePrice(urlState?.minValue || minInput.value || 0);
      const currentMax = hasSavedState
        ? Number(savedState.maxValue)
        : parsePrice(urlState?.maxValue || maxInput.value || maxInput.placeholder || maxValue);
      const resolvedMax = currentMax || maxValue;

      slider.dataset.srPriceReady = 'true';
      slider.dataset.srPriceMax = String(maxValue);
      minRange.max = String(maxValue);
      maxRange.max = String(maxValue);
      minRange.value = String(Math.min(minValue, maxValue));
      maxRange.value = String(Math.min(resolvedMax, maxValue));
      slider.style.setProperty('--sr-price-min', `${(Number(minRange.value) / maxValue) * 100}%`);
      slider.style.setProperty('--sr-price-max', `${(Number(maxRange.value) / maxValue) * 100}%`);
    };

    const applyFilterState = () => {
      document.querySelectorAll('[data-santa-rita-collection]').forEach((container) => {
        const shouldOpen = window.santaRitaCollectionFiltersOpen === true;
        const toggle = container.querySelector('[data-sr-filter-toggle]');

        container.classList.toggle('santa-rita-filters-open', shouldOpen);
        toggle?.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
        container.querySelectorAll('[data-sr-price-slider]').forEach((slider) => setupSlider(slider, true));
      });
    };

    const syncSlider = (range) => {
      const slider = range.closest('[data-sr-price-slider]');
      setupSlider(slider);

      const facet = range.closest('price-facet-component');
      const minInput = facet?.querySelector('[ref="minInput"]');
      const maxInput = facet?.querySelector('[ref="maxInput"]');
      const minRange = slider?.querySelector('[data-sr-price-range="min"]');
      const maxRange = slider?.querySelector('[data-sr-price-range="max"]');

      if (!slider || !minInput || !maxInput || !minRange || !maxRange) return;

      let minValue = Number(minRange.value);
      let maxValue = Number(maxRange.value);

      if (minValue > maxValue) {
        if (range === minRange) {
          maxValue = minValue;
          maxRange.value = String(maxValue);
        } else {
          minValue = maxValue;
          minRange.value = String(minValue);
        }
      }

      minInput.value = minValue > 0 ? formatPrice(minValue) : '';
      maxInput.value = maxValue < Number(slider.dataset.srPriceMax) ? formatPrice(maxValue) : '';

      const absoluteMax = Number(slider.dataset.srPriceMax || 1);
      slider.style.setProperty('--sr-price-min', `${(minValue / absoluteMax) * 100}%`);
      slider.style.setProperty('--sr-price-max', `${(maxValue / absoluteMax) * 100}%`);

      window.santaRitaPriceRangeState = {
        minValue,
        maxValue,
        absoluteMax,
      };
    };

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const toggle = target?.closest('[data-sr-filter-toggle]');

      if (!toggle) return;

      const container = toggle.closest('[data-santa-rita-collection]');

      if (isMobileViewport()) {
        const drawer = document.getElementById('filters-drawer');

        if (drawer?.showDialog) {
          drawer.showDialog();
          toggle.setAttribute('aria-expanded', 'true');

          window.requestAnimationFrame(() => {
            drawer.querySelectorAll('[data-sr-price-slider]').forEach((slider) => setupSlider(slider, true));
          });

          return;
        }
      }

      container?.classList.add('santa-rita-filters-transitioning');
      const isOpen = container?.classList.toggle('santa-rita-filters-open');

      window.santaRitaCollectionFiltersOpen = isOpen;
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

      container?.querySelectorAll('[data-sr-price-slider]').forEach((slider) => setupSlider(slider, true));

      window.setTimeout(() => {
        container?.classList.remove('santa-rita-filters-transitioning');
      }, 360);
    });

    document.addEventListener('input', (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const range = target?.closest('[data-sr-price-range]');

      if (!range) return;

      syncSlider(range);
    });

    document.addEventListener('filter:update', (event) => {
      const openContainer = document.querySelector('[data-santa-rita-collection].santa-rita-filters-open');
      const queryParams = event?.detail?.queryParams;
      const priceState = queryParams instanceof URLSearchParams ? getPriceStateFromParams(queryParams) : getPriceStateFromURL();
      const absoluteMax = getCurrentAbsoluteMax();

      window.santaRitaCollectionFiltersOpen = openContainer != null;

      if (priceState && absoluteMax > 0) {
        window.santaRitaPriceRangeState = {
          minValue: Number(priceState.minValue || 0),
          maxValue: Number(priceState.maxValue || 0),
          absoluteMax,
        };
      } else if (!priceState) {
        window.santaRitaPriceRangeState = null;
      }
    });

    document.addEventListener(
      'change',
      (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const range = target?.closest('[data-sr-price-range]');

        if (!range) return;

        event.stopPropagation();
        syncSlider(range);

        const facet = range.closest('price-facet-component');
        const minInput = facet?.querySelector('[ref="minInput"]');

        minInput?.dispatchEvent(new Event('change', { bubbles: true }));
      },
      true
    );

    document.addEventListener('DOMContentLoaded', () => {
      applyFilterState();

      document.getElementById('filters-drawer')?.addEventListener('dialog:close', () => {
        document.querySelectorAll('[data-sr-filter-toggle]').forEach((toggle) => {
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    });

    new MutationObserver(() => {
      window.requestAnimationFrame(applyFilterState);
    }).observe(document.body, { childList: true, subtree: true });

    const getNormalizedSectionId = (sectionId) => sectionId?.replace(/^shopify-section-/, '');

    const setLoadMoreState = (button, state) => {
      button.dataset.currentPage = String(state.currentPage);
      button.dataset.mode = state.currentPage >= state.lastPage ? 'collapse' : 'load';
      button.textContent = state.currentPage >= state.lastPage ? 'Mostrar menos' : 'Cargar más';
      button.disabled = false;
    };

    document.addEventListener('click', async (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const button = target?.closest('[data-sr-load-more]');

      if (!(button instanceof HTMLButtonElement)) return;

      const container = button.closest('[data-santa-rita-collection]');
      const grid = container?.querySelector('[ref="grid"]');

      if (!container || !grid) return;

      if (button.dataset.mode === 'collapse') {
        grid.querySelectorAll('[ref="cards[]"]').forEach((card) => {
          if (card instanceof HTMLElement && card.dataset.page !== '1') {
            card.remove();
          }
        });

        const url = new URL(window.location.href);
        url.searchParams.delete('page');
        history.pushState('', '', url.toString());

        setLoadMoreState(button, {
          currentPage: 1,
          lastPage: Number(button.dataset.lastPage || 1),
        });

        grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }

      const currentPage = Number(button.dataset.currentPage || 1);
      const lastPage = Number(button.dataset.lastPage || 1);
      const nextPage = currentPage + 1;

      if (nextPage > lastPage) {
        setLoadMoreState(button, { currentPage: lastPage, lastPage });
        return;
      }

      button.disabled = true;
      button.textContent = 'Cargando...';

      try {
        const url = new URL(window.location.href);
        url.searchParams.set('page', String(nextPage));
        url.searchParams.set('section_id', getNormalizedSectionId(container.getAttribute('section-id')));
        url.hash = '';

        const response = await fetch(url.toString());
        const sectionHTML = await response.text();
        const parsedSection = new DOMParser().parseFromString(sectionHTML, 'text/html');
        const nextGrid = parsedSection.querySelector('[ref="grid"]');
        const nextCards = nextGrid?.querySelectorAll(':scope > [ref="cards[]"]');

        if (!nextCards || nextCards.length === 0) {
          setLoadMoreState(button, { currentPage: lastPage, lastPage });
          return;
        }

        grid.append(...nextCards);

        setLoadMoreState(button, { currentPage: nextPage, lastPage });
      } catch (error) {
        button.disabled = false;
        button.textContent = 'Cargar más';
      }
    });
  }
{% endjavascript %}

{% liquid
  assign show_collection_banner = false

  if section.settings.show_collection_banner
    assign show_collection_banner = true
  endif

  assign is_all_collection = false

  if collection.handle == 'all' or request.path contains '/collections/all'
    assign is_all_collection = true
  endif

  assign collection_banner_title = collection.metafields.custom.banner_title.value | default: collection.title
  assign collection_banner_subtitle = collection.metafields.custom.banner_subtitle.value | default: collection.description | strip_html
  assign collection_banner_image = collection.metafields.custom.banner_image.value | default: collection.image
  assign collection_banner_mobile_image = collection.metafields.custom.banner_mobile_image.value | default: collection_banner_image
  assign collection_breadcrumb_label = collection.metafields.custom.breadcrumb_label.value | default: collection.title
  assign child_collection_links = collection.metafields.custom.child_collections.value

  if is_all_collection
    assign collection_banner_title = section.settings.collection_banner_fallback_title | default: 'Productos'
    assign collection_banner_subtitle = section.settings.collection_banner_fallback_subtitle
    assign collection_banner_image = section.settings.collection_banner_image
    assign collection_banner_mobile_image = section.settings.collection_banner_mobile_image | default: collection_banner_image
    assign collection_breadcrumb_label = section.settings.collection_breadcrumb_label | default: 'Productos'
  endif

  if child_collection_links != blank
    assign collection_nav_links = child_collection_links
  else
    assign collection_nav_links = section.settings.collection_links
  endif

  assign sort_by = collection.sort_by | default: collection.default_sort_by
%}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}{% if show_collection_banner %} product-grid-container--santa-rita{% endif %}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
  data-santa-rita-collection
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}{% if show_collection_banner %} collection-wrapper--santa-rita{% endif %}"
  >
    {% if show_collection_banner %}
      <section
        class="santa-rita-collection-banner"
        aria-labelledby="santa-rita-collection-banner-title-{{ section.id }}"
      >
        {% if section.settings.show_collection_breadcrumbs %}
          <nav class="santa-rita-collection-banner__breadcrumbs" aria-label="Breadcrumb">
            <a href="{{ routes.root_url }}">Inicio</a>
            <span aria-hidden="true">&gt;</span>
            <span>{{ collection_breadcrumb_label }}</span>
          </nav>
        {% endif %}

        <div class="santa-rita-collection-banner__layout">
          <div class="santa-rita-collection-banner__content">
            {% if collection_banner_title != blank %}
              <h1 id="santa-rita-collection-banner-title-{{ section.id }}">
                {{ collection_banner_title }}
              </h1>
            {% endif %}

            {% if collection_banner_subtitle != blank %}
              <p>{{ collection_banner_subtitle }}</p>
            {% endif %}
          </div>

          {% if collection_banner_image != blank %}
            <picture class="santa-rita-collection-banner__picture">
              {% if collection_banner_mobile_image != blank %}
                <source
                  media="(max-width: 749px)"
                  srcset="
                    {{ collection_banner_mobile_image | image_url: width: 375 }} 375w,
                    {{ collection_banner_mobile_image | image_url: width: 550 }} 550w,
                    {{ collection_banner_mobile_image | image_url: width: 750 }} 750w
                  "
                  sizes="100vw"
                >
              {% endif %}
              {{
                collection_banner_image
                | image_url: width: 1400
                | image_tag:
                  widths: '375, 550, 750, 990, 1200, 1400',
                  sizes: '(min-width: 990px) 52vw, 100vw',
                  loading: 'eager',
                  class: 'santa-rita-collection-banner__image'
              }}
            </picture>
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'santa-rita-collection-banner__placeholder' }}
          {% endif %}
        </div>
      </section>
    {% endif %}

    {% if show_collection_banner %}
      <nav class="santa-rita-collection-nav" aria-label="Colecciones y filtros">
        <button
          type="button"
          class="santa-rita-collection-nav__filter"
          data-sr-filter-toggle
          aria-expanded="false"
          aria-controls="FacetFiltersForm--{{ section.id }}-desktop"
        >
          <span class="svg-wrapper" aria-hidden="true">
            {{ 'icon-filter.svg' | inline_asset_content }}
          </span>
          Filtrar
        </button>

        <div class="santa-rita-collection-nav__divider" aria-hidden="true"></div>

        <div class="santa-rita-collection-nav__sort">
          {% assign mobile_sort_section_id = section.id | append: '-santa-rita-mobile' %}
          {% render 'sorting',
            results: collection,
            sort_by: sort_by,
            filter_style: 'horizontal',
            suffix: 'desktop',
            sort_position: 'santa-rita-mobile',
            should_use_select_on_mobile: false,
            section_id: mobile_sort_section_id,
            form_section_id: section.id
          %}
        </div>

        <div class="santa-rita-collection-nav__links">
          <a
            href="{{ collection.url }}"
            class="santa-rita-collection-nav__link is-active"
            aria-current="page"
          >
            {{ section.settings.all_products_label }}
          </a>

          {% for nav_collection in collection_nav_links %}
            {% unless nav_collection.handle == collection.handle %}
              <a
                href="{{ nav_collection.url }}"
                class="santa-rita-collection-nav__link"
              >
                {{ nav_collection.title }}
              </a>
            {% endunless %}
          {% endfor %}
        </div>
      </nav>
    {% endif %}

    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% assign products_per_page = 24 %}
    {% assign collection_enable_infinite_scroll = section.settings.enable_infinite_scroll %}

    {% if show_collection_banner %}
      {% assign products_per_page = 12 %}
      {% assign collection_enable_infinite_scroll = false %}
    {% elsif section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% for product in collection.products %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            ref="cards[]"
          >
            {% render 'santa-rita-best-seller-card',
              product: product,
              section_settings: section.settings
            %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: collection_enable_infinite_scroll
      %}

      {% if show_collection_banner and paginate.pages > 1 %}
        <div class="santa-rita-collection-load-more">
          <button
            type="button"
            class="santa-rita-collection-load-more__button"
            data-sr-load-more
            data-current-page="{{ paginate.current_page }}"
            data-last-page="{{ paginate.pages }}"
            data-mode="{% if paginate.current_page >= paginate.pages %}collapse{% else %}load{% endif %}"
          >
            {% if paginate.current_page >= paginate.pages %}
              Mostrar menos
            {% else %}
              Cargar más
            {% endif %}
          </button>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</results-list>

{% stylesheet %}
  .product-grid-container--santa-rita {
    background: #fffbf6;
  }

  .collection-wrapper--santa-rita {
    row-gap: 0;
  }

  .santa-rita-collection-nav {
    grid-column: var(--centered);
    display: flex;
    align-items: center;
    gap: 28px;
    padding-block: 24px;
    border-top: 1px solid rgba(140, 26, 62, 0.12);
    border-bottom: 1px solid rgba(140, 26, 62, 0.12);
    color: #21000f;
  }

  .santa-rita-collection-nav__filter,
  .santa-rita-collection-nav__link {
    display: inline-flex;
    min-height: 36px;
    align-items: center;
    justify-content: center;
    border: 1px solid #21000f;
    border-radius: 999px;
    background: #fffbf6;
    color: #21000f;
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .santa-rita-collection-nav__filter {
    gap: 8px;
    padding-inline: 22px;
    cursor: pointer;
  }

  .santa-rita-collection-nav__filter .svg-wrapper {
    width: 14px;
    height: 14px;
  }

  .santa-rita-collection-nav__link {
    padding-inline: 24px;
  }

  .santa-rita-collection-nav__filter[aria-expanded='true'],
  .santa-rita-collection-nav__link.is-active {
    border-color: #21000f;
    background: #21000f;
    color: #ffffff;
  }

  .santa-rita-collection-nav__divider {
    width: 1px;
    height: 24px;
    background: rgba(140, 26, 62, 0.16);
  }

  .santa-rita-collection-nav__links {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .santa-rita-collection-nav__links::-webkit-scrollbar {
    display: none;
  }

  .santa-rita-collection-nav__sort {
    display: none;
  }

  .santa-rita-collection-banner {
    grid-column: var(--centered);
    width: 100%;
    padding-block: 22px 28px;
    color: #21000f;
  }

  .santa-rita-collection-banner__breadcrumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 20px;
    font-size: 11px;
    line-height: 1.2;
  }

  .santa-rita-collection-banner__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-collection-banner__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 610px);
    gap: clamp(28px, 6vw, 74px);
    align-items: center;
  }

  .santa-rita-collection-banner__content h1 {
    margin: 0 0 18px;
    font-family: var(--font-heading--family);
    font-size: clamp(34px, 4vw, 50px);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: 0;
  }

  .santa-rita-collection-banner__content p {
    max-width: 420px;
    margin: 0;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.3;
  }

  .santa-rita-collection-banner__picture,
  .santa-rita-collection-banner__placeholder {
    display: block;
    aspect-ratio: 2.28 / 1;
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
    background: #f5eadc;
  }

  .santa-rita-collection-banner__image,
  .santa-rita-collection-banner__placeholder {
    width: 100%;
    height: 100%;
  }

  .santa-rita-collection-banner__image {
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .product-grid-container--santa-rita .product-grid {
    align-items: stretch;
    transition: opacity 0.22s ease, transform 0.28s ease;
  }

  .product-grid-container--santa-rita:not(.santa-rita-filters-open) .facets-block-wrapper--vertical:not(#filters-drawer) {
    max-height: 0;
    margin: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateX(-10px);
    visibility: hidden;
  }

  .product-grid-container--santa-rita:not(.santa-rita-filters-open) .main-collection-grid {
    grid-column: var(--centered) !important;
  }

  .product-grid-container--santa-rita .facets-block-wrapper--vertical:not(#filters-drawer) {
    transition: opacity 0.26s ease, transform 0.3s ease, max-height 0.3s ease, padding-top 0.3s ease;
  }

  .product-grid-container--santa-rita.santa-rita-filters-open .facets-block-wrapper--vertical:not(#filters-drawer) {
    max-height: 900px;
    padding-top: 18px;
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
    visibility: visible;
  }

  .product-grid-container--santa-rita.santa-rita-filters-transitioning .product-grid {
    opacity: 0.92;
    transform: translateY(4px);
  }

  .product-grid-container--santa-rita .facets.facets-controls-wrapper {
