{% liquid
  assign selected_products = section.settings.products
  assign product_limit = section.settings.max_products
%}

<santa-rita-page-not-found
  class="santa-rita-404"
  {% if section.settings.autoplay %}
    autoplay
    autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  {% endif %}
  {% if section.settings.infinite_loop %}
    infinite-loop
  {% endif %}
  {{ section.shopify_attributes }}
>
  <section class="santa-rita-404__hero" aria-labelledby="santa-rita-404-title">
    {% if section.settings.banner_image != blank %}
      {{
        section.settings.banner_image
        | image_url: width: 2200
        | image_tag:
          widths: '375, 550, 750, 990, 1440, 1800, 2200',
          sizes: '100vw',
          loading: 'eager',
          class: 'santa-rita-404__hero-image'
      }}
    {% endif %}

    <div class="santa-rita-404__hero-overlay"></div>

    <div class="santa-rita-404__hero-content">
      <h1 id="santa-rita-404-title">{{ section.settings.hero_heading }}</h1>
      <p>{{ section.settings.hero_text }}</p>

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a class="santa-rita-404__hero-button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </section>

  <section class="santa-rita-404__products" aria-labelledby="santa-rita-404-products-title">
    <div class="santa-rita-404__products-inner">
      <header class="santa-rita-404__products-header">
        <h2 id="santa-rita-404-products-title">{{ section.settings.products_heading }}</h2>
        <p>{{ section.settings.products_text }}</p>
      </header>

      <div class="santa-rita-404__viewport" data-sr-404-viewport>
        <div class="santa-rita-404__track" data-sr-404-track>
          {% if selected_products != blank %}
            {% for product in selected_products limit: product_limit %}
              {% render 'santa-rita-best-seller-card',
                product: product,
                section_settings: section.settings
              %}
            {% endfor %}
          {% elsif section.settings.collection != blank %}
            {% for product in section.settings.collection.products limit: product_limit %}
              {% render 'santa-rita-best-seller-card',
                product: product,
                section_settings: section.settings
              %}
            {% endfor %}
          {% elsif request.design_mode %}
            <div class="santa-rita-404__empty">
              Selecciona productos o una coleccion para mostrarlos en la pagina 404.
            </div>
          {% endif %}
        </div>
      </div>

      <div class="santa-rita-404__footer">
        <div class="santa-rita-404__dots" data-sr-404-dots aria-label="Paginacion de productos"></div>
        <div class="santa-rita-404__arrows">
          <button type="button" data-sr-404-prev aria-label="Productos anteriores">
            <span aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="33" height="20" viewBox="0 0 33 20" fill="none">
                <path d="M11 0C11 1.06 9.99212 2.64286 8.97187 3.97143C7.66012 5.68571 6.09263 7.18143 4.2955 8.32286C2.948 9.17857 1.3145 10 0 10M0 10C1.3145 10 2.94938 10.8214 4.2955 11.6771C6.09263 12.82 7.66012 14.3157 8.97187 16.0271C9.99212 17.3571 11 18.9429 11 20M0 10H33" stroke="#8C1A3E"/>
              </svg>
            </span>
          </button>
          <button type="button" data-sr-404-next aria-label="Productos siguientes">
            <span aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="33" height="20" viewBox="0 0 33 20" fill="none">
                <path d="M22 0C22 1.06 23.0079 2.64286 24.0281 3.97143C25.3399 5.68571 26.9074 7.18143 28.7045 8.32286C30.052 9.17857 31.6855 10 33 10M33 10C31.6855 10 30.0506 10.8214 28.7045 11.6771C26.9074 12.82 25.3399 14.3157 24.0281 16.0271C23.0079 17.3571 22 18.9429 22 20M33 10H0" stroke="#8C1A3E"/>
              </svg>
            </span>
          </button>
        </div>
      </div>
    </div>
  </section>
</santa-rita-page-not-found>

<script>
  if (!customElements.get('santa-rita-page-not-found')) {
    customElements.define(
      'santa-rita-page-not-found',
      class SantaRitaPageNotFound extends HTMLElement {
        connectedCallback() {
          this.viewport = this.querySelector('[data-sr-404-viewport]');
          this.track = this.querySelector('[data-sr-404-track]');
          this.prevButton = this.querySelector('[data-sr-404-prev]');
          this.nextButton = this.querySelector('[data-sr-404-next]');
          this.dotsContainer = this.querySelector('[data-sr-404-dots]');
          this.footer = this.querySelector('.santa-rita-404__footer');
          this.autoplayTimer = null;
          this.handleResize = () => this.setupDots();

          if (!this.viewport || !this.track) return;

          this.prevButton?.addEventListener('click', () => this.scrollByPage(-1, true));
          this.nextButton?.addEventListener('click', () => this.scrollByPage(1, true));
          this.viewport.addEventListener('scroll', () => this.updateState(), { passive: true });
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
          this.addEventListener('focusin', () => this.stopAutoplay());
          this.addEventListener('focusout', () => this.startAutoplay());
          window.addEventListener('resize', this.handleResize);

          this.setupDots();
          this.startAutoplay();
        }

        disconnectedCallback() {
          window.removeEventListener('resize', this.handleResize);
          this.stopAutoplay();
        }

        getStep() {
          const card = this.track.querySelector('.santa-rita-product-card');
          if (!card) return this.viewport.clientWidth;
          const gap = parseFloat(window.getComputedStyle(this.track).columnGap || '0');
          return card.getBoundingClientRect().width + gap;
        }

        getPageCount() {
          const total = this.track.querySelectorAll('.santa-rita-product-card').length;
          const visible = Math.max(1, Math.round(this.viewport.clientWidth / this.getStep()));
          return Math.max(1, total - visible + 1);
        }

        getMaxScroll() {
          return Math.max(0, this.viewport.scrollWidth - this.viewport.clientWidth);
        }

        hasOverflow() {
          return this.getMaxScroll() > 4;
        }

        setupDots() {
          if (!this.dotsContainer) return;
          this.dotsContainer.innerHTML = '';

          const hasOverflow = this.hasOverflow();
          if (this.footer) this.footer.hidden = !hasOverflow;

          if (!hasOverflow) {
            this.stopAutoplay();
            this.viewport.scrollTo({ left: 0 });
            this.updateState();
            return;
          }

          const count = this.getPageCount();

          for (let index = 0; index < count; index += 1) {
            const button = document.createElement('button');
            button.type = 'button';
            button.setAttribute('aria-label', `Ir al grupo ${index + 1}`);
            button.addEventListener('click', () => this.scrollToIndex(index, true));
            this.dotsContainer.append(button);
          }

          this.updateState();
          this.startAutoplay();
        }

        scrollToIndex(index, userAction = false) {
          if (!this.hasOverflow()) return;
          if (userAction) this.restartAutoplay();
          this.viewport.scrollTo({ left: index * this.getStep(), behavior: 'smooth' });
        }

        scrollByPage(direction, userAction = false) {
          if (!this.hasOverflow()) return;
          if (userAction) this.restartAutoplay();

          const maxScroll = this.getMaxScroll();
          const nextLeft = this.viewport.scrollLeft + direction * this.getStep();

          if (this.hasAttribute('infinite-loop')) {
            if (nextLeft > maxScroll - 4) {
              this.viewport.scrollTo({ left: 0, behavior: 'smooth' });
              return;
            }

            if (nextLeft < 0) {
              this.viewport.scrollTo({ left: maxScroll, behavior: 'smooth' });
              return;
            }
          }

          this.viewport.scrollBy({ left: direction * this.getStep(), behavior: 'smooth' });
        }

        updateState() {
          const step = this.getStep();
          const activeIndex = Math.round(this.viewport.scrollLeft / step);
          const maxScroll = this.getMaxScroll();
          const infinite = this.hasAttribute('infinite-loop');
          const hasOverflow = this.hasOverflow();

          if (this.footer) this.footer.hidden = !hasOverflow;

          Array.from(this.dotsContainer?.children || []).forEach((dot, index) => {
            const isActive = index === activeIndex;
            dot.classList.toggle('is-active', isActive);
            dot.setAttribute('aria-current', isActive ? 'true' : 'false');
          });

          if (this.prevButton) this.prevButton.disabled = !infinite && this.viewport.scrollLeft <= 4;
          if (this.nextButton) this.nextButton.disabled = !infinite && this.viewport.scrollLeft >= maxScroll - 4;
        }

        startAutoplay() {
          if (!this.hasAttribute('autoplay') || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          if (!this.hasOverflow()) return;
          this.stopAutoplay();

          const speed = Number(this.getAttribute('autoplay-speed') || 5000);
          this.autoplayTimer = window.setInterval(() => {
            this.scrollByPage(1);
          }, speed);
        }

        stopAutoplay() {
          if (!this.autoplayTimer) return;
          window.clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }

        restartAutoplay() {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }
    );
  }
</script>

<style>
  .santa-rita-404 {
    display: block;
    background: #fffbf6;
    color: #21000f;
  }

  .santa-rita-404__hero {
    position: relative;
    display: grid;
    min-height: 400px;
    overflow: hidden;
    place-items: center start;
    background: #09090b;
  }

  .santa-rita-404__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .santa-rita-404__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.44) 34%, rgba(0, 0, 0, 0.06) 74%);
  }

  .santa-rita-404__hero-content {
    position: relative;
    z-index: 1;
    width: min(100% - 48px, 1220px);
    margin-inline: auto;
    color: #ffffff;
  }

  .santa-rita-404__hero-content h1 {
    max-width: 560px;
    margin: 0 0 18px;
    font-family: var(--font-heading--family);
    font-size: clamp(34px, 4vw, 54px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: 0;
  }

  .santa-rita-404__hero-content p {
    max-width: 470px;
    margin: 0 0 18px;
    font-size: 17px;
    line-height: 1.4;
  }

  .santa-rita-404__hero-button {
    display: inline-flex;
    min-width: 84px;
    min-height: 28px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.82);
    border-radius: 7px;
    color: #ffffff;
    font-size: 12px;
    line-height: 1;
    padding: 7px 18px;
    text-decoration: none;
  }

  .santa-rita-404__products {
    background: #fffbf6;
  }

  .santa-rita-404__products-inner {
    width: 100%;
    max-width: 1220px;
    margin-inline: auto;
    padding: 52px 24px 68px;
  }

  .santa-rita-404__products-header {
    margin-bottom: 32px;
  }

  .santa-rita-404__products-header h2 {
    margin: 0 0 10px;
    color: #21000f;
    font-family: var(--font-heading--family);
    font-size: clamp(25px, 2.8vw, 34px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .santa-rita-404__products-header p {
    margin: 0;
    color: #21000f;
    font-size: 15px;
    line-height: 1.35;
  }

  .santa-rita-404__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    padding-block: 15px;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .santa-rita-404__viewport::-webkit-scrollbar {
    display: none;
  }

  .santa-rita-404__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 60px) / 4);
    gap: 20px;
    align-items: stretch;
  }

  .santa-rita-404 .santa-rita-product-card {
    position: relative;
    display: flex;
    min-height: 455px;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid #ffffff;
    border-radius: 12px;
    background: #ffffff;
    box-shadow: 0 0 2px 0 rgba(140, 26, 62, 0.13) inset, 0 10px 10px 0 rgba(140, 26, 62, 0.05);
    scroll-snap-align: start;
    transition: box-shadow 0.3s ease;
  }

  .santa-rita-404 .santa-rita-product-card:hover {
    box-shadow: 0 0 2px 0 rgb(140 26 62 / 41%) inset, 0 10px 10px 0 rgb(140 26 62 / 19%);
  }

  .santa-rita-404 .santa-rita-product-card__badges {
    position: absolute;
    inset: 14px 14px auto;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .santa-rita-404 .santa-rita-product-card__badge {
    display: inline-flex;
    min-width: 48px;
    min-height: 20px;
    align-items: center;
    justify-content: center;
    border: 1px solid #aea2a6;
    border-radius: 12px;
    background: #f5f4ed;
    color: #21000f;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    padding: 0 10px;
  }

  .santa-rita-404 .santa-rita-product-card__badge--discount {
    border-color: #9b173f;
    background: #9b173f;
    color: #ffffff;
  }

  .santa-rita-404 .santa-rita-product-card__badge--blank {
    opacity: 0;
  }

  .santa-rita-404 .santa-rita__product-image {
    position: relative;
  }

  .santa-rita-404 .santa-rita-product-card__media {
    position: relative;
    display: grid;
    min-height: 170px;
    place-items: end center;
    margin-bottom: 25px;
    padding-top: 30px;
    text-decoration: none;
  }

  .santa-rita-404 .santa-rita-product-card__image {
    width: auto;
    max-width: 78%;
    height: 166px;
    object-fit: contain;
  }

  .santa-rita-404 .santa-rita-product-card__rating {
    position: absolute;
    right: 0;
    bottom: 0;
    display: flex;
    min-height: 24px;
    align-items: flex-end;
    flex-direction: column;
    gap: 5px;
    padding-inline: 16px;
    color: #c98d00;
    font-size: 12px;
    line-height: 1;
  }

  .santa-rita-404 .santa-rita__star-group {
    display: flex;
    gap: 2px;
  }

  .santa-rita-404 .santa-rita-product-card__rating small {
    color: #6e5a61;
    font-size: 10px;
  }

  .santa-rita-404 .santa-rita-product-card__eyebrow,
  .santa-rita-404 .santa-rita-product-card__origin {
    margin: 0;
    padding-inline: 16px;
    color: #8d183f;
    font-size: 11px;
    line-height: 1.25;
  }

  .santa-rita-404 .santa-rita-product-card h3 {
    margin: 7px 0 4px;
    padding-inline: 16px;
    color: #2b1e1e;
    font-family: var(--font-heading--family);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.08;
  }

  .santa-rita-404 .santa-rita-product-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-404 .santa-rita-product-card__origin {
    margin-top: 3px;
    color: #6b5d5d;
  }

  .santa-rita-404 .santa-rita-product-card__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 14px;
    padding-inline: 16px;
  }

  .santa-rita-404 .santa-rita-product-card__price strong {
    color: #1e0812;
    font-size: 18px;
    line-height: 1;
  }

  .santa-rita-404 .santa-rita-product-card__price s {
    color: #6e6262;
    font-size: 12px;
  }

  .santa-rita-404 .santa-rita-product-card__details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin: 12px 16px;
    padding-top: 12px;
    border-top: 0.5px solid rgba(110, 90, 97, 0.5);
  }

  .santa-rita-404 .santa-rita-product-card__details span {
    display: flex;
    min-height: 48px;
    flex-direction: column;
    justify-content: center;
    border-radius: 3px;
    background: #eee8e2;
    color: #655b58;
    font-size: 11px;
    line-height: 1.1;
    padding: 8px 10px;
  }

  .santa-rita-404 .santa-rita-product-card__details strong {
    margin-top: 4px;
    color: #21000f;
    font-size: 12px;
  }

  .santa-rita-404 .santa-rita-product-card__form {
    margin: auto 0 0;
  }

  .santa-rita-404 .santa-rita-product-card__button {
    width: calc(100% - 32px);
    min-height: 40px;
    margin: 0 16px 16px;
    border: 1px solid #8c1a3e;
    border-radius: 7px;
    background: #8c1a3e;
    color: #ffffff;
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
  }

  .santa-rita-404__empty {
    grid-column: 1 / -1;
    padding: 28px;
    border: 1px dashed #d9c9bf;
    border-radius: 8px;
    background: #ffffff;
    color: #6b5d5d;
  }

  .santa-rita-404__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 26px;
    margin-top: 24px;
  }

  .santa-rita-404__footer[hidden] {
    display: none;
  }

  .santa-rita-404__dots,
  .santa-rita-404__arrows {
    display: flex;
    align-items: center;
  }

  .santa-rita-404__dots {
    gap: 6px;
  }

  .santa-rita-404__dots button {
    width: 8px;
    height: 8px;
    border: 1px solid #8c1a3e;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    padding: 0;
  }

  .santa-rita-404__dots button.is-active {
    background: #8c1a3e;
  }

  .santa-rita-404__arrows {
    gap: 14px;
  }

  .santa-rita-404__arrows button {
    display: grid;
    width: 52px;
    height: 52px;
    place-items: center;
    border: 1px solid #8c1a3e;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
  }

  .santa-rita-404__arrows button:disabled {
    opacity: 0.35;
    cursor: default;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-404__track {
      grid-auto-columns: calc((100% - 20px) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-404__hero {
      min-height: 430px;
      place-items: end start;
    }

    .santa-rita-404__hero-image {
      object-position: center;
    }

    .santa-rita-404__hero-overlay {
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.08) 0%, rgba(0, 0, 0, 0.25) 42%, rgba(0, 0, 0, 0.68) 100%);
    }

    .santa-rita-404__hero-content {
      width: calc(100% - 32px);
      padding-bottom: 34px;
    }

    .santa-rita-404__hero-content h1 {
      max-width: 270px;
      margin-bottom: 10px;
      font-size: 32px;
      line-height: 0.94;
    }

    .santa-rita-404__hero-content p {
      max-width: 260px;
      margin-bottom: 12px;
      font-size: 12px;
      line-height: 1.25;
    }

    .santa-rita-404__hero-button {
      min-width: 75px;
      min-height: 26px;
      font-size: 11px;
      padding-inline: 14px;
    }

    .santa-rita-404__products-inner {
      padding: 38px 20px 52px;
    }

    .santa-rita-404__products-header {
      margin-bottom: 18px;
    }

    .santa-rita-404__products-header h2 {
      max-width: 310px;
      margin-bottom: 8px;
      font-size: 24px;
      line-height: 1.03;
    }

    .santa-rita-404__products-header p {
      font-size: 13px;
    }

    .santa-rita-404__track {
      grid-auto-columns: min(82vw, 260px);
      gap: 14px;
    }

    .santa-rita-404__footer {
      justify-content: space-between;
      margin-top: 10px;
    }

    .santa-rita-404__arrows {
      order: -1;
    }

    .santa-rita-404__arrows button {
      width: 34px;
      height: 34px;
    }

    .santa-rita-404__arrows svg {
      width: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "SR pagina 404",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Imagen banner"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Titulo banner",
      "default": "Pagina no encontrada"
    },
    {
      "type": "text",
      "id": "hero_text",
      "label": "Texto banner",
      "default": "Descubre las ofertas de Santa Rita Online."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto boton",
      "default": "Ver mas"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link boton"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Titulo productos",
      "default": "No encontraste lo que estas buscando?"
    },
    {
      "type": "text",
      "id": "products_text",
      "label": "Texto productos",
      "default": "Conoce nuestros productos destacados."
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Productos",
      "limit": 12
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleccion fallback"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Cantidad maxima",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
