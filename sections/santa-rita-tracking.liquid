{% liquid
  assign tracking_base_url = section.settings.tracking_base_url | default: 'https://livetracking.simpliroute.com/widget/account/13343/tracking/'
  assign modal_example_code = section.settings.modal_example_code | default: '172030587;358739'
  assign intro_text = section.settings.text | strip_html | strip
  assign notice_text = section.settings.notice_text | strip_html | strip
  assign modal_text = section.settings.modal_text | strip_html | strip
  assign modal_footer_text = section.settings.modal_footer_text | strip_html | strip
%}

<santa-rita-order-tracking
  class="santa-rita-order-tracking"
  data-base-url="{{ tracking_base_url | escape }}"
  data-open-new-window="{{ section.settings.open_new_window }}"
  data-empty-message="{{ section.settings.empty_message | escape }}"
  data-section-id="{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="santa-rita-order-tracking__inner">
    {% if section.settings.heading != blank %}
      <h2 class="santa-rita-order-tracking__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if intro_text != blank %}
      <div class="santa-rita-order-tracking__text">
        {{ section.settings.text }}
      </div>
    {% endif %}

    <form class="santa-rita-order-tracking__form" data-tracking-form>
      <div class="santa-rita-order-tracking__field">
        <label class="visually-hidden" for="tracking-code-{{ section.id }}">
          {{ section.settings.input_label }}
        </label>
        <input
          id="tracking-code-{{ section.id }}"
          type="text"
          inputmode="text"
          autocomplete="off"
          placeholder="{{ section.settings.input_placeholder | escape }}"
          aria-describedby="tracking-helper-{{ section.id }} tracking-error-{{ section.id }}"
          data-tracking-input
        >
        <p id="tracking-helper-{{ section.id }}" class="santa-rita-order-tracking__helper">
          {{ section.settings.input_helper }}
        </p>
        <p id="tracking-error-{{ section.id }}" class="santa-rita-order-tracking__error" data-tracking-error hidden></p>
      </div>

      <button type="submit" class="santa-rita-order-tracking__submit">
        {{ section.settings.button_label }}
      </button>
    </form>

    {% if section.settings.question_title != blank
      or section.settings.question_prefix != blank
      or section.settings.modal_trigger_label != blank
      or section.settings.question_suffix != blank
    %}
      <div class="santa-rita-order-tracking__question">
        {% if section.settings.question_title != blank %}
          <h3>{{ section.settings.question_title }}</h3>
        {% endif %}

        {% if section.settings.question_prefix != blank
          or section.settings.modal_trigger_label != blank
          or section.settings.question_suffix != blank
        %}
          <p>
            {% if section.settings.question_prefix != blank %}
              <span>{{ section.settings.question_prefix }}</span>
            {% endif %}
            {% if section.settings.modal_trigger_label != blank %}
              <button type="button" class="santa-rita-order-tracking__modal-trigger" data-modal-open>
                {{ section.settings.modal_trigger_label }}
              </button><span>{{ section.settings.question_suffix }}</span>
            {% elsif section.settings.question_suffix != blank %}
              <span>{{ section.settings.question_suffix }}</span>
            {% endif %}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% if notice_text != blank %}
      <div class="santa-rita-order-tracking__notice">
        {% if section.settings.show_notice_icon %}
          <span class="santa-rita-order-tracking__notice-icon" aria-hidden="true">i</span>
        {% endif %}
        <div class="santa-rita-order-tracking__notice-text">
          {{ section.settings.notice_text }}
        </div>
      </div>
    {% endif %}
  </div>

  <div class="santa-rita-order-tracking__modal" data-modal hidden>
    <div class="santa-rita-order-tracking__backdrop" data-modal-close></div>
    <div
      class="santa-rita-order-tracking__dialog"
      role="dialog"
      tabindex="-1"
      aria-modal="true"
      aria-labelledby="tracking-modal-title-{{ section.id }}"
    >
      <button type="button" class="santa-rita-order-tracking__close" aria-label="{{ section.settings.close_label | escape }}" data-modal-close>
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M5 5l14 14M19 5 5 19" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>

      {% if section.settings.modal_title != blank %}
        <h2 id="tracking-modal-title-{{ section.id }}">{{ section.settings.modal_title }}</h2>
      {% endif %}

      {% if modal_text != blank %}
        <div class="santa-rita-order-tracking__modal-text">
          {{ section.settings.modal_text }}
        </div>
      {% endif %}

      <div class="santa-rita-order-tracking__sample">
        {% if section.settings.modal_note_label != blank %}
          <p class="santa-rita-order-tracking__sample-note">{{ section.settings.modal_note_label }}</p>
        {% endif %}

        <p class="santa-rita-order-tracking__sample-code">
          {% if section.settings.modal_code_label != blank %}
            <span>{{ section.settings.modal_code_label }}</span>
          {% endif %}
          <strong>{{ modal_example_code }}</strong>
        </p>

        {% if section.settings.modal_button_label != blank %}
          <a
            class="santa-rita-order-tracking__sample-button"
            href="{{ tracking_base_url | append: modal_example_code | escape }}"
            {% if section.settings.open_new_window %}
              target="_blank"
              rel="noopener noreferrer"
            {% endif %}
          >
            {{ section.settings.modal_button_label }}
          </a>
        {% endif %}
      </div>

      {% if modal_footer_text != blank %}
        <div class="santa-rita-order-tracking__modal-footer">
          {{ section.settings.modal_footer_text }}
        </div>
      {% endif %}
    </div>
  </div>
</santa-rita-order-tracking>

<script>
  if (!customElements.get('santa-rita-order-tracking')) {
    customElements.define(
      'santa-rita-order-tracking',
      class SantaRitaOrderTracking extends HTMLElement {
        connectedCallback() {
          if (this.initialized) return;
          this.initialized = true;

          this.form = this.querySelector('[data-tracking-form]');
          this.input = this.querySelector('[data-tracking-input]');
          this.error = this.querySelector('[data-tracking-error]');
          this.modal = this.querySelector('[data-modal]');
          this.dialog = this.querySelector('[role="dialog"]');
          this.openButtons = Array.from(this.querySelectorAll('[data-modal-open]'));
          this.closeButtons = Array.from(this.querySelectorAll('[data-modal-close]'));
          this.boundHandleKeydown = (event) => this.handleKeydown(event);

          this.form?.addEventListener('submit', (event) => this.handleSubmit(event));
          this.openButtons.forEach((button) => button.addEventListener('click', () => this.openModal(button)));
          this.closeButtons.forEach((button) => button.addEventListener('click', () => this.closeModal()));
          document.addEventListener('keydown', this.boundHandleKeydown);
        }

        disconnectedCallback() {
          document.removeEventListener('keydown', this.boundHandleKeydown);
        }

        handleSubmit(event) {
          event.preventDefault();

          const code = this.cleanCode(this.input?.value || '');

          if (!code) {
            this.showError();
            return;
          }

          this.clearError();

          const url = `${this.dataset.baseUrl || ''}${code}`;
          const opensNewWindow = this.dataset.openNewWindow === 'true';

          if (opensNewWindow) {
            window.open(url, '_blank', 'noopener,noreferrer');
          } else {
            window.location.href = url;
          }
        }

        cleanCode(value) {
          return value.toString().replace(/[\s.-]/g, '').trim();
        }

        showError() {
          if (this.error) {
            this.error.textContent = this.dataset.emptyMessage || '';
            this.error.hidden = false;
          }

          this.input?.setAttribute('aria-invalid', 'true');
          this.input?.focus();
        }

        clearError() {
          if (this.error) {
            this.error.textContent = '';
            this.error.hidden = true;
          }

          this.input?.removeAttribute('aria-invalid');
        }

        openModal(trigger) {
          if (!this.modal) return;

          this.activeTrigger = trigger;
          this.modal.hidden = false;
          document.documentElement.classList.add('santa-rita-order-tracking-modal-open');
          requestAnimationFrame(() => {
            this.modal.classList.add('is-open');
            this.dialog?.focus?.();
            this.querySelector('[data-modal-close]')?.focus();
          });
        }

        closeModal() {
          if (!this.modal || this.modal.hidden) return;

          this.modal.classList.remove('is-open');
          document.documentElement.classList.remove('santa-rita-order-tracking-modal-open');
          window.setTimeout(() => {
            this.modal.hidden = true;
            this.activeTrigger?.focus?.();
          }, 180);
        }

        handleKeydown(event) {
          if (event.key === 'Escape' && this.modal && !this.modal.hidden) {
            this.closeModal();
          }
        }
      }
    );
  }
</script>

<style>
  .santa-rita-order-tracking {
    display: block;
    background: #fffbf6;
    color: #21000f;
  }

  .santa-rita-order-tracking__inner {
    width: min(100% - 48px, 490px);
    margin-inline: auto;
    padding-block: 52px 64px;
  }

  .santa-rita-order-tracking__heading {
    margin: 0 0 20px;
    font-family: var(--font-heading--family);
    font-size: clamp(30px, 3vw, 42px);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: 0;
  }

  .santa-rita-order-tracking__text {
    margin-bottom: 22px;
    font-size: 16px;
    line-height: 1.35;
  }

  .santa-rita-order-tracking__text p,
  .santa-rita-order-tracking__notice-text p,
  .santa-rita-order-tracking__modal-text p,
  .santa-rita-order-tracking__modal-footer p {
    margin: 0;
  }

  .santa-rita-order-tracking__form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 92px;
    gap: 14px;
    align-items: start;
  }

  .santa-rita-order-tracking__field input {
    width: 100%;
    min-height: 60px;
    border: 1px solid rgba(110, 90, 97, 0.28);
    border-radius: 4px;
    background: #ffffff;
    color: #21000f;
    font: inherit;
    font-size: 18px;
    line-height: 1;
    padding: 0 18px;
  }

  .santa-rita-order-tracking__field input::placeholder {
    color: #667486;
    opacity: 1;
  }

  .santa-rita-order-tracking__field input[aria-invalid='true'] {
    border-color: #8c1a3e;
  }

  .santa-rita-order-tracking__helper,
  .santa-rita-order-tracking__error {
    margin: 8px 0 0;
    font-size: 14px;
    line-height: 1.25;
  }

  .santa-rita-order-tracking__helper {
    color: #667486;
  }

  .santa-rita-order-tracking__error {
    color: #8c1a3e;
    font-weight: 700;
  }

  .santa-rita-order-tracking__submit {
    display: inline-flex;
    min-height: 60px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 8px;
    background: #8c1a3e;
    color: #ffffff;
    cursor: pointer;
    font: inherit;
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 18px;
  }

  .santa-rita-order-tracking__question {
    margin-top: 26px;
    font-size: 16px;
    line-height: 1.3;
  }

  .santa-rita-order-tracking__question h3 {
    margin: 0 0 12px;
    font-size: 17px;
    font-weight: 700;
    line-height: 1.2;
  }

  .santa-rita-order-tracking__question p {
    margin: 0;
  }

  .santa-rita-order-tracking__modal-trigger {
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .santa-rita-order-tracking__notice {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    margin-top: 30px;
    border-radius: 8px;
    background: #f8f1e6;
    padding: 18px 18px;
  }

  .santa-rita-order-tracking__notice-icon {
    display: inline-grid;
    width: 25px;
    height: 25px;
    place-items: center;
    border: 2px solid #8c1a3e;
    border-radius: 50%;
    color: #8c1a3e;
    font-size: 17px;
    font-weight: 700;
    line-height: 1;
  }

  .santa-rita-order-tracking__notice-text {
    font-size: 16px;
    line-height: 1.2;
  }

  .santa-rita-order-tracking__notice-text strong {
    font-weight: 700;
  }

  .santa-rita-order-tracking__notice-text a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .santa-rita-order-tracking__modal[hidden] {
    display: none;
  }

  .santa-rita-order-tracking__modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .santa-rita-order-tracking__modal.is-open {
    opacity: 1;
  }

  .santa-rita-order-tracking__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(33, 0, 15, 0.28);
  }

  .santa-rita-order-tracking__dialog {
    position: relative;
    z-index: 1;
    width: min(100%, 596px);
    background: #fffbf6;
    color: #21000f;
    padding: 28px 28px 36px;
    transform: translateY(10px);
    transition: transform 180ms ease;
  }

  .santa-rita-order-tracking__modal.is-open .santa-rita-order-tracking__dialog {
    transform: translateY(0);
  }

  .santa-rita-order-tracking__close {
    position: absolute;
    top: 18px;
    right: 18px;
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 0;
    background: transparent;
    color: #6e5a61;
    cursor: pointer;
    padding: 0;
  }

  .santa-rita-order-tracking__close svg {
    width: 28px;
    height: 28px;
  }

  .santa-rita-order-tracking__dialog h2 {
    margin: 0 44px 22px 0;
    font-family: var(--font-heading--family);
    font-size: clamp(30px, 3.2vw, 40px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .santa-rita-order-tracking__modal-text {
    max-width: 520px;
    margin-bottom: 28px;
    font-size: 18px;
    line-height: 1.18;
  }

  .santa-rita-order-tracking__modal-text strong,
  .santa-rita-order-tracking__modal-footer strong {
    font-weight: 700;
  }

  .santa-rita-order-tracking__sample {
    background: #f7f7f7;
    padding: 14px 28px 24px;
  }

  .santa-rita-order-tracking__sample-note,
  .santa-rita-order-tracking__sample-code {
    margin: 0;
    color: #9b9b9b;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.45;
  }

  .santa-rita-order-tracking__sample-code strong {
    color: #b40000;
    font-weight: 700;
  }

  .santa-rita-order-tracking__sample-button {
    display: flex;
    width: min(100%, 352px);
    min-height: 52px;
    align-items: center;
    justify-content: center;
    margin: 14px 0 0 auto;
    border-radius: 999px;
    background: #b40000;
    color: #ffffff;
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
    text-align: center;
    text-decoration: none;
  }

  .santa-rita-order-tracking__modal-footer {
    margin-top: 28px;
    font-size: 18px;
    line-height: 1.28;
  }

  .santa-rita-order-tracking-modal-open {
    overflow: hidden;
  }

  @media screen and (max-width: 749px) {
    .santa-rita-order-tracking__inner {
      width: calc(100% - 56px);
      padding-block: 30px 40px;
    }

    .santa-rita-order-tracking__form {
      grid-template-columns: minmax(0, 1fr) 84px;
      gap: 12px;
    }

    .santa-rita-order-tracking__field input,
    .santa-rita-order-tracking__submit {
      min-height: 59px;
      font-size: 18px;
    }

    .santa-rita-order-tracking__field input {
      padding-inline: 16px;
    }

    .santa-rita-order-tracking__submit {
      border-radius: 8px;
      padding-inline: 12px;
    }

    .santa-rita-order-tracking__helper,
    .santa-rita-order-tracking__error {
      font-size: 14px;
    }

    .santa-rita-order-tracking__question {
      margin-top: 24px;
      font-size: 16px;
    }

    .santa-rita-order-tracking__notice {
      margin-top: 28px;
      padding: 16px 18px;
    }

    .santa-rita-order-tracking__notice-text {
      font-size: 16px;
    }

    .santa-rita-order-tracking__modal {
      align-items: end;
      place-items: end stretch;
      padding: 0;
    }

    .santa-rita-order-tracking__backdrop {
      background: rgba(33, 0, 15, 0.18);
    }

    .santa-rita-order-tracking__dialog {
      width: 100%;
      max-height: calc(100dvh - 32px);
      overflow: auto;
      padding: 28px 36px 30px;
      transform: translateY(100%);
    }

    .santa-rita-order-tracking__modal.is-open .santa-rita-order-tracking__dialog {
      transform: translateY(0);
    }

    .santa-rita-order-tracking__close {
      top: 18px;
      right: 24px;
      width: 38px;
      height: 38px;
    }

    .santa-rita-order-tracking__close svg {
      width: 32px;
      height: 32px;
    }

    .santa-rita-order-tracking__dialog h2 {
      margin-right: 44px;
      margin-bottom: 24px;
      font-size: 38px;
    }

    .santa-rita-order-tracking__modal-text {
      margin-bottom: 26px;
      font-size: 25px;
      line-height: 1.16;
    }

    .santa-rita-order-tracking__sample {
      padding: 16px 32px 22px;
    }

    .santa-rita-order-tracking__sample-note,
    .santa-rita-order-tracking__sample-code {
      font-size: 18px;
    }

    .santa-rita-order-tracking__sample-button {
      width: 100%;
      min-height: 54px;
      margin-top: 18px;
      font-size: 25px;
    }

    .santa-rita-order-tracking__modal-footer {
      margin-top: 30px;
      font-size: 25px;
      line-height: 1.2;
    }
  }

  @media screen and (max-width: 420px) {
    .santa-rita-order-tracking__inner {
      width: calc(100% - 28px);
    }

    .santa-rita-order-tracking__form {
      grid-template-columns: minmax(0, 1fr) 76px;
      gap: 8px;
    }

    .santa-rita-order-tracking__field input,
    .santa-rita-order-tracking__submit {
      font-size: 15px;
    }

    .santa-rita-order-tracking__dialog {
      padding: 22px 24px 28px;
    }

    .santa-rita-order-tracking__dialog h2 {
      font-size: 31px;
    }

    .santa-rita-order-tracking__modal-text,
    .santa-rita-order-tracking__modal-footer,
    .santa-rita-order-tracking__sample-button {
      font-size: 20px;
    }

    .santa-rita-order-tracking__sample {
      padding-inline: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Seguimiento de pedido",
  "settings": [
    {
      "type": "header",
      "content": "Buscador"
    },
    {
      "type": "text",
      "id": "tracking_base_url",
      "label": "URL base de seguimiento",
      "default": "https://livetracking.simpliroute.com/widget/account/13343/tracking/",
      "info": "El codigo ingresado se concatena al final de esta URL."
    },
    {
      "type": "checkbox",
      "id": "open_new_window",
      "label": "Abrir seguimiento en una nueva ventana",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto superior"
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "Etiqueta accesible del campo",
      "default": "Numero de pedido"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Placeholder",
      "default": "N° de pedido"
    },
    {
      "type": "text",
      "id": "input_helper",
      "label": "Ayuda bajo el campo",
      "default": "Sin guiones ni puntos. Ej. 360000000000"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto boton",
      "default": "Buscar"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Mensaje de error",
      "default": "Ingresa tu numero de pedido."
    },
    {
      "type": "header",
      "content": "Enlace al modal"
    },
    {
      "type": "text",
      "id": "question_title",
      "label": "Titulo ayuda",
      "default": "¿No tienes el número?"
    },
    {
      "type": "text",
      "id": "question_prefix",
      "label": "Texto antes del enlace",
      "default": "Puedes encontrarlo en el"
    },
    {
      "type": "text",
      "id": "modal_trigger_label",
      "label": "Texto del enlace",
      "default": "email de confirmación de tu compra"
    },
    {
      "type": "text",
      "id": "question_suffix",
      "label": "Texto despues del enlace",
      "default": "."
    },
    {
      "type": "header",
      "content": "Aviso"
    },
    {
      "type": "checkbox",
      "id": "show_notice_icon",
      "label": "Mostrar icono",
      "default": true
    },
    {
      "type": "richtext",
      "id": "notice_text",
      "label": "Texto aviso",
      "default": "<p><strong>Servicio exclusivo para RM.</strong><br>Otras Regiones: Por favor visitar la sección <a href=\"/pages/plazos-y-costos\">plazos y costos de despacho.</a></p>"
    },
    {
      "type": "header",
      "content": "Modal"
    },
    {
      "type": "text",
      "id": "close_label",
      "label": "Etiqueta cerrar",
      "default": "Cerrar modal"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Titulo modal",
      "default": "Encuentra tu N° de pedido"
    },
    {
      "type": "richtext",
      "id": "modal_text",
      "label": "Texto modal",
      "default": "<p>Busca el correo con el asunto <strong>“Su pedido va en camino”.</strong> Ahí encontrarás tu número de seguimiento:</p>"
    },
    {
      "type": "text",
