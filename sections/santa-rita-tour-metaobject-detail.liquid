{% liquid
  assign current_tour = metaobject
  assign tour_title = current_tour.title.value | default: current_tour.title | default: current_tour.system.title
  assign hero_image = current_tour.banner_image.value | default: current_tour.banner_image
  assign hero_subheading = current_tour.hero_subheading.value | default: current_tour.hero_subheading | default: section.settings.hero_subheading
  assign short_description = current_tour.short_description.value | default: current_tour.short_description
  assign duration = current_tour.duration.value | default: current_tour.duration | default: section.settings.default_duration
  assign people = current_tour.people.value | default: current_tour.people | default: section.settings.default_schedule
  assign languages = current_tour.languages.value | default: current_tour.languages | default: section.settings.default_languages
  assign wines = current_tour.wines.value | default: current_tour.wines | default: section.settings.default_capacity
  assign route_heading = current_tour.route_heading.value | default: current_tour.route_heading | default: section.settings.route_heading
  assign route_stops_value = current_tour.route_stops.value
  assign route_stops_text = current_tour.route_stops.value | default: current_tour.route_stops
  assign route_stop_lines = route_stops_text | newline_to_br | split: '<br />'
  assign experience_heading = current_tour.experience_heading.value | default: current_tour.experience_heading | default: section.settings.experience_heading
  assign experience_text = current_tour.experience_text
  assign includes_heading = current_tour.includes_heading.value | default: current_tour.includes_heading | default: section.settings.includes_heading
  assign includes_items = current_tour.tour_include.value | default: current_tour.includes_items.value | default: current_tour.include_items.value | default: current_tour.included_items.value
  assign includes_text = current_tour.includes.value | default: current_tour.includes
  assign include_lines = includes_text | newline_to_br | split: '<br />'
  assign time_options_source = current_tour.time_options.value | default: current_tour.time_options | default: section.settings.time_options
  assign language_options_source = current_tour.language_options.value | default: current_tour.language_options | default: section.settings.language_options
  assign max_people = current_tour.max_people.value | default: current_tour.max_people | default: section.settings.max_people
  assign disabled_weekdays = current_tour.disabled_weekdays.value | default: current_tour.disabled_weekdays | default: section.settings.disabled_weekdays
  assign blocked_dates = current_tour.blocked_dates.value | default: current_tour.blocked_dates | default: section.settings.blocked_dates
  assign enabled_dates = current_tour.enabled_dates.value | default: current_tour.enabled_dates | default: section.settings.enabled_dates
  assign booking_url = current_tour.booking_url.value | default: current_tour.booking_url | default: section.settings.booking_url
  assign tour_price = current_tour.price.value | default: current_tour.price
  assign price_amount = tour_price.amount | default: tour_price | default: 0
  assign price_cents = price_amount | round
  assign price_currency = tour_price.currency_code | default: cart.currency.iso_code | default: shop.currency
  assign booking_url_string = booking_url | append: ''
  assign time_options = time_options_source | split: ','
  assign language_options = language_options_source | split: ','
%}

{{ 'https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css' | stylesheet_tag }}
<script src="https://cdn.jsdelivr.net/npm/flatpickr" defer></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js" defer></script>

<santa-rita-tour-metaobject-detail
  class="santa-rita-tour-detail"
  data-section-id="{{ section.id }}"
  data-tour-title="{{ tour_title | escape }}"
  data-tour-handle="{{ current_tour.system.handle | escape }}"
  data-price-cents="{{ price_cents }}"
  data-price-currency="{{ price_currency | escape }}"
  data-booking-url="{{ booking_url_string | escape }}"
  data-disabled-weekdays="{{ disabled_weekdays | escape }}"
  data-blocked-dates="{{ blocked_dates | escape }}"
  data-enabled-dates="{{ enabled_dates | escape }}"
  {{ section.shopify_attributes }}
>
  <section class="santa-rita-tour-detail__hero" aria-labelledby="santa-rita-tour-title-{{ section.id }}">
    {% if hero_image != blank %}
      {{
        hero_image
        | image_url: width: 2200
        | image_tag:
          widths: '480, 720, 990, 1440, 1800, 2200',
          sizes: '100vw',
          loading: 'eager',
          class: 'santa-rita-tour-detail__hero-image'
      }}
    {% elsif request.design_mode %}
      {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-detail__hero-image santa-rita-tour-detail__hero-image--placeholder' }}
    {% endif %}

    <div class="santa-rita-tour-detail__hero-overlay"></div>

    <div class="santa-rita-tour-detail__hero-inner">
      <nav class="santa-rita-tour-detail__breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Inicio</a>
        <span aria-hidden="true">&gt;</span>
        {% if section.settings.tours_page != blank %}
          <a href="{{ section.settings.tours_page.url }}">Tours</a>
        {% else %}
          <span>Tours</span>
        {% endif %}
        <span aria-hidden="true">&gt;</span>
        <span>{{ tour_title }}</span>
      </nav>

      <div class="santa-rita-tour-detail__hero-content">
        <h1 id="santa-rita-tour-title-{{ section.id }}">{{ tour_title }}</h1>

        {% if hero_subheading != blank %}
          <p>{{ hero_subheading }}</p>
        {% elsif short_description != blank %}
          <p>{{ short_description | strip_html | truncatewords: 22 }}</p>
        {% endif %}

        <strong>{{ price_cents | money }}</strong>
        {% if section.settings.price_note != blank %}
          <span>{{ section.settings.price_note }}</span>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="santa-rita-tour-detail__content">
    <div class="santa-rita-tour-detail__layout">
      <div class="santa-rita-tour-detail__main">
        <div class="santa-rita-tour-detail__metrics">
          {% if duration != blank %}
            <div class="santa-rita-tour-detail__metric">
              <span>
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M14.6389 10.75H10.75V5.19444M0.75 10.75C0.75 12.0632 1.00866 13.3636 1.5112 14.5768C2.01375 15.7901 2.75035 16.8925 3.67893 17.8211C4.60752 18.7497 5.70991 19.4863 6.92317 19.9888C8.13642 20.4913 9.43678 20.75 10.75 20.75C12.0632 20.75 13.3636 20.4913 14.5768 19.9888C15.7901 19.4863 16.8925 18.7497 17.8211 17.8211C18.7497 16.8925 19.4863 15.7901 19.9888 14.5768C20.4913 13.3636 20.75 12.0632 20.75 10.75C20.75 9.43678 20.4913 8.13642 19.9888 6.92317C19.4863 5.70991 18.7497 4.60752 17.8211 3.67893C16.8925 2.75035 15.7901 2.01375 14.5768 1.5112C13.3636 1.00866 12.0632 0.75 10.75 0.75C9.43678 0.75 8.13642 1.00866 6.92317 1.5112C5.70991 2.01375 4.60752 2.75035 3.67893 3.67893C2.75035 4.60752 2.01375 5.70991 1.5112 6.92317C1.00866 8.13642 0.75 9.43678 0.75 10.75Z" stroke="#8C1A3E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <strong>{{ duration }}</strong>
              <small>duracion</small>
            </div>
          {% endif %}

          {% if people != blank %}
            <div class="santa-rita-tour-detail__metric">
              <span>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M11.7502 0.75C14.3589 0.75 16.4647 2.85572 16.4647 5.46431C16.4647 8.07289 14.3589 10.1786 11.7502 10.1786C9.14147 10.1786 7.03564 8.07289 7.03564 5.46431C7.03564 2.85572 9.14147 0.75 11.7502 0.75Z" stroke="#8C1A3E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M11.7506 14.8945C18.0366 14.8945 22.7511 18.0374 22.7511 19.6088V22.7517H0.75V19.6088C0.75 18.0374 5.46452 14.8945 11.7506 14.8945Z" stroke="#8C1A3E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <strong>{{ people }}</strong>
              <small>personas</small>
            </div>
          {% endif %}

          {% if languages != blank %}
            <div class="santa-rita-tour-detail__metric">
              <span>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7.72223 22.1322C6.3843 21.5529 5.21912 20.7666 4.22667 19.7733C3.23423 18.7801 2.44793 17.6149 1.86778 16.2778C1.28764 14.9407 0.998377 13.5135 1.00001 11.9963C1.00164 10.4791 1.2909 9.05322 1.86778 7.71855C2.44467 6.38389 3.23097 5.21992 4.22667 4.22667C5.22238 3.23341 6.38756 2.44711 7.72223 1.86778C9.06015 1.28926 10.4873 1 12.0037 1C13.5192 1 14.9452 1.28926 16.2814 1.86778C17.6177 2.44711 18.7821 3.23341 19.7746 4.22667C20.767 5.21992 21.5529 6.38389 22.1322 7.71855C22.7107 9.05485 23 10.4808 23 11.9963C23 13.5119 22.7107 14.939 22.1322 16.2778C21.5529 17.6157 20.7666 18.7809 19.7733 19.7733C18.7801 20.7658 17.6161 21.5521 16.2814 22.1322C14.9468 22.7124 13.5209 23.0016 12.0037 23C10.4865 22.9984 9.05934 22.7091 7.72223 22.1322ZM12 21.7875C12.717 20.866 13.3086 19.9611 13.7747 19.073C14.2399 18.1848 14.6184 17.1908 14.9101 16.0908H9.08989C9.41337 17.2527 9.7996 18.2781 10.2486 19.1671C10.6983 20.0553 11.2822 20.9287 12 21.7875ZM10.4441 21.6042C9.87374 20.932 9.35308 20.1009 8.88212 19.1109C8.41115 18.1217 8.06078 17.1146 7.831 16.0896H3.14378C3.84452 17.6092 4.83738 18.8558 6.12234 19.8295C7.40812 20.8024 8.84871 21.394 10.4441 21.6042ZM13.5559 21.6042C15.1513 21.394 16.5919 20.8024 17.8777 19.8295C19.1626 18.8558 20.1555 17.6092 20.8562 16.0896H16.1702C15.8606 17.1301 15.4707 18.1449 15.0006 19.1341C14.5296 20.1241 14.048 20.9483 13.5559 21.6042ZM2.64512 14.8686H7.57678C7.48389 14.3666 7.41871 13.8777 7.38123 13.4019C7.34212 12.9268 7.32256 12.4596 7.32256 12C7.32256 11.5404 7.34171 11.0731 7.38001 10.5981C7.4183 10.1231 7.48349 9.63418 7.57556 9.13144H2.64634C2.51353 9.55515 2.40964 10.0167 2.33467 10.5162C2.25971 11.0149 2.22223 11.5095 2.22223 12C2.22223 12.4905 2.2593 12.9855 2.33345 13.485C2.4076 13.9845 2.51149 14.4453 2.64512 14.8673M8.799 14.8673H15.201C15.2939 14.3662 15.3591 13.8855 15.3966 13.4251C15.4357 12.9656 15.4552 12.4905 15.4552 12C15.4552 11.5095 15.4361 11.0344 15.3978 10.5749C15.3595 10.1153 15.2943 9.63459 15.2022 9.13266H8.79778C8.70571 9.63378 8.64052 10.1145 8.60223 10.5749C8.56393 11.0344 8.54478 11.5095 8.54478 12C8.54478 12.4905 8.56393 12.9656 8.60223 13.4251C8.64052 13.8847 8.70693 14.3654 8.799 14.8673ZM16.4244 14.8673H21.3549C21.4877 14.4444 21.5916 13.9837 21.6666 13.485C21.7407 12.9855 21.7778 12.4905 21.7778 12C21.7778 11.5095 21.7407 11.0145 21.6666 10.515C21.5924 10.0155 21.4885 9.55474 21.3549 9.13266H16.4232C16.5161 9.63378 16.5813 10.1223 16.6188 10.5981C16.6579 11.074 16.6774 11.5413 16.6774 12C16.6774 12.4587 16.6583 12.926 16.62 13.4019C16.5817 13.8777 16.5165 14.3666 16.4244 14.8686M16.1702 7.91044H20.8562C20.14 6.35904 19.159 5.11237 17.9131 4.17044C16.6673 3.22852 15.2149 2.62922 13.5559 2.37256C14.1263 3.123 14.6392 3.98141 15.0947 4.94778C15.5501 5.91333 15.9087 6.90089 16.1702 7.91044ZM9.08989 7.91044H14.9101C14.5874 6.76318 14.1894 5.72592 13.716 4.79867C13.2426 3.87141 12.6706 3.00933 12 2.21244C11.3294 3.00852 10.7574 3.87059 10.284 4.79867C9.8106 5.72674 9.41175 6.764 9.08989 7.91044ZM3.14501 7.91044H7.831C8.09256 6.9017 8.45108 5.91415 8.90656 4.94778C9.36204 3.98141 9.87497 3.123 10.4453 2.37256C8.77171 2.63004 7.31563 3.233 6.07712 4.18144C4.8386 5.13152 3.86082 6.37411 3.14378 7.90922" fill="#8C1A3E"/>
                </svg>
              </span>
              <strong>{{ languages }}</strong>
              <small>idiomas</small>
            </div>
          {% endif %}

          {% if wines != blank %}
            <div class="santa-rita-tour-detail__metric">
              <span>
                <svg width="16" height="21" viewBox="0 0 16 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M15.7301 7.46906L13.5539 0.538125C13.5051 0.382842 13.4041 0.246522 13.2659 0.14953C13.1277 0.0525394 12.9598 8.37452e-05 12.7872 0H3.21281C3.0402 8.37452e-05 2.87226 0.0525394 2.73407 0.14953C2.59588 0.246522 2.49486 0.382842 2.4461 0.538125L0.269919 7.46906C-0.0715116 8.53139 -0.0893805 9.6621 0.218331 10.7335C0.526042 11.8048 1.14707 12.7741 2.01126 13.5319C3.43287 14.7821 5.25937 15.5507 7.2003 15.7153V19.5H4.00151C3.78942 19.5 3.58601 19.579 3.43604 19.7197C3.28607 19.8603 3.20181 20.0511 3.20181 20.25C3.20181 20.4489 3.28607 20.6397 3.43604 20.7803C3.58601 20.921 3.78942 21 4.00151 21H11.9985C12.2106 21 12.414 20.921 12.564 20.7803C12.7139 20.6397 12.7982 20.4489 12.7982 20.25C12.7982 20.0511 12.7139 19.8603 12.564 19.7197C12.414 19.579 12.2106 19.5 11.9985 19.5H8.7997V15.7153C10.7406 15.5507 12.5671 14.7821 13.9887 13.5319C14.8529 12.7741 15.474 11.8048 15.7817 10.7335C16.0894 9.6621 16.0715 8.53139 15.7301 7.46906ZM3.81058 1.5H12.1894L14.1977 7.89281C14.2067 7.92094 14.2147 7.94906 14.2226 7.97719C12.0815 8.69719 9.67037 7.82719 8.36186 7.20563C5.84381 6.01031 3.84457 5.85844 2.37013 6.08719L3.81058 1.5ZM12.8981 12.4359C11.5702 13.6021 9.81917 14.2509 8 14.2509C6.18083 14.2509 4.42975 13.6021 3.10185 12.4359C2.45517 11.8676 1.9908 11.141 1.76118 10.3382C1.53155 9.53542 1.5458 8.6884 1.80234 7.89281L1.84732 7.75031C3.04687 7.36969 4.95315 7.26844 7.63814 8.54438C8.75272 9.07406 10.553 9.74906 12.4793 9.74906C13.1231 9.75205 13.7642 9.67 14.3836 9.50531C14.302 10.6234 13.7711 11.6707 12.8981 12.4359Z" fill="#8C1A3E"/>
                </svg>
              </span>
              <strong>{{ wines }}</strong>
              <small>vinos</small>
            </div>
          {% endif %}
        </div>

        <a href="#SantaRitaTourReserve-{{ section.id }}" class="santa-rita-tour-detail__mobile-reserve-button">
          {{ section.settings.reserve_button_label }}
        </a>

        {% if route_stops_value != blank or route_stops_text != blank %}
          <section class="santa-rita-tour-detail__route">
            {% if route_heading != blank %}
              <h2>{{ route_heading }}</h2>
            {% endif %}

            <div class="santa-rita-tour-detail__route-items">
              {% if current_tour.route_stops.type contains 'list.' %}
                {% for route_stop_entry in route_stops_value %}
                  {% liquid
                    assign route_stop_title = route_stop_entry.title.value | default: route_stop_entry.title | default: route_stop_entry.name.value | default: route_stop_entry.name | default: route_stop_entry
                    assign route_stop_text_field = route_stop_entry.text | default: route_stop_entry.description
                    assign route_stop_text = route_stop_text_field.value | default: route_stop_text_field
                  %}

                  {% if route_stop_title != blank %}
                    <article class="santa-rita-tour-detail__route-item">
                      <span>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                      <h3>{{ route_stop_title }}</h3>
                      {% if route_stop_text != blank %}
                        {% if route_stop_text_field.type == 'rich_text_field' %}
                          <div>{{ route_stop_text_field | metafield_tag }}</div>
                        {% else %}
                          <div><p>{{ route_stop_text }}</p></div>
                        {% endif %}
                      {% endif %}
                    </article>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% for route_stop in route_stop_lines %}
                  {% assign route_stop = route_stop | strip %}
                  {% if route_stop != blank %}
                    <article class="santa-rita-tour-detail__route-item">
                      <span>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                      <h3>{{ route_stop }}</h3>
                    </article>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>
          </section>
        {% endif %}

        {% if experience_heading != blank or experience_text != blank or short_description != blank %}
          <section class="santa-rita-tour-detail__experience">
            {% if experience_heading != blank %}
              <h2>{{ experience_heading }}</h2>
            {% endif %}

            {% if experience_text != blank %}
              <div>{{ experience_text | metafield_tag }}</div>
            {% elsif section.settings.experience_text != blank %}
              <div>{{ section.settings.experience_text }}</div>
            {% elsif short_description != blank %}
              <div><p>{{ short_description }}</p></div>
            {% endif %}
          </section>
        {% endif %}

        {% if includes_items != blank or includes_text != blank %}
          <section class="santa-rita-tour-detail__includes">
            {% if includes_heading != blank %}
              <h2>{{ includes_heading }}</h2>
            {% endif %}

            <div class="santa-rita-tour-detail__includes-grid">
              {% if includes_items != blank %}
                {% for include_item in includes_items %}
                  {% liquid
                    assign include_image = include_item.imagen.value | default: include_item.imagen | default: include_item.image.value | default: include_item.image | default: include_item.icon_image.value | default: include_item.icon_image
                    assign include_text = include_item.titulo.value | default: include_item.titulo | default: include_item.name.value | default: include_item.name | default: include_item.title.value | default: include_item.title | default: include_item.text.value | default: include_item.text
                  %}

                  {% if include_text != blank or include_image != blank %}
                    <div class="santa-rita-tour-detail__include">
                      {% if include_image != blank %}
                        <span aria-hidden="true">
                          {{
                            include_image
                            | image_url: width: 160
                            | image_tag:
                              widths: '64, 96, 128, 160',
                              sizes: '72px',
                              loading: 'lazy',
                              class: 'santa-rita-tour-detail__include-image'
                          }}
                        </span>
                      {% endif %}

                      {% if include_text != blank %}
                        <p>{{ include_text }}</p>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% for include_line in include_lines %}
                  {% assign include_line = include_line | strip %}
                  {% if include_line != blank %}
                    {% assign include_parts = include_line | split: '|' %}
                    {% assign include_icon = include_parts[0] | strip %}
                    {% assign include_text = include_parts[1] | default: include_parts[0] | strip %}
                    <div class="santa-rita-tour-detail__include">
                      {% if include_parts[1] != blank %}
                        <span aria-hidden="true">{{ include_icon }}</span>
                      {% endif %}
                      <p>{{ include_text }}</p>
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>
          </section>
        {% endif %}
      </div>

      <aside id="SantaRitaTourReserve-{{ section.id }}" class="santa-rita-tour-detail__reserve" aria-labelledby="santa-rita-tour-reserve-title-{{ section.id }}">
        <h2 id="santa-rita-tour-reserve-title-{{ section.id }}">
          {{ section.settings.reserve_heading }}
          <span aria-hidden="true">
            <svg width="16" height="20" viewBox="0 0 16 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6.99911 15.92V18H3.99911V20H11.9991V18H8.99911V15.92C12.1791 15.52 14.8891 13.26 15.7591 10.13C16.0191 9.18 16.0691 8.1 15.8991 6.92L15.0291 0.86C14.9591 0.37 14.5391 0 14.0391 0H1.95911C1.45911 0 1.03911 0.37 0.969107 0.86L0.0991073 6.92C-0.0708927 8.1 -0.0208929 9.18 0.239107 10.13C1.10911 13.26 3.80911 15.52 6.99911 15.92ZM13.8291 9.59C13.1091 12.19 10.7091 14 7.99911 14C5.43911 14 3.16911 12.37 2.31911 10C3.03911 10.32 3.78911 10.49 4.53911 10.49C5.99911 10.49 7.45911 9.89 8.68911 8.72C10.1891 7.28 12.0391 7.11 13.6391 8.25L13.9891 8.5C13.9754 8.86476 13.9217 9.22692 13.8291 9.58V9.59ZM2.82911 2H13.1691L13.7491 6.03C11.5991 5.05 9.17911 5.48 7.30911 7.28C5.80911 8.72 3.95911 8.89 2.35911 7.75L2.04911 7.53L2.07911 7.21L2.82911 2.01V2Z" fill="white"/>
            </svg>
          </span>
        </h2>

        <div class="santa-rita-tour-detail__reserve-body">
          {% if section.settings.reserve_info_heading != blank %}
            <h3 class="santa-rita-tour-detail__reserve-info-heading">{{ section.settings.reserve_info_heading }}</h3>
          {% endif %}

          <form class="santa-rita-tour-detail__form" data-tour-booking-form>
            <div class="santa-rita-tour-detail__field">
              <label for="TourLanguage-{{ section.id }}">{{ section.settings.language_label }}</label>
              <select id="TourLanguage-{{ section.id }}" name="idioma" required data-tour-language>
                {% for option in language_options %}
                  {% assign option_value = option | strip %}
                  {% if option_value != blank %}
                    <option value="{{ option_value | escape }}">{{ option_value }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>

            <div class="santa-rita-tour-detail__fields">
              <div class="santa-rita-tour-detail__field">
                <label for="TourAdults-{{ section.id }}">{{ section.settings.adults_label }}</label>
                <select id="TourAdults-{{ section.id }}" name="adultos" required data-tour-adults>
                  {% for adult_count in (1..max_people) %}
                    <option value="{{ adult_count }}">{{ adult_count }}</option>
                  {% endfor %}
                </select>
              </div>

              <div class="santa-rita-tour-detail__field">
                <label for="TourChildren-{{ section.id }}">{{ section.settings.children_label }}</label>
                <select id="TourChildren-{{ section.id }}" name="ninos" data-tour-children>
                  {% for child_count in (0..max_people) %}
                    <option value="{{ child_count }}">{{ child_count }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>

            <div class="santa-rita-tour-detail__field santa-rita-tour-detail__field--calendar">
              <label for="TourDate-{{ section.id }}">{{ section.settings.date_label }}</label>
              <input
                id="TourDate-{{ section.id }}"
                type="text"
                name="fecha"
                placeholder="{{ section.settings.date_placeholder }}"
                required
                data-tour-calendar
              >
            </div>

            <div class="santa-rita-tour-detail__field">
              <label for="TourTime-{{ section.id }}">{{ section.settings.time_label }}</label>
              <select id="TourTime-{{ section.id }}" name="horario" required data-tour-time>
                {% for option in time_options %}
                  {% assign option_value = option | strip %}
                  {% if option_value != blank %}
                    <option value="{{ option_value | escape }}">{{ option_value }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>

            {% if section.settings.reserve_note != blank %}
              <p class="santa-rita-tour-detail__reserve-note">{{ section.settings.reserve_note }}</p>
            {% endif %}

            <div class="santa-rita-tour-detail__total">
              <span>{{ section.settings.total_label }}</span>
              <strong data-tour-total>{{ price_cents | money }}</strong>
            </div>

            <button
              type="submit"
              class="santa-rita-tour-detail__submit"
              {% if booking_url == blank %}
                disabled
              {% endif %}
            >
              {{ section.settings.reserve_button_label }}
            </button>
          </form>
        </div>
      </aside>
    </div>
  </div>
</santa-rita-tour-metaobject-detail>

<script>
  if (!customElements.get('santa-rita-tour-metaobject-detail')) {
    customElements.define(
      'santa-rita-tour-metaobject-detail',
      class SantaRitaTourMetaobjectDetail extends HTMLElement {
        connectedCallback() {
          this.form = this.querySelector('[data-tour-booking-form]');
          this.calendarInput = this.querySelector('[data-tour-calendar]');
          this.languageInput = this.querySelector('[data-tour-language]');
          this.timeInput = this.querySelector('[data-tour-time]');
          this.adultsInput = this.querySelector('[data-tour-adults]');
          this.childrenInput = this.querySelector('[data-tour-children]');
          this.totalElement = this.querySelector('[data-tour-total]');
          this.priceCents = Number(this.dataset.priceCents || 0);
          this.currency = this.dataset.priceCurrency || 'CLP';

          [this.adultsInput, this.childrenInput].forEach((input) => {
            input?.addEventListener('change', () => this.updateTotal());
          });

          this.form?.addEventListener('submit', (event) => this.handleSubmit(event));
          this.updateTotal();
          this.initCalendarWhenReady();
        }

        getPeopleCount() {
          const adults = Math.max(1, Number(this.adultsInput?.value || 1));
          const children = Math.max(0, Number(this.childrenInput?.value || 0));

          return adults + children;
        }

        updateTotal() {
          if (!this.totalElement) return;

          const total = this.priceCents * this.getPeopleCount() / 100;

          this.totalElement.textContent = new Intl.NumberFormat('es-CL', {
            style: 'currency',
            currency: this.currency,
            maximumFractionDigits: 0
          }).format(total);
        }

        handleSubmit(event) {
          event.preventDefault();

          if (!this.form?.reportValidity()) return;

          const bookingUrl = this.dataset.bookingUrl;
          if (!bookingUrl) return;

          const url = new URL(bookingUrl, window.location.origin);
          const people = this.getPeopleCount();
          const price = this.priceCents / 100;
          const total = price * people;

          url.searchParams.set('tour', this.dataset.tourHandle || '');
          url.searchParams.set('tour_title', this.dataset.tourTitle || '');
          url.searchParams.set('idioma', this.languageInput?.value || '');
          url.searchParams.set('adultos', this.adultsInput?.value || '1');
          url.searchParams.set('ninos', this.childrenInput?.value || '0');
          url.searchParams.set('personas', String(people));
          url.searchParams.set('fecha', this.calendarInput?.value || '');
          url.searchParams.set('horario', this.timeInput?.value || '');
          url.searchParams.set('precio', String(price));
          url.searchParams.set('total', String(total));
          url.searchParams.set('currency', this.currency);

          window.location.href = url.toString();
        }

        initCalendarWhenReady() {
          let attempts = 0;

          const run = () => {
            attempts += 1;

            if (window.flatpickr && this.calendarInput) {
              this.initCalendar();
              return;
            }

            if (attempts < 80) {
              window.setTimeout(run, 100);
            }
          };

          run();
        }

        initCalendar() {
          if (this.calendarInput.dataset.flatpickrReady === 'true') return;

          const disabledWeekdays = this.parseList(this.dataset.disabledWeekdays).map((day) => Number(day));
          const blockedDates = this.parseList(this.dataset.blockedDates);
          const enabledDates = this.parseList(this.dataset.enabledDates);
          const disable = blockedDates.slice();
          const today = new Date();
          const todayKey = this.formatDateKey(today);
          const isTodayBlocked = blockedDates.includes(todayKey) || disabledWeekdays.includes(today.getDay());
          const isTodayEnabled = enabledDates.length === 0 || enabledDates.includes(todayKey);

          if (disabledWeekdays.length > 0) {
            disable.push((date) => disabledWeekdays.includes(date.getDay()));
          }

          const options = {
            minDate: 'today',
            dateFormat: 'Y-m-d',
            altInput: true,
            altFormat: 'd-m-Y',
            inline: true,
            locale: window.flatpickr.l10ns?.es || {
              firstDayOfWeek: 1
            },
            disable
          };

          if (!isTodayBlocked && isTodayEnabled) {
            options.defaultDate = 'today';
          }

          if (enabledDates.length > 0) {
            options.enable = enabledDates;
          }

          window.flatpickr(this.calendarInput, options);
          this.calendarInput.dataset.flatpickrReady = 'true';
        }

        parseList(value) {
          return String(value || '')
            .split(',')
            .map((item) => item.trim())
            .filter(Boolean);
        }

        formatDateKey(date) {
          const year = date.getFullYear();
          const month = String(date.getMonth() + 1).padStart(2, '0');
          const day = String(date.getDate()).padStart(2, '0');

          return `${year}-${month}-${day}`;
        }
      }
    );
  }
</script>

