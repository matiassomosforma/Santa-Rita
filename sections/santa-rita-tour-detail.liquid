{% liquid
  assign current_product = product
  assign variant = current_product.selected_or_first_available_variant
  assign hero_image = current_product.metafields.custom.tour_banner_image.value | default: current_product.metafields.custom.tour_banner_image | default: current_product.featured_image
  assign hero_subheading = current_product.metafields.custom.tour_hero_subheading.value | default: current_product.metafields.custom.tour_hero_subheading | default: section.settings.hero_subheading
  assign duration = current_product.metafields.custom.tour_duration.value | default: current_product.metafields.custom.tour_duration | default: section.settings.default_duration
  assign people = current_product.metafields.custom.tour_people.value | default: current_product.metafields.custom.tour_people | default: current_product.metafields.custom.tour_capacity.value | default: current_product.metafields.custom.tour_capacity | default: section.settings.default_schedule
  assign languages = current_product.metafields.custom.tour_languages.value | default: current_product.metafields.custom.tour_languages | default: section.settings.default_languages
  assign wines = current_product.metafields.custom.tour_wines.value | default: current_product.metafields.custom.tour_wines | default: section.settings.default_capacity
  assign route_heading = current_product.metafields.custom.tour_route_heading.value | default: current_product.metafields.custom.tour_route_heading | default: section.settings.route_heading
  assign route_stops_text = current_product.metafields.custom.tour_route_stops.value | default: current_product.metafields.custom.tour_route_stops
  assign route_stop_lines = route_stops_text | newline_to_br | split: '<br />'
  assign experience_heading = current_product.metafields.custom.tour_experience_heading.value | default: current_product.metafields.custom.tour_experience_heading | default: section.settings.experience_heading
  assign experience_metafield = current_product.metafields.custom.tour_experience
  assign includes_heading = current_product.metafields.custom.tour_includes_heading.value | default: current_product.metafields.custom.tour_includes_heading | default: section.settings.includes_heading
  assign includes_text = current_product.metafields.custom.tour_includes.value | default: current_product.metafields.custom.tour_includes
  assign include_lines = includes_text | newline_to_br | split: '<br />'
  assign route_blocks = section.blocks | where: 'type', 'route_stop'
  assign inclusion_blocks = section.blocks | where: 'type', 'inclusion'
  assign metric_blocks = section.blocks | where: 'type', 'metric'
  assign product_form_id = 'SantaRitaTourForm-' | append: section.id
  assign time_options_source = current_product.metafields.custom.tour_time_options.value | default: current_product.metafields.custom.tour_time_options | default: section.settings.time_options
  assign language_options_source = current_product.metafields.custom.tour_language_options.value | default: current_product.metafields.custom.tour_language_options | default: section.settings.language_options
  assign max_people = current_product.metafields.custom.tour_max_people.value | default: current_product.metafields.custom.tour_max_people | default: section.settings.max_people
  assign disabled_weekdays = current_product.metafields.custom.tour_disabled_weekdays.value | default: current_product.metafields.custom.tour_disabled_weekdays | default: section.settings.disabled_weekdays
  assign blocked_dates = current_product.metafields.custom.tour_blocked_dates.value | default: current_product.metafields.custom.tour_blocked_dates | default: section.settings.blocked_dates
  assign enabled_dates = current_product.metafields.custom.tour_enabled_dates.value | default: current_product.metafields.custom.tour_enabled_dates | default: section.settings.enabled_dates
  assign time_options = time_options_source | split: ','
  assign language_options = language_options_source | split: ','
%}

{{ 'https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css' | stylesheet_tag }}
<script src="https://cdn.jsdelivr.net/npm/flatpickr" defer></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js" defer></script>

<santa-rita-tour-detail
  class="santa-rita-tour-detail"
  data-section-id="{{ section.id }}"
  data-price-cents="{{ variant.price }}"
  data-disabled-weekdays="{{ disabled_weekdays | escape }}"
  data-blocked-dates="{{ blocked_dates | escape }}"
  data-enabled-dates="{{ enabled_dates | escape }}"
  {{ section.shopify_attributes }}
>
  <section class="santa-rita-tour-detail__hero" aria-labelledby="santa-rita-tour-title-{{ section.id }}">
    {% if hero_image != blank %}
      {{
        hero_image
        | image_url: width: 2200
        | image_tag:
          widths: '480, 720, 990, 1440, 1800, 2200',
          sizes: '100vw',
          loading: 'eager',
          class: 'santa-rita-tour-detail__hero-image'
      }}
    {% elsif request.design_mode %}
      {{ 'image' | placeholder_svg_tag: 'santa-rita-tour-detail__hero-image santa-rita-tour-detail__hero-image--placeholder' }}
    {% endif %}

    <div class="santa-rita-tour-detail__hero-overlay"></div>

    <div class="santa-rita-tour-detail__hero-inner">
      <nav class="santa-rita-tour-detail__breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Inicio</a>
        <span aria-hidden="true">&gt;</span>
        {% if section.settings.tours_page != blank %}
          <a href="{{ section.settings.tours_page.url }}">Tours</a>
        {% else %}
          <span>Tours</span>
        {% endif %}
        <span aria-hidden="true">&gt;</span>
        <span>{{ current_product.title }}</span>
      </nav>

      <div class="santa-rita-tour-detail__hero-content">
        <h1 id="santa-rita-tour-title-{{ section.id }}">{{ current_product.title }}</h1>

        {% if hero_subheading != blank %}
          <p>{{ hero_subheading }}</p>
        {% elsif current_product.description != blank %}
          <p>{{ current_product.description | strip_html | truncatewords: 22 }}</p>
        {% endif %}

        <strong>{{ variant.price | money }}</strong>
        {% if section.settings.price_note != blank %}
          <span>{{ section.settings.price_note }}</span>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="santa-rita-tour-detail__content">
    <div class="santa-rita-tour-detail__metrics">
      {% if metric_blocks.size > 0 %}
        {% for block in metric_blocks %}
          <div class="santa-rita-tour-detail__metric" {{ block.shopify_attributes }}>
            <span>{{ block.settings.icon }}</span>
            <strong>{{ block.settings.value }}</strong>
            <small>{{ block.settings.label }}</small>
          </div>
        {% endfor %}
      {% else %}
        {% if duration != blank %}
          <div class="santa-rita-tour-detail__metric">
            <span>⏱</span>
            <strong>{{ duration }}</strong>
            <small>duracion</small>
          </div>
        {% endif %}
        {% if people != blank %}
          <div class="santa-rita-tour-detail__metric">
            <span>🕒</span>
            <strong>{{ people }}</strong>
            <small>personas</small>
          </div>
        {% endif %}
        {% if languages != blank %}
          <div class="santa-rita-tour-detail__metric">
            <span>🌐</span>
            <strong>{{ languages }}</strong>
            <small>idiomas</small>
          </div>
        {% endif %}
        {% if wines != blank %}
          <div class="santa-rita-tour-detail__metric">
            <span>👥</span>
            <strong>{{ wines }}</strong>
            <small>vinos</small>
          </div>
        {% endif %}
      {% endif %}
    </div>

    <div class="santa-rita-tour-detail__layout">
      <div class="santa-rita-tour-detail__main">
        {% if route_stops_text != blank or route_blocks.size > 0 %}
          <section class="santa-rita-tour-detail__route">
            {% if route_heading != blank %}
              <h2>{{ route_heading }}</h2>
            {% endif %}

            <div class="santa-rita-tour-detail__route-items">
              {% if route_stops_text != blank %}
                {% for route_stop in route_stop_lines %}
                  {% assign route_stop = route_stop | strip %}
                  {% if route_stop != blank %}
                    <article class="santa-rita-tour-detail__route-item">
                      <span>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                      <h3>{{ route_stop }}</h3>
                    </article>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% for block in route_blocks %}
                  <article class="santa-rita-tour-detail__route-item" {{ block.shopify_attributes }}>
                    <span>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                    <h3>{{ block.settings.title }}</h3>
                    {% if block.settings.text != blank %}
                      <div>{{ block.settings.text }}</div>
                    {% endif %}
                  </article>
                {% endfor %}
              {% endif %}
            </div>
          </section>
        {% endif %}

        <section class="santa-rita-tour-detail__experience">
          {% if experience_heading != blank %}
            <h2>{{ experience_heading }}</h2>
          {% endif %}

          {% if experience_metafield != blank %}
            <div>{{ experience_metafield | metafield_tag }}</div>
          {% elsif section.settings.experience_text != blank %}
            <div>{{ section.settings.experience_text }}</div>
          {% elsif current_product.description != blank %}
            <div>{{ current_product.description }}</div>
          {% endif %}
        </section>

        {% if includes_text != blank or inclusion_blocks.size > 0 %}
          <section class="santa-rita-tour-detail__includes">
            {% if includes_heading != blank %}
              <h2>{{ includes_heading }}</h2>
            {% endif %}

            <div class="santa-rita-tour-detail__includes-grid">
              {% if includes_text != blank %}
                {% for include_line in include_lines %}
                  {% assign include_line = include_line | strip %}
                  {% if include_line != blank %}
                    {% assign include_parts = include_line | split: '|' %}
                    {% assign include_icon = include_parts[0] | strip %}
                    {% assign include_text = include_parts[1] | default: include_parts[0] | strip %}
                    <div class="santa-rita-tour-detail__include">
                      {% if include_parts[1] != blank %}
                        <span aria-hidden="true">{{ include_icon }}</span>
                      {% endif %}
                      <p>{{ include_text }}</p>
                    </div>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% for block in inclusion_blocks %}
                  <div class="santa-rita-tour-detail__include" {{ block.shopify_attributes }}>
                    <span aria-hidden="true">{{ block.settings.icon }}</span>
                    <p>{{ block.settings.text }}</p>
                  </div>
                {% endfor %}
              {% endif %}
            </div>
          </section>
        {% endif %}
      </div>

      <aside class="santa-rita-tour-detail__reserve" aria-labelledby="santa-rita-tour-reserve-title-{{ section.id }}">
        <h2 id="santa-rita-tour-reserve-title-{{ section.id }}">{{ section.settings.reserve_heading }}</h2>

        <div class="santa-rita-tour-detail__reserve-body">
          <product-form-component
            data-section-id="{{ section.id }}"
            data-product-id="{{ current_product.id }}"
            data-product-url="{{ current_product.url }}"
            data-quantity-default="1"
            data-quantity-error-max="{{ 'products.product.quantity_error_max' | t }}"
            on:submit="/handleSubmit"
          >
            <div
              class="visually-hidden"
              aria-live="assertive"
              role="status"
              aria-atomic="true"
              ref="liveRegion"
            ></div>

            {% form 'product', current_product, id: product_form_id, class: 'santa-rita-tour-detail__form', data-type: 'add-to-cart-form' %}
              <input type="hidden" name="id" ref="variantId" value="{{ variant.id }}">

              <div class="santa-rita-tour-detail__field">
                <label for="TourLanguage-{{ section.id }}">{{ section.settings.language_label }}</label>
                <select id="TourLanguage-{{ section.id }}" name="properties[Idioma]" required>
                  {% for option in language_options %}
                    {% assign option_value = option | strip %}
                    {% if option_value != blank %}
                      <option value="{{ option_value | escape }}">{{ option_value }}</option>
                    {% endif %}
                  {% endfor %}
                </select>
              </div>

              <div class="santa-rita-tour-detail__fields">
                <div class="santa-rita-tour-detail__field">
                  <label for="TourPeople-{{ section.id }}">{{ section.settings.people_label }}</label>
                  <input
                    id="TourPeople-{{ section.id }}"
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="{{ max_people }}"
                    required
                    data-tour-people
                  >
                  <input type="hidden" name="properties[Personas]" value="1" data-tour-people-property>
                </div>

                <div class="santa-rita-tour-detail__field">
                  <label for="TourTime-{{ section.id }}">{{ section.settings.time_label }}</label>
                  <select id="TourTime-{{ section.id }}" name="properties[Horario]" required>
                    {% for option in time_options %}
                      {% assign option_value = option | strip %}
                      {% if option_value != blank %}
                        <option value="{{ option_value | escape }}">{{ option_value }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="santa-rita-tour-detail__field">
                <label for="TourDate-{{ section.id }}">{{ section.settings.date_label }}</label>
                <input
                  id="TourDate-{{ section.id }}"
                  type="text"
                  name="properties[Fecha]"
                  placeholder="{{ section.settings.date_placeholder }}"
                  required
                  data-tour-calendar
                >
              </div>

              {% if section.settings.reserve_note != blank %}
                <p class="santa-rita-tour-detail__reserve-note">{{ section.settings.reserve_note }}</p>
              {% endif %}

              <div class="santa-rita-tour-detail__total">
                <span>{{ section.settings.total_label }}</span>
                <strong data-tour-total>{{ variant.price | money }}</strong>
              </div>

              <add-to-cart-component
                ref="addToCartButtonContainer"
                data-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
              >
                <button
                  type="submit"
                  name="add"
                  ref="addToCartButton"
                  on:click="/handleClick"
                  class="santa-rita-tour-detail__submit"
                  {% unless variant.available %}
                    disabled
                  {% endunless %}
                >
                  {% if variant.available %}
                    {{ section.settings.reserve_button_label }}
                  {% else %}
                    {{ 'products.product.sold_out' | t }}
                  {% endif %}
                </button>
              </add-to-cart-component>
            {% endform %}
          </product-form-component>
        </div>
      </aside>
    </div>
  </div>
</santa-rita-tour-detail>

<script>
  if (!customElements.get('santa-rita-tour-detail')) {
    customElements.define(
      'santa-rita-tour-detail',
      class SantaRitaTourDetail extends HTMLElement {
        connectedCallback() {
          this.calendarInput = this.querySelector('[data-tour-calendar]');
          this.peopleInput = this.querySelector('[data-tour-people]');
          this.peoplePropertyInput = this.querySelector('[data-tour-people-property]');
          this.totalElement = this.querySelector('[data-tour-total]');
          this.priceCents = Number(this.dataset.priceCents || 0);

          this.peopleInput?.addEventListener('input', () => {
            this.syncPeopleProperty();
            this.updateTotal();
          });

          this.syncPeopleProperty();
          this.updateTotal();
          this.initCalendarWhenReady();
        }

        initCalendarWhenReady() {
          let attempts = 0;

          const run = () => {
            attempts += 1;

            if (window.flatpickr && this.calendarInput) {
              this.initCalendar();
              return;
            }

            if (attempts < 80) {
              window.setTimeout(run, 100);
            }
          };

          run();
        }

        initCalendar() {
          if (this.calendarInput.dataset.flatpickrReady === 'true') return;

          const disabledWeekdays = this.parseList(this.dataset.disabledWeekdays).map((day) => Number(day));
          const blockedDates = this.parseList(this.dataset.blockedDates);
          const enabledDates = this.parseList(this.dataset.enabledDates);
          const disable = blockedDates.slice();

          if (disabledWeekdays.length > 0) {
            disable.push((date) => disabledWeekdays.includes(date.getDay()));
          }

          const options = {
            minDate: 'today',
            dateFormat: 'Y-m-d',
            altInput: true,
            altFormat: 'd-m-Y',
            inline: true,
            locale: window.flatpickr.l10ns?.es || {
              firstDayOfWeek: 1
            },
            disable
          };

          if (enabledDates.length > 0) {
            options.enable = enabledDates;
          }

          window.flatpickr(this.calendarInput, options);
          this.calendarInput.dataset.flatpickrReady = 'true';
        }

        parseList(value) {
          return String(value || '')
            .split(',')
            .map((item) => item.trim())
            .filter(Boolean);
        }

        syncPeopleProperty() {
          if (!this.peopleInput || !this.peoplePropertyInput) return;

          this.peoplePropertyInput.value = this.peopleInput.value || '1';
        }

        updateTotal() {
          if (!this.totalElement || !this.peopleInput) return;

          const quantity = Math.max(1, Number(this.peopleInput.value || 1));
          const total = this.priceCents * quantity / 100;

          this.totalElement.textContent = new Intl.NumberFormat('es-CL', {
            style: 'currency',
            currency: 'CLP',
            maximumFractionDigits: 0
          }).format(total);
        }
      }
    );
  }
</script>

<style>
  .santa-rita-tour-detail {
    display: block;
    background: #fffbf6;
    color: #21000f;
  }

  .santa-rita-tour-detail__hero {
    position: relative;
    display: grid;
    min-height: clamp(310px, 31vw, 430px);
    overflow: hidden;
    background: #21000f;
    color: #ffffff;
  }

  .santa-rita-tour-detail__hero-image,
  .santa-rita-tour-detail__hero-image--placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .santa-rita-tour-detail__hero-image--placeholder {
    background: #2c0518;
    fill: rgba(255, 255, 255, 0.2);
  }

  .santa-rita-tour-detail__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(33, 0, 15, 0.42), rgba(33, 0, 15, 0.72));
  }

  .santa-rita-tour-detail__hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    width: min(100% - 48px, 1140px);
    min-height: inherit;
    flex-direction: column;
    margin-inline: auto;
    padding-block: 24px 56px;
  }

  .santa-rita-tour-detail__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    align-items: center;
    font-size: 12px;
    line-height: 1.2;
  }

  .santa-rita-tour-detail__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-tour-detail__hero-content {
    width: min(100%, 720px);
    margin: auto auto 0;
    text-align: center;
  }

  .santa-rita-tour-detail__hero-content h1 {
    margin: 0 0 12px;
    font-family: var(--font-heading--family);
    font-size: clamp(36px, 4.1vw, 58px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: 0;
  }

  .santa-rita-tour-detail__hero-content p {
    width: min(100%, 560px);
    margin: 0 auto 14px;
    font-size: 16px;
    line-height: 1.42;
  }

  .santa-rita-tour-detail__hero-content strong,
  .santa-rita-tour-detail__hero-content span {
    display: inline-block;
    font-size: 16px;
  }

  .santa-rita-tour-detail__content {
    width: min(100% - 48px, 1080px);
    margin-inline: auto;
    padding-block: 34px 74px;
  }

  .santa-rita-tour-detail__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 34px;
  }

  .santa-rita-tour-detail__metric {
    display: grid;
    justify-items: center;
    gap: 6px;
    border-radius: 6px;
    background: #fff8f1;
    padding: 18px 12px;
    text-align: center;
  }

  .santa-rita-tour-detail__metric span {
    display: grid;
    width: 28px;
    height: 28px;
    place-items: center;
    border-radius: 50%;
    background: #fff0f3;
    color: #8c1a3e;
    font-size: 14px;
  }

  .santa-rita-tour-detail__metric strong {
    font-size: 15px;
    line-height: 1.15;
  }

  .santa-rita-tour-detail__metric small {
    color: #6e5a61;
    font-size: 11px;
    line-height: 1.15;
  }

  .santa-rita-tour-detail__layout {
    display: grid;
    grid-template-columns: minmax(0, 690px) minmax(260px, 285px);
    justify-content: center;
    gap: 32px;
    align-items: start;
  }

  .santa-rita-tour-detail__main {
    display: grid;
    gap: 34px;
  }

  .santa-rita-tour-detail__route {
    border-radius: 8px;
    background: #250012;
    color: #ffffff;
    padding: 32px 34px;
  }

  .santa-rita-tour-detail h2 {
    margin: 0 0 22px;
    font-family: var(--font-heading--family);
    font-size: clamp(22px, 2vw, 28px);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .santa-rita-tour-detail__route-items {
    display: grid;
    gap: 0;
  }

  .santa-rita-tour-detail__route-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: 14px;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    padding-block: 15px;
  }

  .santa-rita-tour-detail__route-item:first-child {
    border-top: 0;
  }

  .santa-rita-tour-detail__route-item span {
    display: grid;
    width: 28px;
    height: 28px;
    place-items: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.14);
    font-size: 12px;
    font-weight: 700;
  }

  .santa-rita-tour-detail__route-item h3 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 15px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .santa-rita-tour-detail__route-item div {
    grid-column: 2;
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 13px;
    line-height: 1.4;
  }

  .santa-rita-tour-detail__route-item div p,
  .santa-rita-tour-detail__experience div p {
    margin: 0;
  }

  .santa-rita-tour-detail__route-item div p + p,
  .santa-rita-tour-detail__experience div p + p {
    margin-top: 12px;
  }

  .santa-rita-tour-detail__experience {
    width: min(100%, 690px);
    padding-inline: 34px;
  }

  .santa-rita-tour-detail__experience h2 {
    margin-bottom: 18px;
  }

  .santa-rita-tour-detail__experience div {
    color: #2f2026;
    font-size: 14px;
    line-height: 1.62;
  }

  .santa-rita-tour-detail__includes {
    width: min(100%, 690px);
    border-radius: 8px;
    background: #fff8f1;
    padding: 32px 36px;
  }

  .santa-rita-tour-detail__includes-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 18px;
  }

  .santa-rita-tour-detail__include {
    display: grid;
    justify-items: center;
    gap: 10px;
    text-align: center;
  }

  .santa-rita-tour-detail__include span {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 50%;
    background: #fff0e7;
    color: #8c1a3e;
    font-size: 18px;
  }

  .santa-rita-tour-detail__include p {
    margin: 0;
    color: #4f3c43;
    font-size: 12px;
    line-height: 1.25;
  }

  .santa-rita-tour-detail__reserve {
    position: sticky;
    top: calc(var(--header-height, 0px) + 20px);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #8c1a3e;
    background: #ffffff;
    color: #21000f;
    box-shadow: 0 10px 26px rgba(140, 26, 62, 0.16);
  }

  .santa-rita-tour-detail__reserve h2 {
    display: flex;
    min-height: 48px;
    align-items: center;
    margin: 0;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 17px;
    padding: 14px 18px;
  }

  .santa-rita-tour-detail__reserve-body {
    padding: 14px 14px 16px;
  }

  .santa-rita-tour-detail__form {
    display: grid;
    gap: 10px;
  }

  .santa-rita-tour-detail__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .santa-rita-tour-detail__field {
    display: grid;
    gap: 5px;
  }

  .santa-rita-tour-detail__field label {
    color: #21000f;
    font-size: 10px;
    font-weight: 700;
    line-height: 1.2;
  }

  .santa-rita-tour-detail__field input,
  .santa-rita-tour-detail__field select {
    width: 100%;
    min-height: 34px;
    border: 1px solid rgba(140, 26, 62, 0.18);
    border-radius: 4px;
    background: #ffffff;
    color: #21000f;
    font: inherit;
    font-size: 11px;
    padding: 0 10px;
  }

  .santa-rita-tour-detail__reserve .flatpickr-calendar {
    width: 100%;
    margin-top: 2px;
    border: 0;
    border-radius: 6px;
    font-size: 11px;
    box-shadow: none;
  }

  .santa-rita-tour-detail__reserve .flatpickr-months {
    align-items: center;
  }

  .santa-rita-tour-detail__reserve .flatpickr-month,
  .santa-rita-tour-detail__reserve .flatpickr-current-month {
    height: 30px;
  }

  .santa-rita-tour-detail__reserve .flatpickr-current-month {
    padding-top: 2px;
    font-size: 12px;
  }

  .santa-rita-tour-detail__reserve .flatpickr-weekday {
    color: #8c1a3e;
    font-size: 10px;
    font-weight: 700;
  }

  .santa-rita-tour-detail__reserve .flatpickr-rContainer,
  .santa-rita-tour-detail__reserve .flatpickr-days,
  .santa-rita-tour-detail__reserve .dayContainer {
    width: 100%;
    min-width: 100%;
    max-width: 100%;
  }

  .santa-rita-tour-detail__reserve .flatpickr-day {
    height: 27px;
    line-height: 27px;
    max-width: none;
    color: #21000f;
    font-size: 11px;
  }

  .santa-rita-tour-detail__reserve .flatpickr-day.selected,
  .santa-rita-tour-detail__reserve .flatpickr-day.startRange,
  .santa-rita-tour-detail__reserve .flatpickr-day.endRange {
    border-color: #8c1a3e;
    background: #8c1a3e;
  }

  .santa-rita-tour-detail__reserve-note {
    margin: 0;
    color: #6e5a61;
    font-size: 11px;
    line-height: 1.35;
  }

  .santa-rita-tour-detail__total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid rgba(140, 26, 62, 0.14);
    padding-top: 10px;
    font-size: 11px;
  }

  .santa-rita-tour-detail__total strong {
    font-size: 12px;
  }

  .santa-rita-tour-detail__submit {
    display: inline-flex;
    width: 100%;
    min-height: 34px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font: inherit;
    font-size: 11px;
    font-weight: 800;
  }

  .santa-rita-tour-detail__submit:disabled {
    cursor: not-allowed;
    opacity: 0.62;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-tour-detail__layout {
      grid-template-columns: 1fr;
    }

    .santa-rita-tour-detail__reserve {
      position: static;
      max-width: 460px;
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-tour-detail__hero-inner,
    .santa-rita-tour-detail__content {
      width: calc(100% - 24px);
    }

    .santa-rita-tour-detail__hero {
      min-height: 380px;
    }

    .santa-rita-tour-detail__breadcrumbs {
      display: none;
    }

    .santa-rita-tour-detail__hero-inner {
      padding-block: 22px 34px;
    }

    .santa-rita-tour-detail__hero-content {
      text-align: left;
    }

    .santa-rita-tour-detail__hero-content p {
      margin-inline: 0;
    }

    .santa-rita-tour-detail__content {
      padding-block: 24px 50px;
    }

    .santa-rita-tour-detail__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .santa-rita-tour-detail__route,
    .santa-rita-tour-detail__experience,
    .santa-rita-tour-detail__includes,
    .santa-rita-tour-detail__reserve {
      padding: 24px;
    }

    .santa-rita-tour-detail__includes-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .santa-rita-tour-detail__fields {
      grid-template-columns: 1fr;
    }
  }
</style>

