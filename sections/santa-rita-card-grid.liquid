{% liquid
  assign columns_desktop = section.settings.columns_desktop | default: '3'
  assign color_scheme = section.settings.color_scheme | default: 'light'
  assign image_ratio = section.settings.image_ratio | default: 'wide'
%}

{% if section.settings.show_section %}
  <section
    class="santa-rita-card-grid santa-rita-card-grid--{{ color_scheme }} santa-rita-card-grid--{{ image_ratio }}"
    style="--sr-card-columns: {{ columns_desktop }};"
    {{ section.shopify_attributes }}
  >
    <div class="santa-rita-card-grid__inner">
      {% if section.settings.heading != blank or section.settings.text != blank %}
        <div class="santa-rita-card-grid__header">
          {% if section.settings.heading != blank %}
            <h2>{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.text != blank %}
            <p>{{ section.settings.text }}</p>
          {% endif %}
        </div>
      {% endif %}

      <div class="santa-rita-card-grid__list">
        {% for block in section.blocks %}
          {% if block.settings.show_card %}
            <article class="santa-rita-card-grid__card" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    widths: '320, 480, 640, 900',
                    sizes: '(min-width: 990px) 33vw, 100vw',
                    loading: 'lazy',
                    class: 'santa-rita-card-grid__image'
                }}
              {% elsif request.design_mode %}
                {{ 'image' | placeholder_svg_tag: 'santa-rita-card-grid__image santa-rita-card-grid__image--placeholder' }}
              {% endif %}

              <div class="santa-rita-card-grid__body">
                {% if block.settings.title != blank %}
                  <h3>{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="santa-rita-card-grid__text">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

                {% if block.settings.button_label != blank and block.settings.button_url != blank %}
                  <a href="{{ block.settings.button_url }}" class="santa-rita-card-grid__button">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

<style>
  .santa-rita-card-grid {
    display: block;
    background: #fffbf6;
    color: #21000f;
  }

  .santa-rita-card-grid--dark {
    background: #21000f;
    color: #ffffff;
  }

  .santa-rita-card-grid__inner {
    width: min(100% - 48px, 1140px);
    margin-inline: auto;
    padding-block: 56px;
  }

  .santa-rita-card-grid__header {
    max-width: 760px;
    margin-bottom: 30px;
  }

  .santa-rita-card-grid__header h2 {
    margin: 0 0 8px;
    font-family: var(--font-heading--family);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .santa-rita-card-grid__header p {
    margin: 0;
    font-size: 16px;
    line-height: 1.45;
  }

  .santa-rita-card-grid__list {
    display: grid;
    grid-template-columns: repeat(var(--sr-card-columns, 3), minmax(0, 1fr));
    gap: 28px;
  }

  .santa-rita-card-grid__card {
    display: grid;
    overflow: hidden;
    border-radius: 4px;
    background: #fdf8f1;
    color: #21000f;
    box-shadow: 0 10px 10px 0 rgba(140, 26, 62, 0.05);
  }

  .santa-rita-card-grid--dark .santa-rita-card-grid__card {
    background: #fffbf6;
  }

  .santa-rita-card-grid__image,
  .santa-rita-card-grid__image--placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 1.45 / 1;
    object-fit: cover;
  }

  .santa-rita-card-grid--square .santa-rita-card-grid__image,
  .santa-rita-card-grid--square .santa-rita-card-grid__image--placeholder {
    aspect-ratio: 1 / 1;
  }

  .santa-rita-card-grid--portrait .santa-rita-card-grid__image,
  .santa-rita-card-grid--portrait .santa-rita-card-grid__image--placeholder {
    aspect-ratio: 4 / 5;
  }

  .santa-rita-card-grid__image--placeholder {
    background: #eadfd5;
    fill: rgba(140, 26, 62, 0.22);
  }

  .santa-rita-card-grid__body {
    display: grid;
    gap: 10px;
    padding: 18px;
  }

  .santa-rita-card-grid__body h3 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .santa-rita-card-grid__text {
    color: #1e0812;
    font-size: 14px;
    line-height: 1.45;
  }

  .santa-rita-card-grid__text p {
    margin: 0;
  }

  .santa-rita-card-grid__button {
    justify-self: start;
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: #8c1a3e;
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    padding-inline: 14px;
    text-decoration: none;
  }

  @media screen and (max-width: 989px) {
    .santa-rita-card-grid__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .santa-rita-card-grid__inner {
      width: calc(100% - 40px);
      padding-block: 36px;
    }

    .santa-rita-card-grid__header {
      margin-bottom: 22px;
    }

    .santa-rita-card-grid__header h2 {
      font-size: 25px;
    }

    .santa-rita-card-grid__header p {
      font-size: 13px;
    }

    .santa-rita-card-grid__list {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .santa-rita-card-grid__body {
      padding: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "SR grilla de tarjetas",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Mostrar seccion",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Fondo",
      "default": "light",
      "options": [
        {
          "value": "light",
          "label": "Claro"
        },
        {
          "value": "dark",
          "label": "Burdeo"
        }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Espacios singulares"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Bajada",
      "default": "Edita los contenidos y decide cuantas tarjetas se ven por fila."
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Tarjetas por fila en desktop",
      "default": "3",
      "options": [
        {
          "value": "2",
          "label": "2 por fila"
        },
        {
          "value": "3",
          "label": "3 por fila"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Formato de imagen",
      "default": "wide",
      "options": [
        {
          "value": "wide",
          "label": "Horizontal"
        },
        {
          "value": "square",
          "label": "Cuadrada"
        },
        {
          "value": "portrait",
          "label": "Vertical"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Tarjeta",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_card",
          "label": "Mostrar tarjeta",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Titulo de tarjeta"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texto",
          "default": "<p>Agrega una descripcion breve para esta tarjeta.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texto boton"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Link boton"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SR grilla de tarjetas",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
