  .santa-rita-product-hero__inner {
    width: min(100% - 40px, 1120px);
    margin: 0 auto;
    padding: 30px 0 64px;
  }

  .santa-rita-product-hero__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    align-items: center;
    margin-bottom: 46px;
    font-size: 12px;
    line-height: 1.3;
    color: #271f20;
  }

  .santa-rita-product-hero__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .santa-rita-product-hero__breadcrumbs a:hover {
    text-decoration: underline;
  }

  .santa-rita-product-hero__grid {
    display: grid;
    grid-template-columns: minmax(320px, 1.08fr) minmax(320px, 0.92fr);
    gap: clamp(48px, 7vw, 112px);
    align-items: start;
  }

  .santa-rita-product-hero__media {
    display: flex;
    justify-content: center;
    min-height: 430px;
  }

  .santa-rita-product-hero__image {
    display: block;
    width: min(100%, 360px);
    height: min(56vw, 470px);
    object-fit: contain;
  }

  .santa-rita-product-hero__image--placeholder {
    background: transparent;
  }

  .santa-rita-product-hero__details {
    max-width: 520px;
    padding-top: 6px;
  }

  .santa-rita-product-hero__discount {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 0 12px;
    margin-bottom: 18px;
    border-radius: 999px;
    background: #9d1238;
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
  }

  .santa-rita-product-hero__title {
    max-width: 500px;
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(42px, 4.1vw, 56px);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .santa-rita-product-hero__subtitle {
    margin: 18px 0 0;
    font-size: 20px;
    line-height: 1.35;
  }

  .santa-rita-product-hero__rating {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 18px;
    font-size: 14px;
    line-height: 1;
  }

  .santa-rita-product-hero__stars {
    display: inline-flex;
    gap: 1px;
    color: #b7a8a1;
    font-size: 17px;
  }

  .santa-rita-product-hero__star.is-filled {
    color: #b0123f;
  }

  .santa-rita-product-hero__rating-count {
    color: #5b5051;
  }

  .santa-rita-product-hero__price {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 28px;
  }

  .santa-rita-product-hero__price strong {
    font-size: 26px;
    font-weight: 800;
    line-height: 1;
  }

  .santa-rita-product-hero__price s {
    color: #7d7071;
    font-size: 15px;
  }

  .santa-rita-product-hero__pack {
    margin: 8px 0 0;
    color: #7d7071;
    font-size: 13px;
    line-height: 1.3;
  }

  .santa-rita-product-hero__add {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: min(100%, 490px);
    min-height: 48px;
    margin-top: 22px;
    padding: 0 28px;
    border: 0;
    border-radius: 10px;
    background: #9d1238;
    color: #ffffff;
    font: inherit;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 160ms ease;
  }

  .santa-rita-product-hero__add:hover {
    background: #7f0f2f;
  }

  .santa-rita-product-hero__add:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .santa-rita-product-hero__add-icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
  }

  .santa-rita-product-hero__add-icon svg {
    width: 100%;
    height: 100%;
  }

  .santa-rita-product-hero__description {
    max-width: 490px;
    margin: 44px 0 0;
    font-size: 15px;
    line-height: 1.42;
  }

  @media screen and (max-width: 749px) {
    .santa-rita-product-hero::after {
      height: 260px;
    }

    .santa-rita-product-hero__inner {
      width: min(100% - 32px, 520px);
      padding: 22px 0 42px;
    }

    .santa-rita-product-hero__breadcrumbs {
      margin-bottom: 28px;
    }

    .santa-rita-product-hero__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .santa-rita-product-hero__media {
      min-height: 320px;
    }

    .santa-rita-product-hero__image {
      width: min(100%, 280px);
      height: 340px;
    }

    .santa-rita-product-hero__details {
      max-width: none;
      padding-top: 0;
    }

    .santa-rita-product-hero__title {
      font-size: clamp(38px, 12vw, 48px);
    }

    .santa-rita-product-hero__add,
    .santa-rita-product-hero__description {
      width: 100%;
      max-width: none;
    }

    .santa-rita-product-hero__description {
      margin-top: 30px;
    }
  }
</style>
