{% liquid
  assign product = closest.product | default: product
  assign variant = product.selected_or_first_available_variant
  assign image = variant.featured_image | default: product.featured_image
  assign breadcrumb_collection = blank
  assign pack_label = product.metafields.custom.pack_label.value | default: product.metafields.custom.pack_label | default: section.settings.product_hero_pack_label | default: '12 Unidades | 750cc.'
  assign rating = product.metafields.reviews.rating.value.rating | default: product.metafields.custom.rating.value | default: section.settings.product_hero_default_rating | default: '4.2'
  assign rating_count = product.metafields.reviews.rating_count | default: product.metafields.custom.rating_count.value | default: product.metafields.custom.rating_count | default: section.settings.product_hero_default_rating_count | default: '134'
  assign description = product.description | strip_html
  assign discount_percent = 0

  if variant.compare_at_price > variant.price
    assign discount_value = variant.compare_at_price | minus: variant.price
    assign discount_percent = discount_value | times: 100 | divided_by: variant.compare_at_price | round
  endif

  assign rating_number = rating | times: 1.0
  assign filled_stars = rating_number | floor
  assign can_add_to_cart = variant.available
  assign add_to_cart_text = 'Agregar'
  assign product_variant_media = ''

  capture subtitle
    if product.metafields.custom.subtitle != blank
      echo product.metafields.custom.subtitle.value | default: product.metafields.custom.subtitle
    elsif product.metafields.custom.cepa != blank
      echo product.metafields.custom.cepa.value | default: product.metafields.custom.cepa
    elsif product.metafields.custom.varietal != blank
      echo product.metafields.custom.varietal.value | default: product.metafields.custom.varietal
    else
      echo product.type
    endif
  endcapture

  assign subtitle = subtitle | strip

  if image != blank
    assign product_variant_media = image | image_url: width: 120
  endif

  unless can_add_to_cart
    assign add_to_cart_text = 'products.product.sold_out' | t
  endunless

  for product_collection in product.collections
    if product_collection.handle == 'vinos' or product_collection.title == 'Vinos'
      assign breadcrumb_collection = product_collection
      break
    endif
  endfor

  assign breadcrumb_collection = breadcrumb_collection | default: product.collections.first
%}

<section class="santa-rita-product-hero color-{{ section.settings.color_scheme }}">
  <div class="santa-rita-product-hero__inner">
    {% if section.settings.product_hero_show_breadcrumbs != false %}
      <nav class="santa-rita-product-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Inicio</a>
        <span aria-hidden="true">></span>
        {% if breadcrumb_collection != blank %}
          <a href="{{ breadcrumb_collection.url }}">Vinos</a>
        {% else %}
          <a href="{{ routes.all_products_collection_url }}">Vinos</a>
        {% endif %}
        <span aria-hidden="true">></span>
        <span>{{ product.title }}</span>
      </nav>
    {% endif %}

    <div class="santa-rita-product-hero__grid">
      <div class="santa-rita-product-hero__media">
        {% if image != blank %}
          {{
            image
            | image_url: width: 780
            | image_tag:
              class: 'santa-rita-product-hero__image',
              widths: '360, 520, 680, 780, 960',
              sizes: '(min-width: 990px) 420px, 70vw',
              loading: 'eager'
          }}
        {% else %}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'santa-rita-product-hero__image santa-rita-product-hero__image--placeholder' }}
        {% endif %}
      </div>

      <div class="santa-rita-product-hero__details">
        {% if discount_percent > 0 %}
          <span class="santa-rita-product-hero__discount">-{{ discount_percent }}%</span>
        {% endif %}

        <h1 class="santa-rita-product-hero__title">{{ product.title }}</h1>

        {% if subtitle != blank %}
          <p class="santa-rita-product-hero__subtitle">{{ subtitle }}</p>
        {% endif %}

        {% if rating != blank %}
          <div class="santa-rita-product-hero__rating" aria-label="{{ rating_number | round: 1 }} de 5 estrellas">
            <span class="santa-rita-product-hero__rating-number">{{ rating_number | round: 1 }}</span>
            <span class="santa-rita-product-hero__stars" aria-hidden="true">
              {% for index in (1..5) %}
                <span class="santa-rita-product-hero__star{% if index <= filled_stars %} is-filled{% endif %}">★</span>
              {% endfor %}
            </span>
            {% if rating_count != blank %}
              <span class="santa-rita-product-hero__rating-count">({{ rating_count }})</span>
            {% endif %}
          </div>
        {% endif %}

        <div class="santa-rita-product-hero__price">
          <strong>{{ variant.price | money }}</strong>
          {% if variant.compare_at_price > variant.price %}
            <s>{{ variant.compare_at_price | money }}</s>
          {% endif %}
        </div>

        {% if pack_label != blank %}
          <p class="santa-rita-product-hero__pack">{{ pack_label }}</p>
        {% endif %}

        {% assign product_form_id = 'SantaRitaProductHeroForm-' | append: section.id %}
        <product-form-component
          data-section-id="{{ section.id }}"
          data-product-id="{{ product.id }}"
          data-product-url="{{ product.url }}"
          data-quantity-default="1"
          data-quantity-error-max="{{ 'products.product.quantity_error_max' | t }}"
          on:submit="/handleSubmit"
        >
          <div
            class="visually-hidden"
            aria-live="assertive"
            role="status"
            aria-atomic="true"
            ref="liveRegion"
          ></div>

          {% form 'product', product, id: product_form_id, data-type: 'add-to-cart-form' %}
            <input
              type="hidden"
              name="id"
              ref="variantId"
              value="{{ variant.id }}"
            >
            <add-to-cart-component
              ref="addToCartButtonContainer"
              data-product-variant-media="{{ product_variant_media }}"
              data-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
            >
              <button
                type="submit"
                name="add"
                ref="addToCartButton"
                on:click="/handleClick"
                class="santa-rita-product-hero__add"
                {% unless can_add_to_cart %}
                  disabled
                {% endunless %}
              >
                {% if can_add_to_cart %}
                  <span class="santa-rita-product-hero__add-icon" aria-hidden="true">
                    {{ 'icon-add-to-cart.svg' | inline_asset_content }}
                  </span>
                {% endif %}
                <span>{{ add_to_cart_text }}</span>
              </button>
            </add-to-cart-component>
          {% endform %}
        </product-form-component>

        {% if description != blank %}
          <p class="santa-rita-product-hero__description">{{ description | truncatewords: 62 }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

