{% liquid
  assign link_target = ''
  assign link_rel = ''

  if dispatch_section.settings.open_external_links
    assign link_target = '_blank'
    assign link_rel = 'noopener noreferrer'
  endif
%}

<div class="santa-rita-dispatch-tabs__card">
  {% if title != blank %}
    <h2 class="santa-rita-dispatch-tabs__title">{{ title }}</h2>
  {% endif %}

  <h3 class="santa-rita-dispatch-tabs__mobile-kicker">Días de despacho</h3>

  {% if text != blank or cutoff != blank %}
    <p class="santa-rita-dispatch-tabs__intro">
      {{ text }}
      {% if cutoff != blank %}
        <strong>{{ cutoff }}</strong>
      {% endif %}
    </p>
  {% endif %}

  <div class="santa-rita-dispatch-tabs__search" role="search">
    <label class="santa-rita-dispatch-tabs__search-field">
      <span class="visually-hidden">{{ dispatch_section.settings.search_placeholder }}</span>
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
        <path d="M9.17 15.83a6.67 6.67 0 1 0 0-13.33 6.67 6.67 0 0 0 0 13.33ZM14.17 14.17 17.5 17.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        placeholder="{{ dispatch_section.settings.search_placeholder }}"
        autocomplete="off"
        data-dispatch-search
      >
    </label>
    <button type="button" data-dispatch-search-button class="santa-rita__button santa-rita__button-full">
      {{ dispatch_section.settings.search_button_label }}
    </button>
  </div>

  <p class="santa-rita-dispatch-tabs__results-label">{{ dispatch_section.settings.suggestions_label }}</p>

  <div class="santa-rita-dispatch-tabs__results">
    {% for block in dispatch_section.blocks %}
      {% if block.type == 'dispatch_item' and block.settings.zone == zone %}
        {% capture search_value %}
          {{ block.settings.name }}
          {{ block.settings.days }}
          {{ block.settings.price }}
          {{ block.settings.search_terms }}
        {% endcapture %}

        <article
          class="santa-rita-dispatch-tabs__item"
          data-dispatch-item
          data-suggestion="{{ block.settings.is_suggestion }}"
          data-search="{{ search_value | strip | escape }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.name != blank %}
            <h3>{{ block.settings.name }}</h3>
          {% endif %}

          {% if block.settings.days != blank or block.settings.price != blank %}
            <p>
              {% if block.settings.days != blank %}
                {{ block.settings.days }}
              {% endif %}
              {% if block.settings.days != blank and block.settings.price != blank %}
                |
              {% endif %}
              {% if block.settings.price != blank %}
                {{ block.settings.price }}
              {% endif %}
            </p>
          {% endif %}
        </article>
      {% endif %}
    {% endfor %}

    <p class="santa-rita-dispatch-tabs__empty" data-dispatch-empty hidden>
      {{ dispatch_section.settings.empty_text }}
    </p>
  </div>

  {% if show_alert and dispatch_section.settings.alert_text != blank %}
    <div class="santa-rita-dispatch-tabs__alert">
      <span class="santa-rita-dispatch-tabs__alert-icon" aria-hidden="true">i</span>
      <div>
        {% if dispatch_section.settings.alert_title != blank %}
          <h3>{{ dispatch_section.settings.alert_title }}</h3>
        {% endif %}
        <div class="santa-rita-dispatch-tabs__alert-text">
          {{ dispatch_section.settings.alert_text }}
        </div>
      </div>
    </div>
  {% endif %}
</div>

<div class="santa-rita-dispatch-tabs__contact">
  <span class="santa-rita-dispatch-tabs__contact-icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="39" height="39" viewBox="0 0 39 39" fill="none">
